@page
@model ViewPreferencesModel
@{
    ViewData["ActivePage"] = ManageNavPages.ViewPreferences;
    ViewData["Title"] = "Widok";
}

<style>
    .Page-Box-Items {
        width: auto !important;
        flex: 1 1 auto !important;
        min-width: 0 !important;
        max-width: 1100px !important;
        align-items: stretch !important;
        padding: 0 24px !important;
    }

    .vp-info-banner {
        background: #f8f9fc;
        border-radius: 6px;
        padding: 18px 22px;
        margin-bottom: 25px;
        font-size: 13px;
        color: #5a5c69;
        line-height: 1.6;
    }

        .vp-info-banner strong {
            color: #2e3035;
        }

    .vp-section {
        background: #FFF;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.03);
        border: 1px solid #edf0f2;
        margin-bottom: 25px;
    }

    .vp-cards-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    @@media (max-width: 768px) {
        .vp-cards-row {
            grid-template-columns: 1fr;
        }
    }

    .vp-card {
        position: relative;
        background: #fff;
        border: 2px solid #eaecf4;
        border-radius: 10px;
        padding: 25px;
        cursor: pointer;
        opacity: 0.55;
        transition: all 0.2s;
    }

        .vp-card:hover {
            opacity: 0.9;
        }

        .vp-card.is-active {
            opacity: 1;
            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        }

        .vp-card.vp-retailer.is-active {
            border-color: #1cc88a;
        }

        .vp-card.vp-producer.is-active {
            border-color: rgba(113, 96, 232, 1);
        }

    .vp-card-header {
        font-size: 17px;
        font-weight: 500;
        margin-bottom: 10px;
        color: #2e3035;
    }

    .vp-card-text {
        font-size: 14px;
        line-height: 1.55;
        color: #555;
    }

    .vp-card-features {
        background: #f8f9fc;
        padding: 14px 16px;
        border-radius: 8px;
        margin-top: 18px;
        font-size: 13px;
        color: #5a5c69;
    }

        .vp-card-features strong {
            display: block;
            margin-bottom: 8px;
            color: #2e3035;
            font-weight: 600;
        }

        .vp-card-features ul {
            margin: 0;
            padding-left: 18px;
        }

        .vp-card-features li {
            margin: 3px 0;
        }

    .vp-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        padding: 4px 10px;
        border-radius: 999px;
        display: none;
    }

    .vp-card.is-active .vp-badge {
        display: inline-block;
    }

    .vp-card.vp-retailer.is-active .vp-badge {
        background: rgba(28, 200, 138, 0.12);
        color: #1cc88a;
    }

    .vp-card.vp-producer.is-active .vp-badge {
        background: rgba(113, 96, 232, 0.12);
        color: rgba(113, 96, 232, 1);
    }

    .vp-save-bar {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        margin-top: 10px;
    }

    /* Toast */
    .vp-toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #1cc88a;
        color: #fff;
        padding: 14px 22px;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        font-size: 14px;
        font-weight: 500;
        z-index: 9999;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
    }

        .vp-toast.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<form id="view-preferences-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <input type="hidden" asp-for="Input.UseProducerViewForPriceComparison" id="hiddenPriceComparison" />
    <input type="hidden" asp-for="Input.UseProducerViewForMarketplace" id="hiddenMarketplace" />

    <div class="vp-info-banner">
        <i class="fas fa-info-circle" style="margin-right: 8px; color: #4e73df;"></i>
        Widok jest przypisywany do <strong>Twojego konta</strong> — w każdej chwili możesz go zmienić.
        Decyduje on o tym, jak wyglądają panele produktów, jakie kolumny i metryki są pokazywane,
        oraz jakie eksporty danych masz dostępne. Wybrany widok zostanie zastosowany
        zarówno w panelach porównywarek cenowych (Google / Ceneo), jak i w panelu Allegro.
    </div>

    <div class="vp-section">
        <div class="vp-cards-row">
            <div class="vp-card vp-retailer" id="card-retailer" onclick="selectView(false)">
                <span class="vp-badge">Aktywny</span>
                <div class="vp-card-header">Widok Retailera</div>
                <div class="vp-card-text">
                    Jeżeli jesteś sklepem internetowym i konkurujesz z innymi sklepami — ten widok jest dla Ciebie.
                </div>
                <div class="vp-card-features">
                    <strong>Co umożliwia:</strong>
                    <ul>
                        <li>Monitorowanie cen i ofert konkurencji</li>
                        <li>Automatyczne dostosowywanie własnych cen</li>
                        <li>Wgrywanie ceny zakupu w zakładce produkty</li>
                        <li>Analiza marży i narzutu</li>
                        <li>Uwzględnianie prowizji oraz odznak Allegro (SUPERCENA, Smart!)</li>
                        <li>Analiza pozycji w wyszukiwarce</li>
                    </ul>
                </div>
            </div>

            <div class="vp-card vp-producer" id="card-producer" onclick="selectView(true)">
                <span class="vp-badge">Aktywny</span>
                <div class="vp-card-header">Widok Producenta</div>
                <div class="vp-card-text">
                    Jesteś producentem i chcesz egzekwować własną politykę cenową — wybierz ten widok.
                </div>
                <div class="vp-card-features">
                    <strong>Co umożliwia:</strong>
                    <ul>
                        <li>Analiza cen sklepów względem Twoich cen referencyjnych</li>
                        <li>Wgrywanie cen MAP w zakładce produkty</li>
                        <li>Wykrywanie naruszeń polityki cenowej</li>
                        <li>Analiza wszystkich sprzedawców Twoich produktów na Allegro</li>
                        <li>Identyfikacja nieautoryzowanej dystrybucji</li>
                        <li>Dedykowane eksporty i raporty rynkowe dla producentów</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="vp-save-bar">
        <button type="submit" class="Button-Page-Small">Zapisz</button>
    </div>
</form>

<div id="vp-toast" class="vp-toast" role="status" aria-live="polite">
    <i class="fas fa-check-circle" style="margin-right: 8px;"></i>
    <span id="vp-toast-text"></span>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <script>
        function selectView(isProducer) {
            document.getElementById('hiddenPriceComparison').value = isProducer ? 'true' : 'false';
            document.getElementById('hiddenMarketplace').value = isProducer ? 'true' : 'false';
            setCardActive('card-retailer', !isProducer);
            setCardActive('card-producer', isProducer);
        }

        function setCardActive(cardId, active) {
            var el = document.getElementById(cardId);
            if (!el) return;
            if (active) el.classList.add('is-active');
            else el.classList.remove('is-active');
        }

        function showToast(message) {
            var toast = document.getElementById('vp-toast');
            if (!toast || !message) return;
            document.getElementById('vp-toast-text').textContent = message;
            toast.classList.add('is-visible');
            setTimeout(function () {
                toast.classList.remove('is-visible');
            }, 2800);
        }

        document.addEventListener('DOMContentLoaded', function () {
            var pcIsProducer = (document.getElementById('hiddenPriceComparison').value || '').toLowerCase() === 'true';
            var mpIsProducer = (document.getElementById('hiddenMarketplace').value || '').toLowerCase() === 'true';
            var isProducer = pcIsProducer || mpIsProducer;
            selectView(isProducer);

            var statusMsg = @Html.Raw(Json.Serialize(Model.StatusMessage ?? ""));
            if (statusMsg && statusMsg.length > 0) {
                showToast(statusMsg);
            }
        });
    </script>
}