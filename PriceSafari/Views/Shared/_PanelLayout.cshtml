<script>
    // ══════════════════════════════════════════════════════════════════
    //  SYSTEM NAWIGACJI WSTECZ
    //
    //  Zasada działania:
    //  - Klik w menu boczne (.menu-link) → ustawia flagę "reset" i resetuje stos
    //  - Każda inna nawigacja (link w widoku, formularz) → push na globalny stos
    //  - Przycisk cofania → pop i nawiguj do poprzedniej strony
    //
    //  Brak mapowania routingu = brak problemu z bezpieczeństwem,
    //  brak problemu z cross-zone, brak konieczności utrzymywania mapy.
    // ══════════════════════════════════════════════════════════════════
    (function () {
        var STACK_KEY = 'ps_nav_stack';
        var RESET_KEY = 'ps_nav_reset';
        var MAX_DEPTH = 15;

        var currentUrl = window.location.pathname + window.location.search;

        // ── 1. Przechwycenie kliknięć w menu boczne (capture phase) ──
        //    Działa PRZED onclick="location.href=..." więc flaga jest ustawiona
        //    zanim nastąpi nawigacja. Nie trzeba modyfikować żadnego onclick w menu.
        document.addEventListener('click', function (e) {
            var menuLink = e.target.closest('.menu-link');
            if (menuLink) {
                sessionStorage.setItem(RESET_KEY, '1');
            }
        }, true);

        // ── 2. Odczytaj stos ──
        var stack = [];
        try {
            stack = JSON.parse(sessionStorage.getItem(STACK_KEY) || '[]');
            if (!Array.isArray(stack)) stack = [];
        } catch (e) {
            stack = [];
        }

        // ── 3. Logika stosu ──
        var wasReset = sessionStorage.getItem(RESET_KEY) === '1';
        sessionStorage.removeItem(RESET_KEY);

        if (wasReset) {
            // Klik z menu bocznego — nowy root, resetuj stos
            stack = [currentUrl];
        } else {
            // Nawigacja wewnętrzna (link w widoku, formularz, itp.)
            var topUrl = stack.length > 0 ? stack[stack.length - 1] : null;

            if (topUrl === currentUrl) {
                // Odświeżenie strony lub powrót na tę samą — nic nie rób
            } else {
                // Sprawdź czy URL już jest na stosie (user cofnął się i przechodzi dalej)
                var existingIndex = stack.indexOf(currentUrl);
                if (existingIndex >= 0) {
                    // Obetnij stos do tego punktu
                    stack = stack.slice(0, existingIndex + 1);
                } else {
                    // Nowa strona — push
                    stack.push(currentUrl);
                }
            }
        }

        // Ogranicz głębokość
        if (stack.length > MAX_DEPTH) {
            stack = stack.slice(stack.length - MAX_DEPTH);
        }

        // ── 4. Zapisz stos ──
        sessionStorage.setItem(STACK_KEY, JSON.stringify(stack));

        // ── 5. Przycisk cofania ──
        var canGoBack = stack.length > 1;
        var backUrl = canGoBack ? stack[stack.length - 2] : null;
        var depth = stack.length - 1; // ile kroków w głąb od roota

        function navigateBack() {
            if (!backUrl) return;
            // Zdejmij bieżący element PRZED nawigacją
            stack.pop();
            sessionStorage.setItem(STACK_KEY, JSON.stringify(stack));
            window.location.href = backUrl;
        }

        document.addEventListener('DOMContentLoaded', function () {
            // ── Rozwinięty sidebar ──
            var section = document.getElementById('navBackSection');
            var btn = document.getElementById('navBackBtn');
            var label = document.getElementById('navBackLabel');
            var depthSpan = document.getElementById('navBackDepth');

            if (canGoBack && section && btn) {
                label.textContent = 'Cofnij';
                depthSpan.textContent = depth > 1 ? '(' + depth + ')' : '';
                btn.title = 'Cofnij do poprzedniego widoku';
                section.style.display = 'block';
                btn.addEventListener('click', navigateBack);
            }

            // ── Zwinięty sidebar ──
            var sectionMini = document.getElementById('navBackSectionMini');
            var btnMini = document.getElementById('navBackBtnMini');

            if (canGoBack && sectionMini && btnMini) {
                btnMini.title = 'Cofnij (' + depth + ')';
                sectionMini.style.display = 'flex';
                btnMini.addEventListener('click', navigateBack);
            }
        });
    })();
</script>

<script>
    // ══ Sidebar toggle ══
    document.addEventListener('DOMContentLoaded', function () {
        var sidebar = document.querySelector('.Sidebar');
        var sidebarHide = document.querySelector('.Sidebar-hide');

        var sidebarState = localStorage.getItem('sidebarState');
        if (sidebarState === 'hidden') {
            sidebarHide.style.display = "flex";
            sidebar.style.display = "none";
        } else {
            sidebar.style.display = "flex";
            sidebarHide.style.display = "none";
        }

        document.getElementById('toggleSidebar1').addEventListener('click', toggleSidebar);
        document.getElementById('toggleSidebar2').addEventListener('click', toggleSidebar);

        function toggleSidebar() {
            if (sidebar.style.display === "none" || sidebar.style.display === "") {
                sidebar.style.display = "flex";
                sidebarHide.style.display = "none";
                localStorage.setItem('sidebarState', 'visible');
            } else {
                sidebarHide.style.display = "flex";
                sidebar.style.display = "none";
                localStorage.setItem('sidebarState', 'hidden');
            }
        }
    });
</script>