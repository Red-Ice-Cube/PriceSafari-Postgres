<script>
    // ══════════════════════════════════════════════════════════════════
    //  SYSTEM NAWIGACJI + TOPBAR
    // ══════════════════════════════════════════════════════════════════
    (function () {
        var STACK_KEY = 'ps_nav_stack';
        var RESET_KEY = 'ps_nav_reset';
        var MAX_DEPTH = 15;

        var currentUrl = window.location.pathname + window.location.search;

        // ── Tytuł strony z <title> (ustawiany przez ViewData["Title"]) ──
        var pageTitle = (document.title || '').trim();
        if (pageTitle.indexOf(' - ') > 0) {
            pageTitle = pageTitle.substring(0, pageTitle.indexOf(' - ')).trim();
        }
        if (!pageTitle || pageTitle === '_PanelLayout') {
            var parts = currentUrl.split('?')[0].split('/').filter(function (p) { return p.length > 0; });
            pageTitle = parts.length > 0 ? parts.slice(0, 2).join(' / ') : 'Start';
        }

        // ── Przechwycenie kliknięć w menu boczne ──
        document.addEventListener('click', function (e) {
            if (e.target.closest('.menu-link')) {
                sessionStorage.setItem(RESET_KEY, '1');
            }
        }, true);

        // ── Odczytaj stos ──
        var stack = [];
        try {
            var raw = JSON.parse(sessionStorage.getItem(STACK_KEY) || '[]');
            if (Array.isArray(raw)) {
                stack = raw.map(function (item) {
                    if (typeof item === 'string') {
                        return { url: item, title: item.split('?')[0].split('/').filter(function (p) { return p.length > 0; }).slice(0, 2).join(' / ') || 'Start' };
                    }
                    return item;
                });
            }
        } catch (e) { stack = []; }

        // ── Logika stosu ──
        var wasReset = sessionStorage.getItem(RESET_KEY) === '1';
        sessionStorage.removeItem(RESET_KEY);

        if (wasReset) {
            stack = [{ url: currentUrl, title: pageTitle }];
        } else {
            var topEntry = stack.length > 0 ? stack[stack.length - 1] : null;
            var topUrl = topEntry ? topEntry.url : null;

            if (topUrl === currentUrl) {
                stack[stack.length - 1].title = pageTitle;
            } else {
                var existingIndex = -1;
                for (var i = 0; i < stack.length; i++) {
                    if (stack[i].url === currentUrl) { existingIndex = i; break; }
                }
                if (existingIndex >= 0) {
                    stack = stack.slice(0, existingIndex + 1);
                    stack[stack.length - 1].title = pageTitle;
                } else {
                    stack.push({ url: currentUrl, title: pageTitle });
                }
            }
        }

        if (stack.length > MAX_DEPTH) stack = stack.slice(stack.length - MAX_DEPTH);
        sessionStorage.setItem(STACK_KEY, JSON.stringify(stack));

        // ── Dane nawigacji ──
        var canGoBack = stack.length > 1;
        var backEntry = canGoBack ? stack[stack.length - 2] : null;

        function navigateBack() {
            if (!backEntry) return;
            stack.pop();
            sessionStorage.setItem(STACK_KEY, JSON.stringify(stack));
            window.location.href = backEntry.url;
        }

        function navigateToStackIndex(idx) {
            if (idx < 0 || idx >= stack.length - 1) return;
            stack = stack.slice(0, idx + 1);
            sessionStorage.setItem(STACK_KEY, JSON.stringify(stack));
            window.location.href = stack[idx].url;
        }

        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('topBarBackBtn');
            var crumbsEl = document.getElementById('topBarCrumbs');

            // ── Przycisk cofania ──
            if (canGoBack) {
                btn.classList.remove('disabled');
                btn.addEventListener('click', navigateBack);
            }

            // ── Breadcrumbs ──
            var html = '';
            for (var i = 0; i < stack.length; i++) {
                if (i > 0) {
                    html += '<span class="topbar-crumb-chevron">›</span>';
                }
                var entry = stack[i];
                var isCurrent = (i === stack.length - 1);
                if (isCurrent) {
                    html += '<span class="topbar-crumb current">' + entry.title + '</span>';
                } else {
                    html += '<span class="topbar-crumb clickable" data-stack-idx="' + i + '">' + entry.title + '</span>';
                }
            }
            crumbsEl.innerHTML = html;

            // ── Klikanie w breadcrumby ──
            crumbsEl.addEventListener('click', function (e) {
                var crumb = e.target.closest('.topbar-crumb.clickable');
                if (crumb) {
                    navigateToStackIndex(parseInt(crumb.dataset.stackIdx, 10));
                }
            });

            // ── Sync + pokaż treść TopBara z fade-in ──
            syncTopBar();
            document.getElementById('topBar').classList.add('ready');
        });

        // ══ Synchronizacja pozycji TopBar z sidebar ══
        function syncTopBar() {
            var topBar = document.getElementById('topBar');
            if (!topBar) return;
            var sidebar = document.querySelector('.Sidebar');
            var sidebarVisible = sidebar && sidebar.style.display !== 'none';
            topBar.classList.remove('sidebar-expanded', 'sidebar-collapsed');
            topBar.classList.add(sidebarVisible ? 'sidebar-expanded' : 'sidebar-collapsed');
        }

        window.__syncTopBarWithSidebar = syncTopBar;
    })();
</script>

<script>
    // ══ Sidebar toggle + TopBar sync ══
    document.addEventListener('DOMContentLoaded', function () {
        var sidebar = document.querySelector('.Sidebar');
        var sidebarHide = document.querySelector('.Sidebar-hide');

        var sidebarState = localStorage.getItem('sidebarState');
        if (sidebarState === 'hidden') {
            sidebarHide.style.display = "flex";
            sidebar.style.display = "none";
        } else {
            sidebar.style.display = "flex";
            sidebarHide.style.display = "none";
        }

        if (window.__syncTopBarWithSidebar) window.__syncTopBarWithSidebar();

        document.getElementById('toggleSidebar1').addEventListener('click', toggleSidebar);
        document.getElementById('toggleSidebar2').addEventListener('click', toggleSidebar);

        function toggleSidebar() {
            if (sidebar.style.display === "none" || sidebar.style.display === "") {
                sidebar.style.display = "flex";
                sidebarHide.style.display = "none";
                localStorage.setItem('sidebarState', 'visible');
            } else {
                sidebarHide.style.display = "flex";
                sidebar.style.display = "none";
                localStorage.setItem('sidebarState', 'hidden');
            }
            if (window.__syncTopBarWithSidebar) window.__syncTopBarWithSidebar();
        }
    });
</script>