    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.ckeditor.com/4.16.0/standard/ckeditor.js"></script>

    <link rel="icon" type="image/png" sizes="16x16" href="~/icon/icon.png">

    <link href="~/css/panel.css" rel="stylesheet" asp-append-version="true" />

    @RenderSection("Scripts", required: false)
    @await RenderSectionAsync("Styles", required: false)

    @{
        ViewData["Title"] = "_PanelLayout";
    }

    <style>
        /* ── Nawigacja wstecz ── */
        .nav-back-section {
            display: none;
            padding: 4px 14px 8px 14px;
        }
        .nav-back-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            color: rgba(255,255,255,0.7);
            font-size: 13px;
            padding: 5px 10px;
            cursor: pointer;
            transition: all 0.15s ease;
            width: 100%;
            text-align: left;
        }
        .nav-back-btn:hover {
            background: rgba(255,255,255,0.08);
            color: #fff;
            border-color: rgba(255,255,255,0.3);
        }
        .nav-back-btn svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }
        .nav-back-label {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .nav-back-depth {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            margin-left: auto;
            flex-shrink: 0;
        }

        /* Wersja dla zwiniętego sidebara */
        .nav-back-section-mini {
            display: none;
            padding: 6px 0;
            justify-content: center;
        }
        .nav-back-btn-mini {
            display: flex;
            align-items: center;
            justify-content: center;
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            color: rgba(255,255,255,0.7);
            width: 36px;
            height: 30px;
            cursor: pointer;
            transition: all 0.15s ease;
        }
        .nav-back-btn-mini:hover {
            background: rgba(255,255,255,0.08);
            color: #fff;
            border-color: rgba(255,255,255,0.3);
        }
        .nav-back-btn-mini svg {
            width: 16px;
            height: 16px;
        }
    </style>

    <script>
        document.write('<style>.Sidebar, .Sidebar-hide { display: none; }</style>');
        var sidebarState = localStorage.getItem('sidebarState');
        if (sidebarState === 'hidden') {
            document.write('<style>.Sidebar-hide { display: flex; }</style>');
        } else {
            document.write('<style>.Sidebar { display: flex; }</style>');
