@{
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    var storeId = ViewBag.StoreId ?? 0;
    var storeName = ViewBag.StoreName ?? "";
    string existingMapping = ViewBag.ExistingMapping ?? "null";
    bool copyEnabled = ViewBag.CopyXMLPricesEnabled ?? false;
}

<h2>Wizard Doklejania Cen z XML — @storeName (storeId=@storeId)</h2>

<div id="copyxml-wizard-data"
     data-store-id="@storeId"
     data-existing-mapping='@Html.Raw(existingMapping)'>
</div>

<div style="margin-bottom:15px; padding:10px; background:#fff8dc; border:1px solid #d4b96a; border-radius:4px;">
    <label style="font-weight:bold;">
        <input type="checkbox" id="toggleCopyXml" @(copyEnabled ? "checked" : "") />
        Doklejanie cen z XML AKTYWNE dla tego sklepu
    </label>
    <div style="font-size:12px; color:#555; margin-top:4px;">
        Gdy włączone — podczas procesowania sklepu, dla produktów dla których NIE znaleziono naszej oferty w Google,
        system pobierze cenę z XML i doklei ją do historii cen (oznaczoną jako <code>IsBidding = "XML"</code>).
    </div>
</div>

<div style="margin-bottom:10px;">
    <form asp-action="ClearMapping" method="post" style="display:inline;">
        <input type="hidden" name="storeId" value="@storeId" />
        <button type="submit" style="background:red; color:white; padding:6px;">Usuń mapowanie</button>
    </form>
    <button id="loadFromNetworkBtn" style="margin-left:10px; background:#4a90d9; color:white; padding:6px 12px; border:none; border-radius:4px; cursor:pointer;">
        ⬇ Załaduj XML z sieci
    </button>
</div>

<div style="margin-bottom:10px;">
    <label for="xmlFileInput">lub wybierz zapisany plik XML/TXT:</label>
    <input type="file" id="xmlFileInput" accept=".xml,.txt">
    <button id="processXmlButton">Przetwórz plik</button>
</div>

<div style="margin-bottom:10px; padding:10px; background:#f5f8ff; border:1px solid #c8d8f0; border-radius:4px;">
    <strong>Jak używać:</strong>
    <ol style="margin:5px 0 5px 20px; padding:0;">
        <li>Wybierz <b>pole mapujące</b> (EAN lub ID) — to klucz wg. którego będziemy dopasowywać produkty.</li>
        <li>Kliknij w drzewie XML węzeł zawierający tę wartość.</li>
        <li>Przełącz na <b>Cena</b>, kliknij węzeł z ceną. Analogicznie <b>Cena z dostawą</b> (opcjonalne — od niego odejmujemy cenę żeby dostać koszt dostawy).</li>
        <li><b>Dostępność</b> (opcjonalne) — kliknij węzeł wskazujący stan, a potem wpisz w polu <i>Wartość oznaczająca "dostępny"</i> dokładnie to co widać w tym węźle (np. <code>in stock</code>). Produkty z inną wartością → niedostępne.</li>
        <li>Kliknij <b>Zapisz mapowanie</b>. Potem <b>Pokaż podgląd</b> — zobaczysz jak dopasuje się do twojej bazy.</li>
    </ol>
</div>

<div style="margin-bottom:10px;">
    <label><b>Pole mapujące (klucz):</b></label>
    <select id="keyFieldSelector">
        <option value="Ean">EAN</option>
        <option value="ExternalId">ExternalId (ID produktu)</option>
    </select>

    <label style="margin-left:20px;"><b>Co mapujesz:</b></label>
    <select id="fieldSelector">
        <option value="Key">🔑 Klucz (EAN/ID)</option>
        <option value="Price">💰 Cena</option>
        <option value="PromoPrice">🏷️ Cena promocyjna (nadpisuje)</option>
        <option value="PriceWithShipping">🚚 Cena z dostawą</option>
        <option value="InStock">📦 Dostępność (węzeł)</option>
    </select>

    <button id="saveMapping" style="margin-left:10px;">Zapisz mapowanie</button>
    <button id="reloadMapping" style="margin-left:10px;">Załaduj mapowanie</button>
    <button id="previewMapping" style="margin-left:10px; background:#2a9d3e; color:white; padding:6px 12px; border:none; border-radius:4px;">
        🔍 Pokaż podgląd
    </button>
</div>

<div style="margin-bottom:10px;">
    <label>
        <b>Wartość oznaczająca "dostępny":</b>
        <input type="text" id="inStockMarker" placeholder="np. in stock, yes, 1, dostępny" style="width:250px;" />
    </label>
    <span style="font-size:12px; color:#666;">(tylko gdy zmapowane pole Dostępność; puste = zawsze dostępny)</span>
</div>

<div id="xmlProgressContainer" style="display:none;"></div>

<div style="display:flex; gap:10px; width:100%;">
    <div style="flex:1; border:1px solid #ccc; height:700px; overflow:auto; padding:5px;">
        <h4>Struktura XML</h4>
        <div id="xmlContainer"></div>
    </div>

    <div style="flex:1; border:1px solid #ccc; height:700px; overflow:auto; padding:5px;">
        <h4>Mapa pól</h4>
        <table id="mappingTable" border="1" cellpadding="5" style="border-collapse:collapse; width:100%;">
            <thead>
                <tr><th>Pole</th><th>XPath</th><th>Liczba węzłów</th><th>Pierwsza wartość</th></tr>
            </thead>
            <tbody></tbody>
        </table>

        <h4 style="margin-top:20px;">Podgląd dopasowań</h4>
        <div id="previewStats" style="margin-bottom:10px; font-weight:bold;"></div>
        <div id="previewContainer" style="max-height:400px; overflow:auto;"></div>
    </div>
</div>

<script src="~/js/Manager/CopyXmlPricesWizard.js"></script>

<style>
    .xml-node { cursor:pointer; margin:3px 0; }
    .highlight-Key               { background-color: rgba(255, 0,   0,   0.15); }
    .highlight-Price             { background-color: rgba(0,   200, 0,   0.15); }
    .highlight-PromoPrice        { background-color: rgba(160,  25, 150,  0.25); } 
    .highlight-PriceWithShipping { background-color: rgba(255, 165, 0,   0.20); }
    .highlight-InStock           { background-color: rgba(0,   100, 255, 0.15); }

    #mappingTable th, #mappingTable td { padding:4px 8px; text-align:left; font-size:12px; }
    #xmlProgressContainer { padding:14px; background:#f5f8ff; border:1px solid #c8d8f0; border-radius:6px; margin-bottom:10px; }

    .preview-table { width:100%; border-collapse:collapse; font-size:11px; }
    .preview-table th, .preview-table td { border:1px solid #ddd; padding:3px 6px; }
    .preview-table tr.matched { background:#e8f5e9; }
    .preview-table tr.unmatched { background:#ffebee; }
</style>