@model PriceSafari.Models.ManagerViewModels.CeneoExternalScraperViewModel
@using PriceSafari.Services.CeneoExternalScraping

@{
    ViewData["Title"] = "Ceneo External Scraper";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<style>

    .ceneo-ext-container,
    .ceneo-ext-container * {
        min-width: 0;
    }

    .ceneo-ext-container {
        flex: 1 1 auto;
        width: 100%;
        min-width: 0;
    }


    .ceneo-ext-container {
        padding: 20px;
        background: #f8f9fa;
        width: 100%;
        min-height: 100%;
        box-sizing: border-box;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 3px solid #ff6900;
    }

    .page-title {
        font-size: 26px;
        font-weight: 600;
        color: #ff6900;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
    }

    .status-idle { background: #e8eaed; color: #5f6368; }
    .status-running { background: #e6f4ea; color: #1e8e3e; animation: pulse 2s infinite; }
    .status-paused { background: #fef7e0; color: #f9ab00; }


    .stats-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 20px;
        padding: 15px;
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    .stats-bar-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
    }
    .stats-bar-item strong { color: #202124; }
    .stats-bar-item span { color: #ff6900; font-weight: 600; }

    .controls-section {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .btn-ceneo {
        padding: 10px 18px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        font-size: 14px;
    }

    .btn-start { background: #1e8e3e; color: white; }
    .btn-start:hover { background: #137333; }
    .btn-stop { background: #ea4335; color: white; }
    .btn-stop:hover { background: #c5221f; }
    .btn-reset { background: #fbbc05; color: #202124; }
    .btn-reset:hover { background: #f9a825; }
    .btn-clear { background: #5f6368; color: white; }
    .btn-clear:hover { background: #3c4043; }

    .dashboard-section {
        background: white;
        border-radius: 10px;
        padding: 18px;
        margin-bottom: 20px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .section-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 15px;
        color: #202124;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
    }

    .stat-card {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 10px 8px;
        text-align: center;
        border-left: 3px solid #ff6900;
    }

    .stat-card.success { border-left-color: #34a853; }
    .stat-card.warning { border-left-color: #fbbc05; }
    .stat-card.danger { border-left-color: #ea4335; }
    .stat-card.info { border-left-color: #4285f4; }
    .stat-card.captcha { border-left-color: #9c27b0; }

    .stat-value {
        font-size: 20px;
        font-weight: 700;
        color: #202124;
    }

    .stat-label {
        font-size: 10px;
        color: #5f6368;
        margin-top: 4px;
        text-transform: uppercase;
    }

    .progress-section {
        background: white;
        border-radius: 10px;
        padding: 18px;
        margin-bottom: 20px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    .progress-bar-bg {
        background: #333333;
        border-radius: 4px;
        height: 28px;
        overflow: hidden;
        margin-bottom: 15px;
        border: 1px solid #222;
    }

    .progress-bar-fill {
        height: 100%;
        background: #ff6900;
        transition: width 0.3s linear;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 13px;
        min-width: 40px;
    }

    .progress-info {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 10px;
        font-size: 13px;
        color: #5f6368;
    }

    .progress-info-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .elapsed-time {
        font-family: 'Consolas', monospace;
        font-size: 20px;
        font-weight: 700;
        color: #ff6900;
    }

    .two-column-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .logs-section {
        background: #1a1a2e;
        border-radius: 10px;
        padding: 12px;
        max-height: 280px;
        overflow-y: auto;
    }

    .log-entry {
        font-family: 'Consolas', monospace;
        font-size: 11px;
        padding: 4px 8px;
        margin-bottom: 2px;
        border-radius: 4px;
    }

    .log-entry.info { color: #82aaff; background: rgba(130,170,255,0.1); }
    .log-entry.success { color: #c3e88d; background: rgba(195,232,141,0.1); }
    .log-entry.warning { color: #ffcb6b; background: rgba(255,203,107,0.1); }
    .log-entry.error { color: #ff5370; background: rgba(255,83,112,0.1); }

    .log-time { color: #676e95; }
    .log-scraper { color: #89ddff; font-weight: 600; }

    .scrapers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 15px;
    }

    .scraper-card {
        background: white;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        border-left: 5px solid #5f6368;
        transition: all 0.3s;
    }

    .scraper-card.status-idle { border-left-color: #34a853; }
    .scraper-card.status-busy { border-left-color: #ff6900; animation: busy-pulse 1.5s infinite; }
    .scraper-card.status-offline { border-left-color: #ea4335; opacity: 0.6; }
    .scraper-card.status-stopped { border-left-color: #fbbc05; }
    .scraper-card.status-solvingcaptcha { border-left-color: #9c27b0; background-color: #f8f3ff; }

    @@keyframes busy-pulse {
        0%, 100% { box-shadow: 0 2px 6px rgba(255,105,0,0.2); }
        50% { box-shadow: 0 2px 12px rgba(255,105,0,0.5); }
    }

    .scraper-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .scraper-name {
        font-weight: 700;
        font-size: 15px;
        color: #202124;
    }

    .scraper-status {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .scraper-status.idle { background: #e6f4ea; color: #1e8e3e; }
    .scraper-status.busy { background: #fff3e0; color: #e65100; }
    .scraper-status.offline { background: #fce8e6; color: #c5221f; }
    .scraper-status.stopped { background: #fef7e0; color: #e37400; }
    .scraper-status.solvingcaptcha { background: #f3e5f5; color: #7b1fa2; }

    .scraper-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        margin-bottom: 10px;
    }

    .scraper-stat {
        text-align: center;
        padding: 6px 4px;
        background: #f8f9fa;
        border-radius: 6px;
    }

    .scraper-stat-value {
        font-size: 14px;
        font-weight: 700;
        color: #202124;
    }

    .scraper-stat-label {
        font-size: 9px;
        color: #5f6368;
        text-transform: uppercase;
    }

    .scraper-details {
        font-size: 11px;
        color: #5f6368;
        margin-bottom: 10px;
    }

    .scraper-details div {
        margin-bottom: 3px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .scraper-actions {
        display: flex;
        gap: 8px;
    }

    .btn-scraper {
        flex: 1;
        padding: 8px;
        border: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-scraper.pause { background: #fef7e0; color: #e37400; }
    .btn-scraper.pause:hover { background: #fbbc05; color: #202124; }
    .btn-scraper.resume { background: #e6f4ea; color: #1e8e3e; }
    .btn-scraper.resume:hover { background: #34a853; color: white; }

    .no-scrapers {
        text-align: center;
        padding: 30px;
        background: #f8f9fa;
        border-radius: 10px;
        color: #5f6368;
        grid-column: 1 / -1;
    }

    .no-scrapers i {
        font-size: 40px;
        margin-bottom: 10px;
        color: #dadce0;
    }

    .table-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .search-box {
        padding: 10px 15px;
        border: 1px solid #dadce0;
        border-radius: 8px;
        width: 280px;
        font-size: 14px;
    }

    .search-box:focus {
        outline: none;
        border-color: #ff6900;
        box-shadow: 0 0 0 3px rgba(255,105,0,0.2);
    }

    .filter-tabs {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 8px 14px;
        border: none;
        background: #f8f9fa;
        border-radius: 18px;
        font-size: 12px;
        cursor: pointer;
    }

    .filter-tab.active { background: #ff6900; color: white; }
    .filter-tab:hover:not(.active) { background: #e8eaed; }

    .table-container {
        display: block !important; /* Wymusza widoczność i nadpisuje globalne style */
        overflow: auto;
        max-height: 1100px;
    }

    .urls-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .urls-table th {
        background: #f8f9fa;
        padding: 10px 8px;
        text-align: left;
        font-weight: 600;
        color: #5f6368;
        border-bottom: 2px solid #e8eaed;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .urls-table td {
        padding: 8px;
        border-bottom: 1px solid #e8eaed;
        vertical-align: middle;
    }

    .urls-table tbody tr {
        background-color: white;
        transition: background-color 0.2s;
    }

    .urls-table tbody tr:hover { background: #f1f3f4 !important; }
    .urls-table tbody tr.scraped { background-color: #e6f4ea !important; }
    .urls-table tbody tr.rejected { background-color: #fce8e6 !important; }

    .url-cell {
        max-width: 380px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-family: monospace;
        font-size: 11px;
    }

    .url-cell a {
        color: #1a73e8;
        text-decoration: none;
    }

    .url-cell a:hover { text-decoration: underline; }

    .badge {
        padding: 3px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 600;
        display: inline-block;
    }

    .badge-scraped { background: #e6f4ea; color: #1e8e3e; }
    .badge-rejected { background: #fce8e6; color: #c5221f; }
    .badge-pending { background: #f8f9fa; color: #5f6368; }
</style>

<div class="ceneo-ext-container">
    <div class="page-header">
        <div class="page-title">
            <i class="fas fa-shopping-cart"></i>
            Ceneo External Scraper
        </div>
        <div>
            <span id="statusBadge" class="status-badge status-@Model.CurrentStatus.ToString().ToLower()">
                @(Model.CurrentStatus == CeneoExternalScrapingProcessStatus.Running ? "Działa" :
                  Model.CurrentStatus == CeneoExternalScrapingProcessStatus.Paused ? "Wstrzymany" : "Bezczynny")
            </span>
        </div>
    </div>

    <div class="stats-bar">
        <div class="stats-bar-item"><strong>Łącznie URL:</strong> <span id="totalUrlCount">@Model.DbStats.TotalUrls</span></div>
        <div class="stats-bar-item"><strong>Zescrapowane:</strong> <span id="scrapedUrlCount">@Model.DbStats.ScrapedUrls</span></div>
        <div class="stats-bar-item"><strong>Odrzucone:</strong> <span id="rejectedUrlCount">@Model.DbStats.RejectedUrls</span></div>
        <div class="stats-bar-item"><strong>Oczekujące:</strong> <span id="pendingUrlCount">@Model.DbStats.PendingUrls</span></div>
        <div class="stats-bar-item"><strong>Zebrane ceny:</strong> <span id="totalPricesCount">@Model.DbStats.TotalPrices</span></div>
        <div class="stats-bar-item"><strong>Scrapery online:</strong> <span id="onlineScrapersCount">@Model.Scrapers.Count</span></div>
    </div>

    <div class="controls-section" id="controlsSection">
        @if (Model.CurrentStatus != CeneoExternalScrapingProcessStatus.Running)
        {
            <button type="button" class="btn-ceneo btn-start" onclick="startScraping()">
                <i class="fas fa-play"></i> Rozpocznij scrapowanie
            </button>
        }
        else
        {
            <button type="button" class="btn-ceneo btn-stop" onclick="stopScraping()">
                <i class="fas fa-stop"></i> Zatrzymaj scrapowanie
            </button>
        }
        <button type="button" class="btn-ceneo btn-reset" onclick="resetRejected()">
            <i class="fas fa-redo"></i> Resetuj odrzucone (<span id="rejectedCountBtn">@Model.DbStats.RejectedUrls</span>)
        </button>
        <button type="button" class="btn-ceneo btn-clear" onclick="clearData()">
            <i class="fas fa-trash"></i> Wyczyść dane
        </button>
    </div>

    <div class="progress-section">
        <div class="section-title"><i class="fas fa-chart-line"></i> Postęp scrapowania</div>
        @{
            var progressPercent = Model.DbStats.TotalUrls > 0
                ? Math.Round((double)Model.DbStats.ScrapedUrls / Model.DbStats.TotalUrls * 100, 1)
                : 0;
        }
        <div class="progress-bar-bg">
            <div id="progressBarFill" class="progress-bar-fill" style="width: @progressPercent%;">@progressPercent%</div>
        </div>
        <div class="progress-info">
            <div class="progress-info-item">
                <i class="fas fa-clock"></i> Czas: <span id="elapsedTime" class="elapsed-time">00:00:00</span>
            </div>
            <div class="progress-info-item">
                <i class="fas fa-tachometer-alt"></i> Prędkość: <span id="currentSpeed" style="color:#ff6900; font-weight:600;">0.00</span> URL/sek
            </div>
            <div class="progress-info-item">
                <i class="fas fa-check-circle"></i>
                <span id="progressScraped">@Model.DbStats.ScrapedUrls</span> /
                <span id="progressTotal">@Model.DbStats.TotalUrls</span>
            </div>
            <div class="progress-info-item">
                <i class="fas fa-hourglass-half"></i> Pozostało: <span id="progressPending">@Model.DbStats.PendingUrls</span>
            </div>
        </div>
    </div>

    <div class="two-column-grid">
        <div class="dashboard-section">
            <div class="section-title"><i class="fas fa-chart-bar"></i> Statystyki</div>
            <div class="stats-grid">
                <div class="stat-card info">
                    <div id="totalUrlsStat" class="stat-value">@Model.DbStats.TotalUrls</div>
                    <div class="stat-label">Wszystkie</div>
                </div>
                <div class="stat-card success">
                    <div id="scrapedUrlsStat" class="stat-value">@Model.DbStats.ScrapedUrls</div>
                    <div class="stat-label">Zescrapowane</div>
                </div>
                <div class="stat-card warning">
                    <div id="rejectedUrlsStat" class="stat-value">@Model.DbStats.RejectedUrls</div>
                    <div class="stat-label">Odrzucone</div>
                </div>
                <div class="stat-card success">
                    <div id="totalPricesStat" class="stat-value">@Model.DbStats.TotalPrices</div>
                    <div class="stat-label">Ceny</div>
                </div>
                <div class="stat-card captcha">
                    <div id="captchaCountStat" class="stat-value">0</div>
                    <div class="stat-label">Captcha</div>
                </div>
                <div class="stat-card info">
                    <div id="batchesProcessedStat" class="stat-value">0</div>
                    <div class="stat-label">Paczki OK</div>
                </div>
                <div class="stat-card warning">
                    <div id="batchesTimedOutStat" class="stat-value">0</div>
                    <div class="stat-label">Timeouts</div>
                </div>
                <div class="stat-card info">
                    <div id="activeBatchesStat" class="stat-value">0</div>
                    <div class="stat-label">Aktywne paczki</div>
                </div>
            </div>
        </div>
        <div class="dashboard-section">
            <div class="section-title"><i class="fas fa-terminal"></i> Logi aktywności</div>
            <div id="logsContainer" class="logs-section">
                @foreach (var log in Model.RecentLogs.OrderByDescending(l => l.Timestamp).Take(50))
                {
                    <div class="log-entry @log.Level.ToLower()">
                        <span class="log-time">[@log.Timestamp.ToString("HH:mm:ss")]</span>
                        <span class="log-scraper">[@log.ScraperName]</span>
                        @if (!string.IsNullOrEmpty(log.BatchId))
                        {
                            <span style="color:#89ddff;">[#@(log.BatchId.Length > 8 ? log.BatchId.Substring(log.BatchId.Length - 8) : log.BatchId)]</span>
                        }
                        @log.Message
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="dashboard-section">
        <div class="section-title">
            <i class="fas fa-server"></i> Aktywne scrapery
            <span style="margin-left: auto; font-size: 13px; font-weight: 400; color: #5f6368;">
                Online: <span id="scrapersOnlineCount">@Model.Scrapers.Count</span> |
                Zajęte: <span id="scrapersBusyCount">0</span> |
                Captcha: <span id="scrapersCaptchaCount">0</span>
            </span>
        </div>
        <div id="scrapersContainer" class="scrapers-grid">
            <div class="no-scrapers" id="noScrapersInfo">
                <i class="fas fa-server"></i>
                <p>Brak aktywnych scraperów.</p>
                <p style="font-size: 13px;">Uruchom skrypt Python, aby rozpocząć scrapowanie.</p>
            </div>
        </div>
    </div>

    <div class="dashboard-section">
        <div class="section-title"><i class="fas fa-list"></i> Lista URLi do scrapowania (<span id="urlsTotalCount">@Model.Urls.Count</span> wierszy)</div>
        <div class="table-controls">
            <input type="text" id="searchBox" class="search-box" placeholder="Szukaj po URL, ID...">
            <div class="filter-tabs">
                <button class="filter-tab active" data-filter="all" onclick="applyFilter('all', this)">
                    Wszystkie (<span id="filterAll">@Model.DbStats.TotalUrls</span>)
                </button>
                <button class="filter-tab" data-filter="pending" onclick="applyFilter('pending', this)">
                    Oczekujące (<span id="filterPending">@Model.DbStats.PendingUrls</span>)
                </button>
                <button class="filter-tab" data-filter="scraped" onclick="applyFilter('scraped', this)">
                    Zescrapowane (<span id="filterScraped">@Model.DbStats.ScrapedUrls</span>)
                </button>
                <button class="filter-tab" data-filter="rejected" onclick="applyFilter('rejected', this)">
                    Odrzucone (<span id="filterRejected">@Model.DbStats.RejectedUrls</span>)
                </button>
            </div>
        </div>
        <div class="table-container">
            <table class="urls-table" id="urlsTable">
                <thead>
                    <tr>
                        <th>Kolejka</th>
                        <th>Task ID</th>
                        <th>URL Ceneo</th>
                        <th>Powiązane produkty (ID produktu)</th>
                        <th>Status</th>
                        <th>Liczba cen</th>
                        <th>Sprzedaż</th>
                    </tr>
                </thead>
                <tbody id="urlsTableBody">
                    @{
                        // Tworzymy zmienną licznika, która zaczyna się od 1
                        int rowIndex = 1;
                    }
                    @foreach (var url in Model.Urls)
                    {
                        var rowClass = url.IsScraped ? (url.IsRejected ? "rejected" : "scraped") : "";
                        var statusText = url.IsRejected ? "rejected" : (url.IsScraped ? "scraped" : "pending");
                        <tr class="@rowClass" data-id="@url.Id" data-status="@statusText">

                            <!-- 1. Kolumna: Kolejka -->
                            <td>@rowIndex</td>

                            <!-- 2. Kolumna: Task ID -->
                            <td><strong>@url.Id</strong></td>

                            <!-- 3. Kolumna: URL Ceneo -->
                            <td class="url-cell" title="@url.OfferUrl">
                                @if (!string.IsNullOrEmpty(url.OfferUrl))
                                {
                                    <a href="@url.OfferUrl" target="_blank">@url.OfferUrl</a>
                                }
                            </td>

                            <!-- 4. Kolumna: Powiązane produkty -->
                            <td>@(url.ProductIds != null && url.ProductIds.Any() ? string.Join(", ", url.ProductIds) : "-")</td>

                            <!-- 5. Kolumna: Status -->
                            <td class="status-cell">
                                @if (url.IsRejected)
                                {
                                    <span class="badge badge-rejected">Odrzucony</span>
                                }
                                else if (url.IsScraped)
                                {
                                    <span class="badge badge-scraped">Zescrapowany</span>
                                }
                                else
                                {
                                    <span class="badge badge-pending">Oczekuje</span>
                                }
                            </td>

                            <!-- 6. Kolumna: Liczba cen -->
                            <td class="prices-cell">
                                @if (url.PricesCount > 0)
                                {
                                    <strong style="color:#1e8e3e;">@url.PricesCount</strong>
                                }
                                else
                                {
                                    <span style="color:#5f6368;">-</span>
                                }
                            </td>

                            <!-- 7. Kolumna: Sprzedaż -->
                            <td class="sales-cell">
                                @if (url.CeneoSalesCount.HasValue && url.CeneoSalesCount.Value > 0)
                                {
                                    <span style="color:#ff6900; font-weight:600;">@url.CeneoSalesCount</span>
                                }
                                else
                                {
                                    <span style="color:#5f6368;">-</span>
                                }
                            </td>
                        </tr>

                        // Zwiększamy licznik o 1 na koniec każdej iteracji
                        rowIndex++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div id="initialState"
     style="display:none;"
     data-start-time="@(Model.ScrapingStartTime?.ToString("o") ?? "")"
     data-is-running="@(Model.CurrentStatus == CeneoExternalScrapingProcessStatus.Running ? "true" : "false")"
     data-base-count="@Model.DbStats.ScrapedUrls">
</div>
@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        (function () {
        function init() {
        var _initEl = document.getElementById('initialState');
        if (!_initEl) {
        console.error('[INIT] Brak #initialState. Sprawdź kolejność w _PanelLayout (RenderSection("Scripts") musi być PO RenderBody).');
        return;
        }

        var _startStr = _initEl.dataset.startTime;
        var scrapingStartTime = _startStr ? new Date(_startStr) : null;
        var isRunning = _initEl.dataset.isRunning === 'true';
        var currentFilter = 'all';
        var initialBaseCount = parseInt(_initEl.dataset.baseCount) || 0;

        function getToken() {
        var t = document.querySelector('input[name="__RequestVerificationToken"]');
        return t ? t.value : '';
        }

        function updateStatusBadge(status, text) {
            var badge = document.getElementById('statusBadge');
            badge.className = 'status-badge status-' + status;
            badge.textContent = text;
        }

        function updateControlButtons(running) {
            var section = document.getElementById('controlsSection');
            var rejCount = document.getElementById('rejectedUrlCount').textContent;
            var firstBtn = running
                ? '<button type="button" class="btn-ceneo btn-stop" onclick="stopScraping()"><i class="fas fa-stop"></i> Zatrzymaj scrapowanie</button>'
                : '<button type="button" class="btn-ceneo btn-start" onclick="startScraping()"><i class="fas fa-play"></i> Rozpocznij scrapowanie</button>';
            section.innerHTML =
                firstBtn +
                '<button type="button" class="btn-ceneo btn-reset" onclick="resetRejected()"><i class="fas fa-redo"></i> Resetuj odrzucone (<span id="rejectedCountBtn">' + rejCount + '</span>)</button>' +
                '<button type="button" class="btn-ceneo btn-clear" onclick="clearData()"><i class="fas fa-trash"></i> Wyczyść dane</button>';
        }

        function renderScraper(scraper) {
            var container = document.getElementById('scrapersContainer');
            var noScrapers = document.getElementById('noScrapersInfo');
            if (noScrapers) noScrapers.remove();

            var card = document.querySelector('.scraper-card[data-scraper="' + scraper.name + '"]');
            if (!card) {
                card = document.createElement('div');
                card.dataset.scraper = scraper.name;
                container.appendChild(card);
            }

            var statusClass = (scraper.status || '').toLowerCase();
            var statusText =
                statusClass === 'idle' ? 'Bezczynny' :
                statusClass === 'busy' ? 'Zajęty' :
                statusClass === 'offline' ? 'Offline' :
                statusClass === 'stopped' ? 'Zatrzymany' :
                statusClass === 'solvingcaptcha' ? 'Captcha' : statusClass;

            var urlsPerSec = ((scraper.urlsPerMinute || 0) / 60).toFixed(2);

            var actionBtn = scraper.isManuallyPaused
                ? '<button type="button" class="btn-scraper resume" onclick="resumeScraper(\'' + scraper.name + '\')"><i class="fas fa-play"></i> Wznów</button>'
                : '<button type="button" class="btn-scraper pause" onclick="pauseScraper(\'' + scraper.name + '\')"><i class="fas fa-pause"></i> Wstrzymaj</button>';

            var batchShort = scraper.currentBatchId
                ? scraper.currentBatchId.slice(-12)
                : 'Brak';

            card.className = 'scraper-card status-' + statusClass;
            card.innerHTML =
                '<div class="scraper-header">' +
                    '<div class="scraper-name">' + scraper.name + '</div>' +
                    '<span class="scraper-status ' + statusClass + '">' + statusText + '</span>' +
                '</div>' +
                '<div class="scraper-stats">' +
                    '<div class="scraper-stat"><div class="scraper-stat-value">' + (scraper.totalUrlsProcessed || 0) + '</div><div class="scraper-stat-label">Przetw.</div></div>' +
                    '<div class="scraper-stat"><div class="scraper-stat-value">' + (scraper.successRate || 0) + '%</div><div class="scraper-stat-label">Sukces</div></div>' +
                    '<div class="scraper-stat"><div class="scraper-stat-value">' + (scraper.urlsPerMinute || 0) + '</div><div class="scraper-stat-label">URL/min</div></div>' +
                    '<div class="scraper-stat"><div class="scraper-stat-value" style="color:#ff6900;">' + urlsPerSec + '</div><div class="scraper-stat-label">URL/sek</div></div>' +
                '</div>' +
                '<div class="scraper-details">' +
                    '<div><i class="fas fa-network-wired"></i> IP: ' + (scraper.currentIpAddress || 'N/A') + '</div>' +
                    '<div>' + (scraper.currentBatchId
                        ? '<i class="fas fa-spinner fa-spin" style="color:#ff6900;"></i> Paczka: <code>' + batchShort + '</code>' + (scraper.activeBatchTaskCount ? ' (' + scraper.activeBatchTaskCount + ' URLi)' : '')
                        : '<i class="fas fa-box"></i> Paczka: Brak') + '</div>' +
                    '<div><i class="fas fa-shield-alt"></i> Captcha: ' + (scraper.captchaCount || 0) + ' | <i class="fas fa-coins"></i> Ceny: ' + (scraper.totalPricesCollected || 0) + '</div>' +
                '</div>' +
                '<div class="scraper-actions">' + actionBtn + '</div>';
        }

        function updateDashboard(d) {
            document.getElementById('scrapersOnlineCount').textContent = d.scrapersOnline || 0;
            document.getElementById('scrapersBusyCount').textContent = d.scrapersBusy || 0;
            document.getElementById('scrapersCaptchaCount').textContent = d.scrapersSolvingCaptcha || 0;
            document.getElementById('onlineScrapersCount').textContent = d.scrapersOnline || 0;
            document.getElementById('captchaCountStat').textContent = d.totalCaptchaEvents || 0;
            document.getElementById('batchesProcessedStat').textContent = d.totalBatchesProcessed || 0;
            document.getElementById('batchesTimedOutStat').textContent = d.totalBatchesTimedOut || 0;
            document.getElementById('activeBatchesStat').textContent = d.activeBatchesCount || 0;

            var m = { 'Running': ['running', 'Działa'], 'Idle': ['idle', 'Bezczynny'], 'Paused': ['paused', 'Wstrzymany'] };
            var s = m[d.status] || ['idle', d.status];
            updateStatusBadge(s[0], s[1]);
            isRunning = d.status === 'Running';
        }

        function updateStats(s) {
            document.getElementById('totalUrlsStat').textContent = s.totalUrls;
            document.getElementById('scrapedUrlsStat').textContent = s.scrapedUrls;
            document.getElementById('rejectedUrlsStat').textContent = s.rejectedUrls;
            document.getElementById('totalPricesStat').textContent = s.totalPrices;
            document.getElementById('totalUrlCount').textContent = s.totalUrls;
            document.getElementById('scrapedUrlCount').textContent = s.scrapedUrls;
            document.getElementById('rejectedUrlCount').textContent = s.rejectedUrls;
            document.getElementById('pendingUrlCount').textContent = s.pendingUrls;
            document.getElementById('totalPricesCount').textContent = s.totalPrices;
            document.getElementById('progressScraped').textContent = s.scrapedUrls;
            document.getElementById('progressTotal').textContent = s.totalUrls;
            document.getElementById('progressPending').textContent = s.pendingUrls;

            var filterAll = document.getElementById('filterAll'); if (filterAll) filterAll.textContent = s.totalUrls;
            var filterScraped = document.getElementById('filterScraped'); if (filterScraped) filterScraped.textContent = s.scrapedUrls;
            var filterRejected = document.getElementById('filterRejected'); if (filterRejected) filterRejected.textContent = s.rejectedUrls;
            var filterPending = document.getElementById('filterPending'); if (filterPending) filterPending.textContent = s.pendingUrls;

            var rb = document.getElementById('rejectedCountBtn');
            if (rb) rb.textContent = s.rejectedUrls;

            var pct = s.totalUrls > 0 ? Math.round(s.scrapedUrls / s.totalUrls * 1000) / 10 : 0;
            var pb = document.getElementById('progressBarFill');
            pb.style.width = pct + '%';
            pb.textContent = pct + '%';

            if (isRunning && scrapingStartTime) {
                var elapsed = (new Date() - scrapingStartTime) / 1000;
                if (elapsed > 1) {
                    var processedInSession = Math.max(0, s.scrapedUrls - initialBaseCount);
                    var avgSpeed = (processedInSession / elapsed).toFixed(2);
                    document.getElementById('currentSpeed').textContent = avgSpeed;
                }
            }
        }

        function updateLogs(logs) {
            var html = '';
            for (var i = 0; i < logs.length; i++) {
                var l = logs[i];
                var t = new Date(l.timestamp).toLocaleTimeString('pl-PL');
                var b = l.batchId ? l.batchId.slice(-8) : '';
                html += '<div class="log-entry ' + l.level.toLowerCase() + '">' +
                        '<span class="log-time">[' + t + ']</span> ' +
                        '<span class="log-scraper">[' + l.scraperName + ']</span> ' +
                        (b ? '<span style="color:#89ddff;">[#' + b + ']</span> ' : '') +
                        l.message +
                        '</div>';
            }
            document.getElementById('logsContainer').innerHTML = html;
        }

        function updateOfferRow(o) {
            var row = document.querySelector('tr[data-id="' + o.id + '"]');
            if (!row) return;
            row.classList.remove('scraped', 'rejected');
            row.dataset.status = o.isRejected ? 'rejected' : (o.isScraped ? 'scraped' : 'pending');
            if (o.isRejected) row.classList.add('rejected');
            else if (o.isScraped) row.classList.add('scraped');

            row.querySelector('.status-cell').innerHTML =
                o.isRejected ? '<span class="badge badge-rejected">Odrzucony</span>' :
                o.isScraped ? '<span class="badge badge-scraped">Zescrapowany</span>' :
                '<span class="badge badge-pending">Oczekuje</span>';

            row.querySelector('.prices-cell').innerHTML = o.pricesCount > 0
                ? '<strong style="color:#1e8e3e;">' + o.pricesCount + '</strong>'
                : '<span style="color:#5f6368;">-</span>';

            applyCurrentFilter();
        }

        function updateElapsedTime() {
            if (!scrapingStartTime || !isRunning) return;
            var d = Math.floor((new Date() - scrapingStartTime) / 1000);
            document.getElementById('elapsedTime').textContent =
                String(Math.floor(d / 3600)).padStart(2, '0') + ':' +
                String(Math.floor((d % 3600) / 60)).padStart(2, '0') + ':' +
                String(d % 60).padStart(2, '0');
        }

        function applyFilter(f, btn) {
            currentFilter = f;
            document.querySelectorAll('.filter-tab').forEach(function (t) { t.classList.remove('active'); });
            if (btn) btn.classList.add('active');
            applyCurrentFilter();
        }

        function applyCurrentFilter() {
            var q = document.getElementById('searchBox').value.toLowerCase();
            document.querySelectorAll('#urlsTableBody tr').forEach(function (r) {
                var show = (currentFilter === 'all' || r.dataset.status === currentFilter) &&
                           (!q || r.textContent.toLowerCase().indexOf(q) !== -1);
                r.style.display = show ? '' : 'none';
            });
        }

        // === API CALLS ===

        function startScraping() {
            fetch('@Url.Action("StartScraping", "CeneoExternalScraper")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getToken() }
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    initialBaseCount = parseInt(document.getElementById('scrapedUrlCount').textContent) || 0;
                    scrapingStartTime = new Date();
                    updateControlButtons(true);
                    updateStatusBadge('running', 'Działa');
                } else {
                    alert('Błąd: ' + d.message);
                }
            })
            .catch(function (e) { alert('Błąd: ' + e); });
        }

        function stopScraping() {
            fetch('@Url.Action("StopScraping", "CeneoExternalScraper")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getToken() }
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    updateControlButtons(false);
                    updateStatusBadge('idle', 'Zatrzymane');
                }
            });
        }

        function resetRejected() {
            if (!confirm('Zresetować wszystkie odrzucone URL-e?')) return;
            fetch('@Url.Action("ResetRejected", "CeneoExternalScraper")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getToken() }
            }).then(refreshStats);
        }

        function clearData() {
            if (!confirm('Czy na pewno chcesz wyczyścić wszystkie zebrane dane Ceneo?')) return;
            fetch('@Url.Action("ClearData", "CeneoExternalScraper")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getToken() }
            }).then(function () { location.reload(); });
        }

        function pauseScraper(name) {
            var fd = new FormData();
            fd.append('scraperName', name);
            fetch('@Url.Action("PauseScraper", "CeneoExternalScraper")', {
                method: 'POST',
                body: fd,
                headers: { 'RequestVerificationToken': getToken() }
            });
        }

        function resumeScraper(name) {
            var fd = new FormData();
            fd.append('scraperName', name);
            fetch('@Url.Action("ResumeScraper", "CeneoExternalScraper")', {
                method: 'POST',
                body: fd,
                headers: { 'RequestVerificationToken': getToken() }
            });
        }

        function refreshStats() {
            fetch('@Url.Action("GetStats", "CeneoExternalScraper")')
                .then(function (r) { return r.json(); })
                .then(updateStats);
        }


           window.startScraping   = startScraping;
            window.stopScraping    = stopScraping;
            window.resetRejected   = resetRejected;
            window.clearData       = clearData;
            window.pauseScraper    = pauseScraper;
            window.resumeScraper   = resumeScraper;
            window.applyFilter     = applyFilter;

            // SignalR
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/scrapinghub")
                .withAutomaticReconnect()
                .build();

            connection.on("CeneoExternalUpdateScraperStatus", renderScraper);
            connection.on("CeneoExternalUpdateDashboard", updateDashboard);
            connection.on("CeneoExternalUpdateLogs", updateLogs);
            connection.on("CeneoExternalUpdateStats", updateStats);
            connection.on("CeneoExternalUpdateOfferRow", updateOfferRow);

            connection.on("CeneoExternalScrapingStarted", function (data) {
                isRunning = true;
                scrapingStartTime = new Date(data.startTime);
                initialBaseCount = parseInt(document.getElementById('scrapedUrlCount').textContent) || 0;
                updateStatusBadge('running', 'Działa');
                updateControlButtons(true);
            });
            connection.on("CeneoExternalScrapingFinished", function () {
                isRunning = false;
                updateStatusBadge('idle', 'Zakończone');
                updateControlButtons(false);
            });
            connection.on("CeneoExternalScrapingStopped", function () {
                isRunning = false;
                scrapingStartTime = null;
                updateStatusBadge('idle', 'Zatrzymane');
                updateControlButtons(false);
            });

            connection.start().catch(function (err) { console.error('[SignalR]', err); });

            // Pobierz aktywne scrapery przy starcie
            fetch('@Url.Action("GetScrapersDetails", "CeneoExternalScraper")')
                .then(function (r) { return r.json(); })
                .then(function (scrapers) {
                    if (scrapers && scrapers.length > 0) {
                        scrapers.forEach(function (s) { renderScraper(s); });
                    }
                })
                .catch(function (e) { console.warn('Nie pobrano scraperów:', e); });

            setInterval(updateElapsedTime, 1000);
            setInterval(refreshStats, 5000);
            document.getElementById('searchBox').addEventListener('input', applyCurrentFilter);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
}