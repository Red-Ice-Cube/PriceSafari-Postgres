@using PriceSafari.Models.ViewModels
@{
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    ViewBag.Title = "Analiza Safari - " + ViewBag.ReportName;
    var flags = ViewBag.Flags as List<FlagViewModel> ?? new List<FlagViewModel>();
    var regions = ViewBag.Regions as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<link rel="stylesheet" href="~/css/safari-report.css" asp-append-version="true" />

<div class="Vert">
    <div class="Page-Box">
        <div class="Page-Box-Container">

            <!-- ===================== LEWY PANEL ===================== -->
            <div class="Page-Box-Category">

                <div><img src="@ViewBag.StoreLogo" class="img-container" /></div>

                <!-- 2 zakładki wykresów -->
                <div class="period-selector-group safari-chart-tabs">
                    <button type="button" class="period-btn-custom chart-tab active" data-chart="classification" title="Klasyfikacja Twojej pozycji cenowej">
                        <i class="fa-solid fa-chart-pie"></i>
                    </button>
                    <button type="button" class="period-btn-custom chart-tab" data-chart="countries" title="Rozkład ofert wg krajów">
                        <i class="fa-solid fa-globe"></i>
                    </button>
                </div>

                <div class="side-chart-box safari-chart-box">
                    <canvas id="mainChart"></canvas>
                </div>

                <!-- Klasyfikacja -->
                <div class="store-section" id="filters-competitiveness">
                    <div class="form-check">
                        <span class="color-rect rect-no-offer"></span>
                        <input class="form-check-input colorFilter" type="checkbox" id="prNoOfferCheckbox" value="prNoOffer">
                        <label class="form-check-label" for="prNoOfferCheckbox">Brak Twojej oferty</label>
                    </div>

                    <div class="form-check">
                        <span class="color-rect rect-ideal"></span>
                        <input class="form-check-input colorFilter" type="checkbox" id="prIdealCheckbox" value="prIdeal">
                        <label class="form-check-label" for="prIdealCheckbox">Twoja oferta tańsza</label>
                    </div>

                    <div class="form-check">
                        <span class="color-rect rect-gray"></span>
                        <input class="form-check-input colorFilter" type="checkbox" id="prGrayCheckbox" value="prGray">
                        <label class="form-check-label" for="prGrayCheckbox">Cena podobna</label>
                    </div>

                    <div class="form-check">
                        <span class="color-rect rect-to-high"></span>
                        <input class="form-check-input colorFilter" type="checkbox" id="prToHighCheckbox" value="prToHigh">
                        <label class="form-check-label" for="prToHighCheckbox">Twoja oferta droższa</label>
                    </div>

                    <div class="safari-thresholds-wrap">
                        <div class="price-range-settings">
                            <div class="color-circle prIdeal-circle"></div>
                            <div class="legendBox"><span>Tańsza o min.</span></div>
                            <label for="price2"></label>
                            <input type="number" id="threshold1"
                                   value="@(((decimal)ViewBag.SetSafariPrice1).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                   step="0.01" min="0">
                            <span id="unitLabel1" class="safari-unit-label"></span>
                        </div>

                        <div class="price-range-settings">
                            <div class="color-circle prHigher-circle"></div>
                            <div class="legendBox"><span>Droższa o min.</span></div>
                            <label for="price2"></label>
                            <input type="number" id="threshold2"
                                   value="@(((decimal)ViewBag.SetSafariPrice2).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                   step="0.01" min="0">
                            <span id="unitLabel2" class="safari-unit-label"></span>
                        </div>

                        <div class="safari-threshold-actions">
    
                            <div style="flex: 1; display: flex;">
                                <input class="diffCheckBox" style="margin: 0; width: 100%;" type="checkbox" id="usePriceDifference"
                                @(((bool)ViewBag.UsePriceDiffSafari) ? "checked" : "") />
                            </div>

                            <button class="Button-Page-Small" style="margin: 0; flex: 1; width: 100%; padding-left: 0; padding-right: 0;" id="savePriceValues"
                                    data-store-id="@ViewBag.StoreId">
                                Przelicz i zapisz
                            </button>

                        </div>
                    </div>
                </div>

                <div class="filterBox">

                    <!-- FLAGI — teraz PIERWSZE -->
                    <div class="Category-Container-Select">
                        Flagi
                        <a asp-controller="Flags" asp-action="List" asp-route-storeId="@ViewBag.StoreId" class="link-line">+ Dodaj flagę</a>
                    </div>
                    <div class="store-section" id="flagContainer"></div>

                    <!-- REGION RYNKU — teraz POD flagami -->
                    <div class="Category-Container-Select">Region rynku</div>
                    <div class="store-section">
                        <select id="regionFilter" class="DropDown safari-fullwidth-select">
                            <option value="">Wszystkie regiony</option>
                            @foreach (var r in regions)
                            {
                                <option value="@r.Key" selected="@(r.Key == (int?)ViewBag.RegionId)">@r.Value</option>
                            }
                        </select>
                    </div>

                    <div class="Category-Container-Select">Liczba ofert konkurencji</div>
                    <div class="store-section">
                        <div id="offerRange" class="safari-range-display"></div>
                        <div id="offerRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Cena Twojej oferty</div>
                    <div class="store-section">
                        <div id="myPriceRange" class="safari-range-display"></div>
                        <div id="myPriceRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Cena konkurencji</div>
                    <div class="store-section">
                        <div id="compPriceRange" class="safari-range-display"></div>
                        <div id="compPriceRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Pozycja na rynku</div>
                    <div class="store-section">
                        <div id="positionRange" class="safari-range-display"></div>
                        <div id="positionRangeSlider"></div>
                    </div>

                </div>
            </div>

            <!-- ===================== PRAWY PANEL ===================== -->
            <div class="Horizontal">

                <div class="order-upper-box">
                    <input type="text" id="productSearch" placeholder="Wyszukaj produkt"
                           class="safari-toolbar-input">

                    <input type="text" id="storeSearch" placeholder="Wyszukaj sklep"
                           class="safari-toolbar-input">

                    <select id="producerFilterDropdown" class="DropDown safari-toolbar-select">
                        <option value="">Wszystkie marki</option>
                    </select>

                    <select id="identifierSelect" class="DropDown safari-toolbar-select-narrow"
                            title="Wyświetlany identyfikator">
                        <option value="EAN">EAN</option>
                        <option value="ID">ID</option>
                        <option value="ProducerCode">SKU</option>
                    </select>

                    <button class="Button-Page-Small" id="exportSafariExcelBtn">
                        <i class="fa-solid fa-file-excel"></i>Eksport
                    </button>

                    <button type="button" class="Button-Page-Small safari-info-btn" data-toggle="modal" data-target="#infoModal">
                        <i class="fa fa-info-circle"></i>
                    </button>
                </div>

                <div id="sortingButtons">
                    <div class="ProductCount" id="displayedProductCount">0</div>
                    <div id="paginationContainer"></div>

                    <button id="sortName">A-Z</button>
                    <button id="sortPrice">Cena</button>
                    <button id="sortDifferenceAmount">Różnica PLN</button>
                    <button id="sortDifferencePercent">Różnica %</button>
                    <button id="sortMarginAmount">Narzut PLN</button>
                    <button id="sortMarginPercent">Narzut %</button>
                    <button id="sortOfferCount">Ilość ofert</button>
                </div>

                <div class="Vert-table">
                    <div id="priceContainer" class="price-container"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Info Modal -->
<div class="modal fade" id="infoModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content safari-modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Informacje o raporcie</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Zamknij">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-check-orders">
                    <p><strong>Nazwa raportu:</strong> @ViewBag.ReportName</p>
                    <p><strong>Data utworzenia:</strong> @(((DateTime)ViewBag.CreatedDate).ToString("dd.MM.yyyy HH:mm"))</p>
                    <p><strong>Sklep:</strong> @ViewBag.StoreName</p>
                    <p><strong>Liczba produktów:</strong> <span id="modalProductCount">0</span></p>
                    <p><strong>Liczba zebranych ofert:</strong> <span id="modalOfferCount">0</span></p>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="globalNotification" class="safari-notification safari-notification-error"></div>
<div id="globalUpdate" class="safari-notification safari-notification-success"></div>

<div id="loadingOverlay" class="loading-overlay" style="display:none;">
    <div class="loader"></div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.6.1/nouislider.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/wnumb/1.2.0/wNumb.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.6.1/nouislider.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

    <script>
        window.safariConfig = {
        reportId: @ViewBag.ReportId,
        storeId: @ViewBag.StoreId,
        regionId: @(ViewBag.RegionId != null ? ViewBag.RegionId.ToString() : "null"),
        myStoreName: @Html.Raw(Json.Serialize((string)ViewBag.StoreName ?? "")),
        flags: @Html.Raw(Json.Serialize(flags)),
        setSafariPrice1: @(((decimal)ViewBag.SetSafariPrice1).ToString(System.Globalization.CultureInfo.InvariantCulture)),
        setSafariPrice2: @(((decimal)ViewBag.SetSafariPrice2).ToString(System.Globalization.CultureInfo.InvariantCulture)),
        usePriceDiffSafari: @(((bool)ViewBag.UsePriceDiffSafari) ? "true" : "false"),
        identifierForSimulation: @Html.Raw(Json.Serialize((string)ViewBag.IdentifierForSimulation ?? "EAN"))
        };
    </script>

    <script src="~/js/member/SafariReportAnalysis.js" asp-append-version="true"></script>
}
