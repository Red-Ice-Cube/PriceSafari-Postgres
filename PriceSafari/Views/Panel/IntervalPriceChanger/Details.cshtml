        const CountdownSystem = (function() {
            let elements = [];
            let timer = null;

            function formatDiff(ms) {
                if (ms <= 0) return null;
                const totalSec = Math.floor(ms / 1000);
                const days = Math.floor(totalSec / 86400);
                const h = Math.floor((totalSec % 86400) / 3600);
                const m = Math.floor((totalSec % 3600) / 60);
                const s = totalSec % 60;
                if (days > 0) return `Za ${days}d ${h}h`;
                if (h > 0) return `Za ${h}h ${m}min`;
                if (m > 0) return `Za ${m}min ${s}s`;
                return `Za ${s}s`;
            }

            function formatKpi(ms) {
                if (ms <= 0) return null;
                const totalSec = Math.floor(ms / 1000);
                const days = Math.floor(totalSec / 86400);
                const h = Math.floor((totalSec % 86400) / 3600);
                const m = Math.floor((totalSec % 3600) / 60);
                const s = totalSec % 60;
                if (days > 0) return `Za ${days}d ${h}h`;
                if (h > 0) return `Za ${h}h ${m}m`;
                if (m > 0) return `Za ${m}m ${s}s`;
                return `Za ${s}s`;
            }

            function tick() {
                const now = Date.now();
                elements.forEach(el => {
                    const iso = el.getAttribute('data-countdown');
                    if (!iso) return;
                    const target = new Date(iso).getTime();
                    const diff = target - now;
                    const isKpi = el.id === 'kpiNextExecLabel';

                    if (diff <= 0) {

                        if (isKpi) {
                            el.textContent = 'Wykonuje się...';
                            el.style.color = '#8e44ad';
                        } else {

                            el.classList.remove('countdown-active');
                            el.classList.add('countdown-running');
                            el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Wykonuje się...';
                        }
                        return;
                    }

                    const txt = isKpi ? formatKpi(diff) : formatDiff(diff);
                    if (isKpi) {
                        el.textContent = txt;
                    } else {

                        el.innerHTML = '<i class="fas fa-clock"></i> ' + txt;
                    }
                });
            }

            function init() {
                elements = Array.from(document.querySelectorAll('[data-countdown]')).filter(el => {
                    const iso = el.getAttribute('data-countdown');
                    return iso && iso.length > 0;
                });
                if (elements.length === 0) return;
                tick();
                timer = setInterval(tick, 1000);
            }

            return { init };
        })();

        document.addEventListener("DOMContentLoaded", function() {
            const searchInput = document.getElementById('productSearch');
