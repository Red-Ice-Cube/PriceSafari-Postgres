@await Html.PartialAsync("~/Views/Shared/PartialViewsPanel/_MassAction.cshtml")

@section Scripts {
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/member/MassActions.js"></script>

    <script>

        const storeId = @Model.StoreId;
        const intervalRuleId = @Model.IntervalRuleId;
        const parentRuleId = @Model.ParentRuleId;
        const isAllegroContext = @(isMarketplace ? "true" : "false");
        const flags = @Html.Raw(Json.Serialize(Model.AvailableStoreFlags));

        const STEPS_DATA = {
            1: {
                value: @Model.PriceStep.ToString(System.Globalization.CultureInfo.InvariantCulture),
                pct:   @(Model.IsPriceStepPercent ? "true" : "false"),
                active:@(Model.IsStepAActive ? "true" : "false")
            },
            2: {
                value: @Model.PriceStepB.ToString(System.Globalization.CultureInfo.InvariantCulture),
                pct:   @(Model.IsPriceStepPercentB ? "true" : "false"),
                active:@(Model.IsStepBActive ? "true" : "false")
            },
            3: {
                value: @Model.PriceStepC.ToString(System.Globalization.CultureInfo.InvariantCulture),
                pct:   @(Model.IsPriceStepPercentC ? "true" : "false"),
                active:@(Model.IsStepCActive ? "true" : "false")
            }
        };

function _renderIntervalUnassignUI(data, ctx) {
    var container = document.getElementById('intervalUnassignContainer');
    container.innerHTML = '';

    var intervals = data.intervals || [];

    var currentInterval = intervals.find(function (iv) { return iv.id === intervalRuleId; });
    var matchingInCurrent = currentInterval ? (currentInterval.matchingCount || 0) : 0;
    var notInCurrent = ctx.count - matchingInCurrent;

    var statsHeader = document.createElement('div');
    statsHeader.style.cssText = 'background-color:#f8f9fa; border:1px solid #e3e6f0; border-radius:8px; padding:15px; margin-bottom:16px; display:flex; justify-content:space-around; align-items:center; text-align:center;';
    statsHeader.innerHTML =
        '<div>'
        + '<div style="font-size:11px; color:#858796; text-transform:uppercase; font-weight:700; letter-spacing:0.5px;">Zaznaczonych</div>'
        + '<div style="font-size:20px; font-weight:700; color:#5a5c69;">' + ctx.count + '</div>'
        + '</div>'
        + '<div style="border-left:1px solid #e3e6f0; height:30px;"></div>'
        + '<div>'
        + '<div style="font-size:11px; color:#e67e22; text-transform:uppercase; font-weight:700; letter-spacing:0.5px;">W tym interwale</div>'
        + '<div style="font-size:20px; font-weight:700; color:#e67e22;">' + matchingInCurrent + '</div>'
        + '</div>'
        + '<div style="border-left:1px solid #e3e6f0; height:30px;"></div>'
        + '<div>'
        + '<div style="font-size:11px; color:#858796; text-transform:uppercase; font-weight:700; letter-spacing:0.5px;">Poza interwałem</div>'
        + '<div style="font-size:20px; font-weight:700; color:#858796;">' + Math.max(0, notInCurrent) + '</div>'
        + '</div>';
    container.appendChild(statsHeader);

    if (typeof data.storeLimit !== 'undefined') {
        var storeLimit = data.storeLimit || 0;
        var storeUsed = data.storeUsed || 0;
        var storeRemaining = Math.max(0, data.storeRemaining || 0);
        var pct = storeLimit > 0 ? Math.min(100, (storeUsed / storeLimit) * 100) : 0;
        var barColor = pct >= 90 ? '#e74a3b' : pct >= 70 ? '#f6c23e' : '#27ae60';

        var limitBox = document.createElement('div');
        limitBox.style.cssText = 'background:#fff; border:1px solid #e3e6f0; border-radius:8px; padding:14px 18px; margin-bottom:20px;';

        var limitHtml =
            '<div style="display:flex; justify-content:space-between; align-items:center; font-size:11px; font-weight:700; color:#858796; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:6px;">'
            + '  <span><i class="fas fa-database" style="margin-right:5px;"></i>Limit produktów w interwale (sklep)</span>'
            + '  <span style="color:' + barColor + ';">' + storeUsed + ' / ' + (storeLimit > 0 ? storeLimit : '—') + '</span>'
            + '</div>';

        if (storeLimit > 0) {
            limitHtml +=
                '<div style="width:100%; height:8px; background:#e3e3e3; border-radius:4px; overflow:hidden;">'
                + '  <div style="width:' + pct + '%; height:100%; background:' + barColor + '; border-radius:4px; transition:width 0.3s;"></div>'
                + '</div>'
                + '<div style="font-size:11px; color:#858796; margin-top:6px;">Wolnych miejsc: <strong style="color:#27ae60;">' + storeRemaining + '</strong></div>';

            if (matchingInCurrent > 0) {
                limitHtml +=
                    '<div style="margin-top:10px; padding:10px 12px; background:rgba(28,200,138,0.08); border-left:3px solid #1cc88a; border-radius:4px; font-size:12px; color:#5a5c69; line-height:1.4;">'
                    + '<i class="fas fa-info-circle" style="color:#1cc88a; margin-right:6px;"></i>'
                    + 'Po odpięciu zwolni się <strong style="color:#1cc88a;">' + matchingInCurrent + '</strong> miejsc w limicie sklepu.'
