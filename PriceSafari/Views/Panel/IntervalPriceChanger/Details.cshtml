                sessionStorage.setItem('interval_activeFilters', JSON.stringify(activeFilters));

                const searchInput = document.getElementById('productSearch');
                if (searchInput) sessionStorage.setItem('interval_searchText', searchInput.value);
            },
            restoreFiltersAndSearch: function () {
                const savedSearch = sessionStorage.getItem('interval_searchText');
                if (savedSearch) {
                    const searchInput = document.getElementById('productSearch');
                    if (searchInput) {
                        searchInput.value = savedSearch;
                        searchInput.dispatchEvent(new Event('input'));
                    }
                }
                const savedFilters = sessionStorage.getItem('interval_activeFilters');
                if (savedFilters) {
                    try {
                        const filters = JSON.parse(savedFilters);
                        if (Array.isArray(filters)) {
                            filters.forEach(key => {
                                const btn = document.querySelector(`.filter-btn[data-filter-key="${key}"]`);
                                if (btn && !btn.classList.contains('active')) btn.click();
                            });
                        }
                    } catch (e) { console.error("Błąd przywracania filtrów:", e); }
                }
            },
            scrollToProduct: function () {
                const scrollToId = sessionStorage.getItem('interval_scrollToProduct');
                if (!scrollToId) return;

                sessionStorage.removeItem('interval_scrollToProduct');
                sessionStorage.removeItem('interval_activeFilters');
                sessionStorage.removeItem('interval_searchText');

                setTimeout(function () {
                    const wrapper = document.querySelector('.purchase-wrapper[data-id="' + scrollToId + '"]');
                    if (wrapper) {
                        const row = wrapper.closest('tr');
                        row.scrollIntoView({ behavior: 'instant', block: 'center' });
                        window.scrollTo(0, 0);

                        row.style.transition = 'background-color 0s';
                        row.style.backgroundColor = '#fff3cd';
                        setTimeout(function () {
                            row.style.transition = 'background-color 3s ease';
                            row.style.backgroundColor = '';
                        }, 100);
                    }
                    document.documentElement.style.visibility = 'visible';
                }, 300);
            }
        };

        $(document).ready(function () {
            StateManager.restoreFiltersAndSearch();
            StateManager.scrollToProduct();
        });

    
        const PauseSystem = (function () {
            let currentProductId = null;
            let currentProductName = null;
            let countdownTimer = null;

            function escapeHtml(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
                })[c]);
            }

            function isPauseIndefinite(iso) {
                if (!iso) return false;
                const d = new Date(iso);
                if (isNaN(d.getTime())) return false;
                const now = new Date();
                const diffYears = (d - now) / (1000 * 60 * 60 * 24 * 365);
                return diffYears > 5;
            }

            function formatRemaining(iso) {
                if (!iso) return '-';
                const target = new Date(iso);
                if (isNaN(target.getTime())) return '-';
                const now = new Date();
                let diffMs = target - now;
                if (diffMs <= 0) return 'wygasło';

                const diffMinutes = Math.floor(diffMs / 60000);
                const days = Math.floor(diffMinutes / 1440);
                const hours = Math.floor((diffMinutes % 1440) / 60);
                const minutes = diffMinutes % 60;

                if (days > 0) return days + 'd ' + hours + 'h';
                if (hours > 0) return hours + 'h ' + minutes + 'min';
                if (minutes > 0) return minutes + 'min';
                return '< 1min';
            }

            function buildDurationCards() {
                const durations = [
                    { hours: 1, label: '1 godzina' },
                    { hours: 4, label: '4 godziny' },
                    { hours: 6, label: '6 godzin' },
                    { hours: 12, label: '12 godzin' },
                    { hours: 24, label: '24 godziny' }
                ];
                let html = '<div class="pause-duration-grid">';
                durations.forEach(d => {
                    html += `
                        <div class="pause-duration-card" data-pause-hours="${d.hours}">
                            <div class="duration-value">${d.hours}h</div>
                            <div class="duration-label">${d.label}</div>
                        </div>
                    `;
                });
                html += '</div>';
                html += `
                    <div class="pause-duration-card-indefinite" data-pause-hours="-1">
                        <i class="fas fa-infinity indef-icon"></i>
                        <div class="indef-text">
                            <div class="indef-title">Do odwołania</div>
                            <div class="indef-sub">Wstrzymane bez limitu czasu — wznów ręcznie</div>
                        </div>
                    </div>
                `;
                return html;
            }

            function openModal(productId, productName, isPausedNow, pausedUntilIso) {
                currentProductId = productId;
                currentProductName = productName;
                const content = document.getElementById('pauseModalContent');

                if (isPausedNow) {
                    const indefinite = isPauseIndefinite(pausedUntilIso);
                    const remaining = indefinite ? null : formatRemaining(pausedUntilIso);

                    let infoHtml = indefinite
                        ? '<strong>Wstrzymano do odwołania.</strong> Automat oraz interwał nie będą zmieniać ceny dopóki nie wznowisz ręcznie.'
                        : 'Pozostały czas wstrzymania: <strong>' + escapeHtml(remaining) + '</strong>';

                    content.innerHTML = `
                        <div class="pause-currently-info">
                            <i class="fas fa-pause-circle pause-currently-icon"></i>
                            <div class="pause-currently-text">
                                <div class="pname">${escapeHtml(productName)}</div>
                                <div class="ptime">${infoHtml}</div>
                            </div>
                        </div>
                        <button type="button" class="pause-resume-btn" data-pause-action="unpause">
                            <i class="fas fa-play"></i> Wznów działanie automatu
                        </button>
                        <div class="pause-section-divider">Lub przedłuż wstrzymanie</div>
                        <p class="pause-instructions">Wybierz nowy czas — zastąpi obecne ustawienie.</p>
                        ${buildDurationCards()}
                    `;
                } else {
                    content.innerHTML = `
                        <div class="pause-product-name-box">${escapeHtml(productName)}</div>
                        <p class="pause-instructions">
                            Wybierz na jak długo chcesz wstrzymać automatyczne zmiany cen dla tego produktu.
                            Pauza dotyczy automatu cenowego oraz systemu Interwału cenowego.
                        </p>
                        ${buildDurationCards()}
                    `;
                }

                $('#pauseProductModal').modal('show');
            }

            function pause(durationHours) {
                if (!currentProductId) return;
                const token = $('input[name="__RequestVerificationToken"]').val();

                $('#pauseProductModal').modal('hide');
                if (typeof showLoading === 'function') showLoading();
                else $('#loadingOverlay').css('display', 'flex');

                $.ajax({
                    url: '@Url.Action("PauseProduct", "IntervalPrice")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': token },
                    data: JSON.stringify({
                        RuleId: intervalRuleId,
                        ProductId: parseInt(currentProductId),
                        DurationHours: parseInt(durationHours)
                    }),
                    success: function (r) {
                        if (typeof hideLoading === 'function') hideLoading(); else $('#loadingOverlay').hide();
                        if (r && r.success) {
                            sessionStorage.setItem('interval_scrollToProduct', currentProductId);
                            location.reload();
                        } else {
                            alert('Błąd: ' + ((r && r.message) || 'Nie udało się zapisać pauzy.'));
                        }
                    },
                    error: function (xhr) {
                        if (typeof hideLoading === 'function') hideLoading(); else $('#loadingOverlay').hide();
                        alert('Błąd komunikacji: ' + (xhr.responseText || xhr.statusText));
                    }
                });
            }

            function unpause() {
                if (!currentProductId) return;
                const token = $('input[name="__RequestVerificationToken"]').val();

                $('#pauseProductModal').modal('hide');
                if (typeof showLoading === 'function') showLoading();
                else $('#loadingOverlay').css('display', 'flex');

                $.ajax({
                    url: '@Url.Action("UnpauseProduct", "IntervalPrice")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': token },
                    data: JSON.stringify({
                        RuleId: intervalRuleId,
                        ProductId: parseInt(currentProductId)
                    }),
                    success: function (r) {
                        if (typeof hideLoading === 'function') hideLoading(); else $('#loadingOverlay').hide();
                        if (r && r.success) {
                            sessionStorage.setItem('interval_scrollToProduct', currentProductId);
                            location.reload();
                        } else {
                            alert('Błąd: ' + ((r && r.message) || 'Nie udało się wznowić.'));
                        }
                    },
                    error: function (xhr) {
                        if (typeof hideLoading === 'function') hideLoading(); else $('#loadingOverlay').hide();
                        alert('Błąd komunikacji: ' + (xhr.responseText || xhr.statusText));
                    }
                });
            }

            function updateCountdowns() {
                document.querySelectorAll('.pause-product-btn.is-paused').forEach(btn => {
                    const iso = btn.getAttribute('data-paused-until');
                    if (!iso) return;

                    const target = new Date(iso);
                    if (isNaN(target.getTime())) return;
                    const now = new Date();

                    if (target <= now) {
                        btn.classList.remove('is-paused');
                        btn.innerHTML = '<i class="fas fa-play"></i>';
                        btn.title = 'Wstrzymaj automat dla tego produktu';
                        btn.setAttribute('data-paused-until', '');
                        const row = btn.closest('tr');
                        if (row) {
                            row.classList.remove('row-paused');
                            row.setAttribute('data-is-paused', 'false');
                        }
                        return;
                    }

                    const txt = btn.querySelector('.pause-countdown-text');
                    if (!txt) return;
                    txt.textContent = isPauseIndefinite(iso) ? '∞' : formatRemaining(iso);
                });
            }

            function init() {
                document.addEventListener('click', function (e) {
                    const btn = e.target.closest('.pause-product-btn');
                    if (!btn) return;
                    if (btn.style.cursor === 'not-allowed') return;
                    e.preventDefault();
                    e.stopPropagation();

                    const productId = btn.dataset.productId;
                    const productName = btn.dataset.productName;
                    const isPausedNow = btn.classList.contains('is-paused');
                    const pausedUntil = btn.getAttribute('data-paused-until');

                    openModal(productId, productName, isPausedNow, pausedUntil);
                });

                document.addEventListener('click', function (e) {
                    const card = e.target.closest('.pause-duration-card, .pause-duration-card-indefinite');
                    if (card && document.getElementById('pauseProductModal').classList.contains('show')) {
                        const hours = card.getAttribute('data-pause-hours');
                        pause(hours);
                        return;
                    }
                    const resumeBtn = e.target.closest('[data-pause-action="unpause"]');
                    if (resumeBtn) { unpause(); return; }
                });

                updateCountdowns();
                countdownTimer = setInterval(updateCountdowns, 30000);
            }

            return { init };
        })();

        $(document).ready(function () { PauseSystem.init(); });

        let scheduleOpen = false, scheduleBuilt = false;

        function toggleSchedule() {
            scheduleOpen = !scheduleOpen;
            document.getElementById('scheduleCollapsible').classList.toggle('open', scheduleOpen);
            document.getElementById('scheduleChevron').classList.toggle('open', scheduleOpen);
            document.getElementById('scheduleToggleHint').textContent = scheduleOpen ? '(kliknij aby zwinąć)' : '(kliknij aby rozwinąć)';
            if (scheduleOpen && !scheduleBuilt) { scheduleBuilt = true; SG.init(); }
        }

        const SG = (function () {
            const DAYS = 7, SLOTS = 144;
            const STEP_LETTERS = { 1: 'A', 2: 'B', 3: 'C' };
            let grid = [], cells = {};

            const serverNow = new Date('@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")');
            const nowDayIndex = ((serverNow.getDay() + 6) % 7);
            const nowSlotIndex = Math.floor((serverNow.getHours() * 60 + serverNow.getMinutes()) / 10);

            const G = {
                c:  {1:'#145a32',2:'#1a7a42',3:'#1e8c4a',4:'#22a053',5:'#27ae60',6:'#2ecc71'},
                hi: {1:'#1a7040',2:'#20904e',3:'#26a458',4:'#2cb862',5:'#34d870',6:'#3ee882'},
                lo: {1:'#0f4426',2:'#145a32',3:'#18703c',4:'#1c8646',5:'#209c50',6:'#24b25a'},
                accent:'#27ae60'
            };
            const R = {
                c:  {1:'#7b1a1a',2:'#992222',3:'#b52a2a',4:'#cc3333',5:'#e04040',6:'#e86060'},
                hi: {1:'#922222',2:'#aa2e2e',3:'#c43636',4:'#d94040',5:'#ec5050',6:'#f07070'},
                lo: {1:'#5c1212',2:'#6e1818',3:'#841e1e',4:'#9a2626',5:'#b03030',6:'#c43a3a'},
                accent:'#e04040'
            };

            function slotTime(s) { const h = Math.floor((s*10)/60), m = (s*10)%60; return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0'); }

            function decodeVal(v) {
                const a = Math.abs(v);
                if (a === 0) return { stepIdx: 0, size: 0 };
                if (a >= 1 && a <= 6) return { stepIdx: 1, size: a }; 

                return { stepIdx: Math.floor(a/100), size: a % 100 };
            }

            function getStepInfo(stepIdx) {
                const data = STEPS_DATA[stepIdx] || STEPS_DATA[1];
                const v = data.value, pct = data.pct, active = data.active;
                return {
                    stepIdx: stepIdx,
                    letter: STEP_LETTERS[stepIdx] || 'A',
                    value: v,
                    active: active,
                    up: v > 0,
                    text: (v<0?'':'+') + Math.abs(v).toFixed(2) + (pct?'%':' PLN'),
                    icon: v>0?'fa-arrow-up':'fa-arrow-down',
                    palette: v>0 ? R : G
                };
            }

            function init() {
                try {
                    grid = JSON.parse('@Html.Raw(Model.ScheduleJson ?? "[]")');
                    if (!Array.isArray(grid) || grid.length !== DAYS) throw 0;
                } catch {
                    grid = Array.from({length:DAYS}, () => Array(SLOTS).fill(0));
                }
                buildTable();
                render();
            }

            function buildTable() {
                const tbody = document.getElementById('sgBody');
                tbody.innerHTML = '';
                cells = {};
                for (let d = 0; d < DAYS; d++) cells[d] = {};

                const sr = document.createElement('tr');
                sr.className = 'day-stats-row';
                const t0 = document.createElement('td');
                t0.className = 'tc'; t0.style.fontSize = '8px'; t0.textContent = '∑';
                sr.appendChild(t0);
                for (let d = 0; d < DAYS; d++) {
                    const td = document.createElement('td');
                    td.id = 'ds-'+d;
                    sr.appendChild(td);
                }
                tbody.appendChild(sr);

                for (let s = 0; s < SLOTS; s++) {
                    const isHour = (s*10)%60 === 0;
                    const tr = document.createElement('tr');
                    if (isHour) tr.classList.add('hour-boundary');
                    const tc = document.createElement('td');
                    tc.className = 'tc' + (isHour?' hour-mark':'');
                    tc.textContent = slotTime(s);
                    tr.appendChild(tc);
                    for (let d = 0; d < DAYS; d++) {
                        const td = document.createElement('td');
                        td.className = 'sg-cell';
                        td.dataset.d = d;
                        td.dataset.s = s;
                        cells[d][s] = td;
                        tr.appendChild(td);
                    }
                    tbody.appendChild(tr);
                }
            }

            function mkLabel(info, timeStr) {
                return '<div class="blk-lbl">'
                    + '<span class="blk-lbl-left">'
                    + '<span class="blk-lbl-step blk-lbl-step-' + info.stepIdx + '">' + info.letter + '</span>'
                    + '<i class="fas ' + info.icon + '"></i> ' + info.text
                    + '</span>'
                    + '<span class="blk-lbl-right">' + timeStr + '</span>'
                    + '</div>';
            }

            function render() {

                for (let d = 0; d < DAYS; d++) {
                    for (let s = 0; s < SLOTS; s++) {
                        const td = cells[d][s];
                        td.className = 'sg-cell';
                        td.innerHTML = '';
                        td.style.cssText = '';
                    }
                }

                const dayBlocks = Array(DAYS).fill(0);
                let totalBlocks = 0;

                for (let d = 0; d < DAYS; d++) {
                    let s = 0;
                    while (s < SLOTS) {
                        const v = grid[d][s];
                        if (v <= 0) { s++; continue; }

                        let len = 1;
                        while (s+len < SLOTS && grid[d][s+len] === -v) len++;

                        const decoded = decodeVal(v);
                        const info = getStepInfo(decoded.stepIdx);
                        const size = decoded.size;
                        const color = info.palette.c[size] || info.palette.c[1];
                        const colorHi = info.palette.hi[size] || info.palette.hi[1];
                        const colorLo = info.palette.lo[size] || info.palette.lo[1];
                        const timeFrom = slotTime(s);

                        dayBlocks[d]++;
                        totalBlocks++;

                        for (let i = 0; i < len; i++) {
                            const cell = cells[d][s+i];
                            let css = 'background:'+color+';border-color:'+color+';';
                            const shadows = [];

                            if (!info.active) {
                                cell.classList.add('inactive-step');
                            }

                            if (len === 1) {
                                shadows.push('inset 0 2px 0 0 '+colorHi, 'inset 0 -2px 0 0 '+colorLo);
                                cell.innerHTML = mkLabel(info, timeFrom);
                            } else if (i === 0) {
                                shadows.push('inset 0 2px 0 0 '+colorHi);
                                cell.innerHTML = mkLabel(info, timeFrom);
                            } else if (i === len-1) {
                                shadows.push('inset 0 -2px 0 0 '+colorLo);
                            }

                            if (shadows.length) css += 'box-shadow:'+shadows.join(',')+';';
                            cell.style.cssText = css;
                        }
                        s += len;
                    }
                }

                for (let d = 0; d < DAYS; d++) {
                    const el = document.getElementById('ds-'+d);
                    if (el) {
                        el.innerHTML = dayBlocks[d]>0
                            ? '<span style="color:#5a5c69;font-weight:700;">'+dayBlocks[d]+'</span>'
                            : '<span style="color:#d0d2d8;">0</span>';
                    }
                }

                if (nowDayIndex>=0 && nowDayIndex<DAYS && nowSlotIndex>=0 && nowSlotIndex<SLOTS) {
                    cells[nowDayIndex][nowSlotIndex].classList.add('now-marker');
                }
            }

            return { init };
        })();
    </script>
}
