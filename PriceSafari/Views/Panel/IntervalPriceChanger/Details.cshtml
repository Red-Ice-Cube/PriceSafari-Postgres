@using PriceSafari.Models
@using PriceSafari.Models.ViewModels
@using PriceSafari.IntervalPriceChanger.Models
@using PriceSafari.IntervalPriceChanger.Models.ViewModels
@using Microsoft.AspNetCore.Identity

@model IntervalPriceDetailsViewModel
@inject UserManager<PriceSafariUser> UserManager

@{
    ViewData["Title"] = $"Interwał: {Model.IntervalName}";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    <link href="~/css/Automation.css" rel="stylesheet" asp-append-version="true" />
    var user = await UserManager.GetUserAsync(User);
    bool canEdit = user?.AccesToEditPriceAutomation ?? false;
    string noAccessMessage = "Nie masz uprawnień aby zarządzać regułami automatyzacji cen. Skontaktuj sie z nami biuro@pricesafari.pl";

    bool isMarketplace = Model.SourceType == AutomationSourceType.Marketplace;
    bool effectivelyActive = Model.IsEffectivelyActive;

    decimal activePct = Model.ActiveSlotsCount > 0 ? Math.Round((Model.ActiveSlotsCount / 1008m) * 100, 1) : 0;

    int headerStepIdx = Model.NextGlobalExecutionStepIdx ?? 1;
    decimal headerStepVal =
        headerStepIdx == 2 ? Model.PriceStepB :
        headerStepIdx == 3 ? Model.PriceStepC :
        Model.PriceStep;
    bool headerStepPct =
        headerStepIdx == 2 ? Model.IsPriceStepPercentB :
        headerStepIdx == 3 ? Model.IsPriceStepPercentC :
        Model.IsPriceStepPercent;
    string headerStepLetter = headerStepIdx == 2 ? "B" : headerStepIdx == 3 ? "C" : "A";
    string headerStepLetterBg = headerStepIdx == 2 ? "#3498db" : headerStepIdx == 3 ? "#9b59b6" : "#e67e22";

    string stepSign = headerStepVal < 0 ? "" : "+";
    string stepText = $"{stepSign}{headerStepVal:F2}{(headerStepPct ? "%" : " PLN")}";
    string stepColor = headerStepVal < 0 ? "#27ae60" : "#e74a3b";
    string stepIcon = headerStepVal < 0 ? "fa-arrow-down" : "fa-arrow-up";


    string nextExecIso = Model.NextGlobalExecution?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
@Html.AntiForgeryToken()


    <div class="Vert">
        <div class="Date" style="display:flex; justify-content:space-between; align-items:center; width:100%;">
            <div style="display:flex; align-items:center;">
                <div class="Order-Container-Title" style="font-size:23px;">
                    Interwał <strong>@Model.IntervalName</strong>
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:10px;">
                <div class="header-info-box">
                    <div style="font-weight:600; font-size:14px; color:#e67e22; display:flex; align-items:center; gap:6px;">
                        <i class="fas fa-clock"></i> Interwał
                    </div>
                    <span style="color:#bbb; font-weight:300; font-size:16px;">|</span>
                    <div class="status-indicator-text" style="color:@(effectivelyActive ? "#1cc88a" : "#e74a3b");">
                        <i class="fa-solid fa-circle" style="font-size:6px;"></i>
                        @if (effectivelyActive)
                        { <text>Aktywny</text> }
                        else if (Model.IsActive && !Model.ParentIsActive)
                        { <text>Zablokowany (rodzic)</text> }
                        else
                        { <text>Wyłączony</text> }
                    </div>
                    <span style="color:#bbb; font-weight:300; font-size:16px;">|</span>
                    <div style="font-weight:600; font-size:12px; color:@stepColor; display:flex; align-items:center; gap:6px;">
                        <span class="step-letter-badge sm" style="background:@headerStepLetterBg;">@headerStepLetter</span>
                        <i class="fas @stepIcon" style="font-size:10px;"></i> @stepText
                    </div>
                </div>
                @if (canEdit)
                {
                    <a asp-controller="IntervalPrice" asp-action="Edit" asp-route-id="@Model.IntervalRuleId"
                       class="btn-icon-settings" title="Konfiguruj"><i class="fas fa-cog"></i></a>
                }
            </div>
        </div>
    </div>

 
    <div class="Vert">
        <a href="@Url.Action("Details", "PriceAutomation", new { id = Model.ParentRuleId })" class="parent-info-box">
            <div class="parent-color-dot" style="background-color:@Model.ParentColorHex;"></div>
            <div style="flex-grow:1;">
                <div style="font-size:15px; font-weight:700; color:#333;">@Model.ParentRuleName</div>
                <div style="font-size:12px; color:#858796; margin-top:2px;">
                    Automat-rodzic · @Model.StoreName ·
                    @(Model.StrategyMode == AutomationStrategyMode.Competitiveness ? "Lider Rynku" : "Rentowność")
                </div>
            </div>
            <span class="parent-badge @(Model.ParentIsActive ? "parent-badge-active" : "parent-badge-inactive")">
                @(Model.ParentIsActive ? "Aktywny" : "Wyłączony")
            </span>
            <i class="fas fa-chevron-right" style="color:#d1d3e2;"></i>
        </a>
    </div>
   

    <div class="Vert">
        <div class="kpi-container">
           <div class="kpi-card">
                <div class="kpi-title">Produkty <i class="fas fa-cube text-gray-400"></i></div>
                <div class="kpi-value-big">@Model.TotalProducts<span style="font-size:14px; color:#858796; font-weight:400;"> / @Model.ParentProductCount</span></div>
                <div class="kpi-subtext">w interwale / w automacie-rodzicu</div>

                @{
                    int limit = Model.StoreIntervalLimit;
                    int used = Model.StoreIntervalUsed;
                    double pct = limit > 0 ? Math.Round((double)used / limit * 100, 1) : 0;
                    string pctCss = Math.Min(pct, 100).ToString(System.Globalization.CultureInfo.InvariantCulture);
                    string barColor = pct >= 90 ? "#e74a3b" : pct >= 70 ? "#f6c23e" : "#27ae60";
                    string sourceLabel = isMarketplace ? "Allegro" : "porównywarki";
                }

                <div style="margin-top:10px; padding-top:10px; border-top:1px solid #eaecf4;">
                    <div style="display:flex; justify-content:space-between; align-items:center; font-size:11px; font-weight:600; color:#858796; text-transform:uppercase; letter-spacing:0.3px; margin-bottom:4px;">
                        <span>Limit produktów w interwale (@sourceLabel)</span>
                        <span style="color:@barColor;">@used / @(limit > 0 ? limit.ToString() : "—")</span>
                    </div>
                    @if (limit > 0)
                    {
                        <div class="mini-progress-bg">
                            <div class="mini-progress-fill" style="width:@(pctCss)%; background:@barColor;"></div>
                        </div>
                        @if (used >= limit)
                        {
                            <div style="font-size:10px; color:#e74a3b; font-weight:600; margin-top:4px;">
                                <i class="fas fa-exclamation-triangle"></i> Limit osiągnięty — nie można dodać więcej produktów
                            </div>
                        }
                    }
                    else
                    {
                        <div style="font-size:10px; color:#e74a3b; font-weight:600;">
                            <i class="fas fa-ban"></i> Sklep ma limit 0 — skontaktuj się z biuro@pricesafari.pl
                        </div>
                    }
                </div>
                <div class="kpi-subtext" style="display:flex; align-items:center; gap:6px; margin-top:6px;">
                    <i class="fas fa-clock" style="font-size:12px; width:12px; text-align:center;"></i>
                    <span>Scrap: @(Model.LastScrapDate.HasValue? Model.LastScrapDate.Value.ToString("dd.MM HH:mm") : "-")</span>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-title">Status Produktów</div>
                <div class="d-flex align-items-end gap-2">
                    <div class="kpi-value-big" style="color:#00917B;">@Model.CountReady</div>
                    <div class="kpi-subtext mb-1">gotowych do wykonania</div>
                </div>
                <div class="kpi-subtext mt-2" style="display:flex; gap:12px;">
                    <span><i class="fas fa-ban mr-1 text-danger"></i> @Model.CountBlocked blokad</span>
                    <span><i class="fas fa-exclamation-triangle mr-1" style="color:#f6c23e;"></i> @Model.CountLimitReached na limicie</span>
                    <span><i class="fas fa-pause mr-1" style="color:#858796;"></i> @Model.CountPaused pauza</span>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-title">Harmonogram <span style="color:#27ae60;">@activePct%</span></div>
                <div class="kpi-value-big">@Model.ActiveSlotsCount</div>
                <div class="kpi-subtext">aktywnych slotów (z 1008)</div>
                <div class="mini-progress-bg"><div class="mini-progress-fill" style="width:@activePct%; background:#27ae60;"></div></div>
            </div>
            <div class="kpi-card">
                <div class="kpi-title">
                    Następne Wykonanie
                    @if (Model.NextGlobalExecutionStepIdx.HasValue)
                    {
                        <span class="step-letter-badge sm step-letter-@(headerStepLetter.ToLower())">@headerStepLetter</span>
                    }
                </div>
                <div class="kpi-value-big" id="kpiNextExecLabel"
                     data-countdown="@nextExecIso"
                     style="color:@(effectivelyActive ? "#27ae60" : "#858796");">—</div>
                <div class="kpi-subtext">
                    @if (Model.NextGlobalExecution.HasValue)
                    {
                        <span>@Model.NextGlobalExecution.Value.ToString("dd.MM.yyyy HH:mm")</span>
                    }
                    else
                    {
                        <span>Brak aktywnych slotów</span>
                    }
                </div>
            </div>
        </div>
    </div>

  
    <div class="Vert">
        <div class="ipc-box">
            <div style="font-size:16px; font-weight:600; color:#2e3035; display:flex; align-items:center; gap:8px; margin-bottom:16px;">
                Ustawienia dziedziczone z automatu
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:8px;">
                <div class="inherited-item">
                    <span class="inherited-label">Min narzut</span>
                    <span class="inherited-value">
                        @if (Model.EnforceMinimalMarkup)
                        { @Model.MinimalMarkupValue.ToString("F2") @(Model.IsMinimalMarkupPercent ? "%" : "PLN") }
                        else
                        { <span style="color:#b7b9cc;">Wyłączony</span> }
                    </span>
                </div>
                <div class="inherited-item">
                    <span class="inherited-label">Max narzut</span>
                    <span class="inherited-value">
                        @if (Model.EnforceMaxMarkup)
                        { @Model.MaxMarkupValue.ToString("F2") @(Model.IsMaxMarkupPercent ? "%" : "PLN") }
                        else
                        { <span style="color:#b7b9cc;">Wyłączony</span> }
                    </span>
                </div>
             @if (isMarketplace)
                {
                    <div class="inherited-item">
                        <span class="inherited-label">Prowizja</span>
                        <span class="inherited-value">@(Model.MarketplaceIncludeCommission ? "Uwzględniana" : "Nieuwzg.")</span>
                    </div>
                    <div class="inherited-item">
                        <span class="inherited-label">Kampanie</span>
                        <span class="inherited-value" style="color:@(Model.MarketplaceChangePriceForBadgeInCampaign ? "#1cc88a" : "#e74a3b");">
                            @if (Model.MarketplaceChangePriceForBadgeInCampaign)
                            {
                                <i class="fas fa-check-circle" style="margin-right:4px;"></i> <text>Pozwala na zmiany</text>
                            }
                            else
                            {
                                <i class="fas fa-ban" style="margin-right:4px;"></i> <text>Blokuje zmiany</text>
                            }
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>


    <div class="Vert">
        <div class="ipc-box">
            <div class="schedule-collapse-toggle" onclick="toggleSchedule()">
                <div style="display:flex; align-items:center; gap:12px;">
                    <div style="font-size:16px; font-weight:600; color:#2e3035;">Mapa Harmonogramu i Kroki Cenowe</div>
                    <span style="font-size:12px; color:#b7b9cc; font-weight:500;" id="scheduleToggleHint">(kliknij aby rozwinąć)</span>
                </div>
                <i class="fas fa-chevron-down toggle-chevron" id="scheduleChevron"></i>
            </div>
            <div class="schedule-collapsible" id="scheduleCollapsible">
                <div style="margin-top:18px;">

                 
                    <div class="step-cards-grid">
                        @{
                            var stepsData = new[] {
                                new { Letter = "A", Cls = "step-a", Val = Model.PriceStep,  Pct = Model.IsPriceStepPercent,  Active = Model.IsStepAActive },
                                new { Letter = "B", Cls = "step-b", Val = Model.PriceStepB, Pct = Model.IsPriceStepPercentB, Active = Model.IsStepBActive },
                                new { Letter = "C", Cls = "step-c", Val = Model.PriceStepC, Pct = Model.IsPriceStepPercentC, Active = Model.IsStepCActive }
                            };
                        }
                        @foreach (var s in stepsData)
                        {
                            bool isDown = s.Val < 0;
                            string sign = isDown ? "" : "+";
                            string unit = s.Pct ? "%" : " PLN";
                            string valClass = isDown ? "down" : "up";
                            string iconCls = isDown ? "fa-arrow-down" : "fa-arrow-up";
                            <div class="step-card-ro @s.Cls @(s.Active ? "" : "inactive")">
                                <div class="step-card-ro-header">
                                    <div class="step-card-ro-title">
                                        <div class="step-card-ro-letter">@s.Letter</div>
                                        <div class="step-card-ro-name">Krok @s.Letter</div>
                                    </div>
                                    <div class="step-card-ro-status @(s.Active ? "on" : "off")">
                                        @(s.Active ? "Aktywny" : "Wyłączony")
                                    </div>
                                </div>
                                <div class="step-card-ro-value @valClass">
                                    <i class="fas @iconCls"></i>
                                    <span>@sign@s.Val.ToString("F2")@unit</span>
                                </div>
                            </div>
                        }
                    </div>

                    <div style="font-size:11px; color:#b7b9cc; margin-bottom:8px;">
                        <i class="fas fa-info-circle"></i> Wyszarzone bloki należą do kroków wyłączonych i nie zostaną wykonane.
                    </div>

              
                    <div style="overflow-x:auto;">
                        <table class="sg-table" id="sgTable">
                            <thead><tr><th class="th-time"></th><th>Pn</th><th>Wt</th><th>Śr</th><th>Cz</th><th>Pt</th><th>Sb</th><th>Nd</th></tr></thead>
                            <tbody id="sgBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

  
    <div class="Vert">
        <div class="Date" style="display:flex; justify-content:space-between; align-items:center; width:100%;">
            <div style="display:flex; align-items:center; gap:6px;">
                <input type="text" id="productSearch" style="max-width:150px; height:33.99px;" placeholder="Wyszukaj produkt">
            </div>
            <div>
                <div id="selectionContainer" class="selection-container">
                    <span id="selectedProductsCounter" class="ProductCount" style="width:126px; height:33.99px;">Wybrano: 0</span>
                    <button id="selectAllVisibleBtn" class="Button-Page-Small" style="width:48px;" title="Zaznacz wszystkie widoczne"><i class="fa-solid fa-square-check"></i></button>
                    <button id="deselectAllVisibleBtn" class="Button-Page-Small" style="width:48px;" title="Odznacz wszystkie widoczne"><i class="fa-solid fa-square-xmark"></i></button>
                    <button id="showSelectedProductsBtn" class="Button-Page-Small" style="width:89.25px;">Akcje</button>
                </div>
            </div>
        </div>
    </div>


    <div class="Vert">
        <div class="filter-toolbar-wrapper">
            <div class="filter-toolbar" id="filterToolbar"></div>
            <div class="filter-summary" id="filterSummary">
                <span class="filter-summary-text">Wyświetlane: <strong id="visibleCount">0</strong> z <strong id="totalCount">0</strong></span>
                <button class="filter-reset-btn" id="resetFiltersBtn" style="display:none;">
                    <i class="fas fa-times"></i> Resetuj filtry
                </button>
            </div>
        </div>

    <div class="Automation-Table-Box">
        <div class="Vert-table" style="flex: 1; height: 100%; min-height: 0; margin-top:0px;">
                <table class="table-orders" id="intervalTable" width="100%">
                    <thead>
                        <tr>
                            <th style="min-width:240px;">Produkt</th>
                            <th style="max-width:170px; min-width:165px;">Limity Cenowe</th>
                            @if (isMarketplace)
                            {
                                <th style="min-width: 145px; width: 150px;">Sprzedaż</th>
                            }
                            <th style="min-width:235px;">Dane z rynku - Twoja oferta</th>
                            <th style="min-width:200px;">Najlepszy Rywal</th>
                            <th style="min-width:190px;">Ostatnia Znana Cena</th>
                            <th style="min-width:240px;" class="bg-gradient-light border-left-primary">Następny Krok</th>
                            <th style="min-width:110px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Products)
                        {
                            string marginBadgeClass = "price-badge-positive";
                            string marginBoxClass = "price-box-diff-margin-ib-positive";
                            if (item.CurrentMarkupAmount.HasValue && item.CurrentMarkupAmount.Value < 0)
                            {
                                marginBadgeClass = "price-badge-negative";
                                marginBoxClass = "price-box-diff-margin-ib-negative";
                            }

                            string projMarginBadge = "price-badge-positive";
                            string projMarginBox = "price-box-diff-margin-ib-positive";
                            if (item.ProjectedMarkupAmount.HasValue && item.ProjectedMarkupAmount.Value < 0)
                            {
                                projMarginBadge = "price-badge-negative";
                                projMarginBox = "price-box-diff-margin-ib-negative";
                            }
                            else if (item.IsMarginWarning)
                            {
                                projMarginBadge = "price-badge-warning";
                                projMarginBox = "price-box-diff-margin-ib-warning";
                            }

                            string nextStepLetter = item.NextStepIdx == 2 ? "B" : item.NextStepIdx == 3 ? "C" : item.NextStepIdx == 1 ? "A" : null;
                            string nextStepLetterCls = item.NextStepIdx == 2 ? "step-letter-b" : item.NextStepIdx == 3 ? "step-letter-c" : "step-letter-a";

                            string lkStepLetter = item.LastKnownStepIdx == 2 ? "B" : item.LastKnownStepIdx == 3 ? "C" : item.LastKnownStepIdx == 1 ? "A" : null;
                            string lkStepLetterCls = item.LastKnownStepIdx == 2 ? "step-letter-b" : item.LastKnownStepIdx == 3 ? "step-letter-c" : "step-letter-a";

                            string rowNextExecIso = item.NextExecutionTime?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "";

                        
                            string pausedUntilIso = item.PausedUntil.HasValue ? item.PausedUntil.Value.ToUniversalTime().ToString("o") : "";
                            string rowPausedClass = item.IsPaused ? "row-paused" : "";
                         
                         <tr id="prod-row-@item.ProductId" class="main-product-row @rowPausedClass"
                            data-status="@item.Status.ToString()"
                            data-has-purchase-price="@item.PurchasePrice.HasValue.ToString().ToLower()"
                            data-has-min-limit="@item.MinPriceLimit.HasValue.ToString().ToLower()"
                            data-has-max-limit="@item.MaxPriceLimit.HasValue.ToString().ToLower()"
                            data-limited-by-min="@item.IsLimitedByMin.ToString().ToLower()"
                            data-limited-by-max="@item.IsLimitedByMax.ToString().ToLower()"
                            data-has-margin-warning="@item.IsMarginWarning.ToString().ToLower()"
                            data-is-subsidy="@item.IsSubsidyActive.ToString().ToLower()"
                            data-is-campaign="@item.IsInAnyCampaign.ToString().ToLower()"
                            data-flag-ids="@(item.FlagIds != null ? string.Join(",", item.FlagIds) : "")"
                            data-pop-total="@(item.TotalPopularity ?? 0)"
                            data-pop-mine="@(item.MyTotalPopularity ?? 0)"
                            data-pop-share="@((item.MarketSharePercentage ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                            data-is-paused="@item.IsPaused.ToString().ToLower()">

                              
                                <td class="align-middle">
                                    <div style="display:flex; gap:10px; align-items:flex-start;">
                                        @if (!isMarketplace && !string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <div style="flex-shrink:0; width:40px; text-align:center; margin-top:2px;">
                                                <img src="@item.ImageUrl" alt="img" style="max-height:40px; max-width:40px; object-fit:contain; border-radius:4px;" />
                                            </div>
                                        }
                                        <div style="flex-grow:1; min-width:0;">
                                            <div class="font-weight-bold product-name-wrap" title="@item.Name">
                                                @{
                                                    string linkUrl = isMarketplace
                                                    ? $"/AllegroPriceHistory/Details?storeId={Model.StoreId}&productId={item.ProductId}"
                                                    : (Model.LatestScrapId.HasValue ? $"/PriceHistory/Details?scrapId={Model.LatestScrapId}&productId={item.ProductId}" : null);
                                                }
                                              @if (!string.IsNullOrEmpty(linkUrl))
                                                {
                                                    <a href="@linkUrl" target="_blank" rel="noopener noreferrer" class="simulationProductTitle">
                                                        @item.Name
                                                    </a>
                                                }
                                                else
                                                {
                                                    @item.Name
                                                }
                                            </div>
                                            @if (item.FlagIds != null && item.FlagIds.Any())
                                            {
                                                <div class="flags-container d-flex flex-wrap mt-1" style="gap:4px; justify-content: flex-start;">
                                                    @foreach (var flagId in item.FlagIds)
                                                    {
                                                        var flag = Model.AvailableStoreFlags?.FirstOrDefault(f => f.FlagId == flagId);
                                                        if (flag != null)
                                                        {
                                                            <span class="flag-badge" style="color:@flag.FlagColor; border-color:@flag.FlagColor; background-color:@(flag.FlagColor)4D;">@flag.FlagName</span>
                                                        }
                                                    }
                                                </div>
                                            }
                                        <div class="d-flex align-items-center mt-2" style="gap:6px; flex-wrap:wrap;">
                                            <button class="select-product-btn" data-product-id="@item.ProductId" data-product-name="@item.Name" data-identifier="@item.Identifier" style="font-size:11px; padding:2px 8px;">Zaznacz</button>
                                            @if (canEdit)
                                            {
                                                <button type="button"
                                                        class="pause-product-btn @(item.IsPaused ? "is-paused" : "")"
                                                        data-product-id="@item.ProductId"
                                                        data-product-name="@item.Name"
                                                        data-paused-until="@pausedUntilIso"
                                                        title="@(item.IsPaused ? "Zarządzaj wstrzymaniem automatu" : "Wstrzymaj automat dla tego produktu")">
                                                    @if (item.IsPaused)
                                                    {
                                                        <i class="fas fa-pause"></i>
                                                        <span class="pause-countdown-text">--</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-play"></i>
                                                    }
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="pause-product-btn" style="opacity:0.5; cursor:not-allowed;" onclick="showNoAccessAlert(); return false;" title="Brak uprawnień">
                                                    <i class="fas fa-play"></i>
                                                </button>
                                            }
                                            <div class="small text-muted" style="line-height:1;">ID: @item.Identifier</div>
                                        </div>
                                        </div>
                                    </div>
                                </td>

                                <td class="align-middle">
                                    <div class="purchase-wrapper" data-id="@item.ProductId" data-store-id="@Model.StoreId" data-is-marketplace="@isMarketplace.ToString().ToLower()">
                                        <div class="display-mode">
                                            @if (item.PurchasePrice.HasValue)
                                            {
                                                <div class="bg-light p-2 rounded border purchase-row">
                                                    @if (item.MaxPriceLimit.HasValue)
                                                    {
                                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                                            <span class="limit-badge badge-max">MAX <i class="fa-solid fa-arrow-up"></i></span>
                                                            <span class="limit-price-text" style="color:rgba(0,145,123,1);">@item.MaxPriceLimit.Value.ToString("F2") PLN</span>
                                                        </div>
                                                    }
                                                    @if (item.MinPriceLimit.HasValue)
                                                    {
                                                        <div class="d-flex justify-content-between align-items-center @(item.MaxPriceLimit.HasValue ? "border-top pt-1 mt-1" : "mb-1")">
                                                            <span class="limit-badge badge-min">MIN <i class="fa-solid fa-arrow-down"></i></span>
                                                            <span class="limit-price-text" style="color:rgba(171,37,32,1);">@item.MinPriceLimit.Value.ToString("F2") PLN</span>
                                                        </div>
                                                    }
                                                    <div class="d-flex justify-content-between align-items-center @(item.MinPriceLimit.HasValue || item.MaxPriceLimit.HasValue ? "border-top pt-1 mt-1" : "")">
                                                        <span class="limit-badge badge-purchase">Zakup</span>
                                                        <div class="d-flex align-items-center">
                                                            <span class="price-actions-display">
                                                                @if (item.PurchasePriceUpdatedDate.HasValue)
                                                                {
                                                                    <i class="fas fa-clock mr-1" style="font-size:10px; color:#858796; cursor:help; margin-right:4px;" title="Zaktualizowano: @item.PurchasePriceUpdatedDate.Value.ToString("dd.MM.yyyy HH:mm")"></i>
                                                                }
                                                                @if (canEdit)
                                                                {
                                                                    <i class="fas fa-pencil-alt edit-btn edit-trigger" title="Edytuj cenę zakupu"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="fas fa-lock edit-disabled" title="Brak uprawnień" onclick="showNoAccessAlert()"></i>
                                                                }
                                                            </span>
                                                            <span class="limit-price-text val-display" style="color:#282828;">@item.PurchasePrice.Value.ToString("F2") PLN</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-center text-gray-400 small purchase-row py-2 border rounded bg-light">
                                                    @if (canEdit)
                                                    {
                                                        <i class="fas fa-plus-circle text-gray-500 edit-btn edit-trigger" style="font-size:12px;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-plus-circle text-gray-300" style="font-size:12px; cursor:not-allowed;" onclick="showNoAccessAlert()"></i>
                                                    }
                                                    Brak ceny zakupu
                                                </div>
                                            }
                                        </div>
                                        <div class="edit-mode d-none bg-white p-2 rounded border shadow-sm" style="position:absolute; z-index:10; width:100%; top:50%; left:0; transform:translateY(-50%);">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <input type="number" step="0.01" class="price-edit-input" value="@(item.PurchasePrice?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "")" placeholder="0.00">
                                                <div class="d-flex ml-1">
                                                    <button class="btn-action-icon save-btn" type="button" title="Zapisz"><i class="fas fa-check"></i></button>
                                                    <button class="btn-action-icon cancel-btn" type="button" title="Anuluj"><i class="fas fa-times"></i></button>
                                                    @if (item.PurchasePrice.HasValue)
                                                    {
                                                        <button class="btn-action-icon delete-btn-inner ml-1 border-left pl-2" type="button" title="Usuń"><i class="fas fa-trash-alt"></i></button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                @if (isMarketplace)
                                {
                                    <td class="align-middle">
                                        @if (item.TotalPopularity.HasValue && item.TotalPopularity.Value > 0)
                                        {
                                            <div class="bg-light p-2 rounded border sales-info-wrapper">
                                                <div class="d-flex justify-content-between align-items-center mb-1"
                                                     title="Łączna sprzedaż w katalogu (30 dni)">
                                                    <span class="sales-badge badge-sales-market">
                                                        <i class="fas fa-shopping-cart" style="font-size: 9px;"></i> Rynek
                                                    </span>
                                                    <span class="sales-value-text" style="color: #545b62;">
                                                        @item.TotalPopularity szt.
                                                    </span>
                                                </div>

                                                <div class="d-flex justify-content-between align-items-center border-top pt-1 mt-1"
                                                     title="Twoja sprzedaż w katalogu (30 dni)">
                                                    <span class="sales-badge badge-sales-mine">
                                                        <i class="fas fa-store" style="font-size: 9px;"></i> Moje
                                                    </span>
                                                    <span class="sales-value-text" style="color: #d38a36;">
                                                        @(item.MyTotalPopularity ?? 0) szt.
                                                    </span>
                                                </div>

                                                <div class="d-flex justify-content-between align-items-center border-top pt-1 mt-1"
                                                     title="Twój udział w rynku">
                                                    <span class="sales-badge badge-sales-share">
                                                        <i class="fas fa-chart-pie" style="font-size: 9px;"></i> Udział
                                                    </span>
                                                    <span class="sales-value-text" style="color: #5da189; font-weight: 700;">
                                                        @((item.MarketSharePercentage ?? 0).ToString("F2"))%
                                                    </span>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="sales-empty-box">Brak danych</span>
                                        }
                                    </td>
                                }
                           
                                <td class="align-middle text-right">
                                    <div class="price-row-block">
                                        <span class="price-main-style @(item.IsBestPriceGuarantee ? "price-green" : "")">
                                            @(item.MarketCurrentPrice.HasValue ? item.MarketCurrentPrice.Value.ToString("F2") : "-") PLN
                                        </span>
                                        @if (item.HasCheaperOwnOffer)
                                        { <span class="text-danger" title="Tańsza własna oferta!"><i class="fas fa-exclamation-triangle"></i></span> }
                                        @if (item.IsBestPriceGuarantee)
                                        { <img src="/images/TopPrice.png" alt="Gwarancja" style="width:18px; height:18px;" title="Gwarancja Najniższej Ceny"> }
                                        @if (item.IsSuperPrice)
                                        { <div class="SuperPrice">SUPERCENA</div> }
                                        @if (item.IsTopOffer)
                                        { <div class="TopOffer">Top</div> }
                                    </div>

                              
                                    <div class="d-flex align-items-center mt-1" style="gap:8px;">
                                        <div class="small text-muted">@Model.StoreName</div>

                                        <div class="d-flex align-items-center" style="gap: 6px; font-size: 11px;">
                                            @if (isMarketplace && !string.IsNullOrEmpty(item.CurrentRankingAllegro) && item.CurrentRankingAllegro != "-")
                                            {
                                                <div class="rank-row"><img src="/images/AllegroIcon.png" alt="Allegro" class="rank-icon"><span class="text-muted">@item.CurrentRankingAllegro</span></div>
                                            }
                                            @if (!isMarketplace)
                                            {
                                                bool hasGoogle = !string.IsNullOrEmpty(item.CurrentRankingGoogle) && item.CurrentRankingGoogle != "-";
                                                bool hasCeneo = !string.IsNullOrEmpty(item.CurrentRankingCeneo) && item.CurrentRankingCeneo != "-";

                                                if (hasGoogle)
                                                {
                                                    <div class="rank-row"><img src="/images/GoogleShopping.png" alt="Google" class="rank-icon"><span class="text-muted">@item.CurrentRankingGoogle</span></div>
                                                }

                                         
                                                if (hasGoogle && hasCeneo)
                                                {
                                                    <span style="color: #d1d3e2;">|</span>
                                                }

                                                if (hasCeneo)
                                                {
                                                    <div class="rank-row"><img src="/images/Ceneo.png" alt="Ceneo" class="rank-icon"><span class="text-muted">@item.CurrentRankingCeneo</span></div>
                                                }
                                            }
                                        </div>
                                    </div>
                               

                                    @if (item.CommissionAmount.HasValue)
                                    {
                                        <div class="Commission-stack mt-1">
                                            <span class="commission-stack-badge">Prowizja</span>
                                            <p>@item.CommissionAmount.Value.ToString("F2") PLN @(item.IsCommissionIncluded ? "| uwzg." : "| nieuwzg.")</p>
                                        </div>
                                    }
                                    @if (item.CurrentMarkupAmount.HasValue && item.CurrentMarkupPercent.HasValue)
                                    {
                                        <div class="price-box-diff-margin-ib @marginBoxClass" style="margin-top:4px; width:100%;">
                                            <span class="price-badge @marginBadgeClass">Narzut</span>
                                            <p>@item.CurrentMarkupAmount.Value.ToString("F2") PLN (@item.CurrentMarkupPercent.Value.ToString("F2")%)</p>
                                        </div>
                                    }

                                    @* ═══ NOWY BLOK: Dopłaty / Kampania — identyczny jak w głównym automacie ═══ *@
                                    @if (item.ApiAllegroPriceFromUser.HasValue)
                                    {
                                        if (item.IsSubsidyActive)
                                        {
                                            <div class="subsidy-stack" style="margin-top: 4px;">
                                                <span class="subsidy-stack-badge">Dopłaty | Twoja cena</span>
                                                <p>@item.ApiAllegroPriceFromUser.Value.ToString("F2") PLN</p>
                                            </div>
                                        }
                                        else if (item.IsInAnyCampaign)
                                        {
                                            <div class="Campaign-stack" style="margin-top: 4px;">
                                                <span class="campaign-stack-badge">Kampania | Twoja cena</span>
                                                <p>@item.ApiAllegroPriceFromUser.Value.ToString("F2") PLN</p>
                                            </div>
                                        }
                                    }
                                </td>

                           
                                <td class="align-middle text-right">
                                    @if (item.BestCompetitorPrice.HasValue)
                                    {
                                        <div class="price-row-block">
                                            <span class="price-main-style @(item.CompetitorIsBestPriceGuarantee ? "price-green" : "")">@item.BestCompetitorPrice.Value.ToString("F2") PLN</span>
                                            @if (item.CompetitorIsBestPriceGuarantee)
                                            { <img src="/images/TopPrice.png" alt="Gwarancja" style="width:18px; height:18px;"> }
                                            @if (item.CompetitorIsSuperPrice)
                                            { <div class="SuperPrice">SUPERCENA</div> }
                                            @if (item.CompetitorIsTopOffer)
                                            { <div class="TopOffer">Top</div> }
                                        </div>
                                        <div class="small text-muted">@item.CompetitorName</div>
                                    }
                                    else
                                    {
                                        <span class="small text-muted">Brak konkurencji</span>
                                    }
                                </td>

                              
                                <td class="align-middle text-center">
                                    @if (item.LastKnownPrice.HasValue)
                                    {
                                        <div class="price-main-style" style="color:@(item.LastKnownSource == LastKnownPriceSource.Interval ? "#e67e22" : item.LastKnownSource == LastKnownPriceSource.Automation ? "#1cc88a" : "#858796");">
                                            @item.LastKnownPrice.Value.ToString("F2") PLN
                                        </div>
                                        @if (item.LastKnownPriceDate.HasValue)
                                        {
                                            <div class="small text-muted">@item.LastKnownPriceDate.Value.ToString("dd.MM HH:mm")</div>
                                        }
                                        <div style="margin-top:4px; display:flex; flex-direction:column; align-items:center; gap:3px;">
                                            @switch (item.LastKnownSource)
                                            {
                                                case LastKnownPriceSource.Interval:
                                                    <span style="font-size:10px; padding:2px 6px; border-radius:3px; background:rgba(230,126,34,0.12); color:#e67e22; font-weight:600; display:inline-flex; align-items:center; gap:4px;">
                                                        <i class="fas fa-clock"></i> Z interwału
                                                        @if (lkStepLetter != null)
                                                        {
                                                            <span class="step-letter-badge sm @lkStepLetterCls" style="margin-left:2px;">@lkStepLetter</span>
                                                        }
                                                    </span>
                                                    break;
                                                case LastKnownPriceSource.Automation:
                                                    <span style="font-size:10px; padding:2px 6px; border-radius:3px; background:rgba(28,200,138,0.12); color:#1cc88a; font-weight:600;">
                                                        <i class="fas fa-robot" style="margin-right:2px;"></i> Z automatu
                                                    </span>
                                                    break;
                                                case LastKnownPriceSource.Market:
                                                    <span style="font-size:10px; padding:2px 6px; border-radius:3px; background:rgba(133,135,150,0.12); color:#858796; font-weight:600;">
                                                        <i class="fas fa-globe" style="margin-right:2px;"></i> Z rynku
                                                    </span>
                                                    break;
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="color:#d1d3e2; font-size:13px;">
                                            <i class="fas fa-question-circle" style="margin-right:4px;"></i> Brak danych
                                        </div>
                                    }
                                </td>

                                <td class="align-middle text-right bg-light border-left-primary">
                                    @if (item.Status == IntervalProductStatus.Blocked)
                                    {
                                        <div class="price-main-style" style="color:#6C757D;">—</div>
                                        <div class="small text-muted">Blokada</div>
                                    }
                                    else
                                    {
                                        <div class="price-row-space">
                                            <div style="display:flex; align-items:center; gap:6px;">
                                                @if (nextStepLetter != null)
                                                {
                                                    <span class="step-letter-badge @nextStepLetterCls" title="Krok @nextStepLetter">@nextStepLetter</span>
                                                }
                                                <span class="price-main-style @(item.IsMarginWarning ? "text-warning" : "text-success")">
                                                    @(item.ProjectedNextPrice?.ToString("F2") ?? "-") PLN
                                                </span>
                                            </div>
                                            @if (item.ProjectedPriceChange.HasValue && item.ProjectedPriceChange.Value != 0)
                                            {
                                                bool isDown = item.ProjectedPriceChange.Value < 0;
                                                <span class="next-step-badge @(isDown ? "next-step-down" : "next-step-up")">
                                                    <i class="fas @(isDown ? "fa-arrow-down" : "fa-arrow-up")" style="font-size:9px;"></i>
                                                    @Math.Abs(item.ProjectedPriceChange.Value).ToString("F2") PLN
                                                </span>
                                            }
                                        </div>

                                        @if (item.IsLimitedByMin)
                                        {
                                            <div style="font-size:10px; color:#f6c23e; font-weight:600; margin-top:2px;"><i class="fas fa-filter"></i> Ogr. Min</div>
                                        }
                                        @if (item.IsLimitedByMax)
                                        {
                                            <div style="font-size:10px; color:#4d6b3a; font-weight:600; margin-top:2px;"><i class="fas fa-filter"></i> Ogr. Max</div>
                                        }

                                        @if (item.ProjectedMarkupAmount.HasValue && item.ProjectedMarkupPercent.HasValue)
                                        {
                                            <div class="price-box-diff-margin-ib @projMarginBox" style="margin-top:4px; width:100%;">
                                                <span class="price-badge @projMarginBadge">Narzut</span>
                                                <p>@item.ProjectedMarkupAmount.Value.ToString("F2") PLN (@item.ProjectedMarkupPercent.Value.ToString("F2")%)</p>
                                            </div>
                                        }

                                        <div class="mt-2">
                                            @if (item.WillNextExecutionRun && item.NextExecutionTime.HasValue)
                                            {
                                                <div class="countdown-label countdown-active" data-countdown="@rowNextExecIso">
                                                    <i class="fas fa-clock"></i> —
                                                </div>
                                            }
                                            else if (item.Status == IntervalProductStatus.Paused)
                                            {
                                                <div class="countdown-label countdown-paused"><i class="fas fa-pause"></i> Pauza</div>
                                            }
                                            else if (item.Status == IntervalProductStatus.LimitReached)
                                            {
                                                <div class="countdown-label countdown-blocked"><i class="fas fa-flag-checkered"></i> Limit osiągnięty</div>
                                            }
                                        </div>
                                    }
                                </td>

                          
                                <td class="align-middle text-center">
                                    @switch (item.Status)
                                    {
                                        case IntervalProductStatus.Ready:
                                            <div class="status-badge status-ok"><i class="fas fa-check mr-1"></i> Gotowy</div>
                                            break;
                                        case IntervalProductStatus.Blocked:
                                            <div class="status-badge status-blocked"><i class="fas fa-ban mr-1"></i> @item.BlockReason</div>
                                            break;
                                        case IntervalProductStatus.LimitReached:
                                            if (item.BlockReason?.Contains("Min") == true)
                                            {
                                                <div class="status-badge status-limited"><i class="fas fa-flag mr-1"></i> @item.BlockReason</div>
                                            }
                                            else
                                            {
                                                <div class="status-badge status-limited-max"><i class="fas fa-flag mr-1"></i> @item.BlockReason</div>
                                            }
                                            break;
                                        case IntervalProductStatus.Paused:
                                            if (item.IsPaused)
                                            {
                                                <div class="status-badge status-paused-badge"><i class="fas fa-pause mr-1"></i> PAUZA</div>
                                            }
                                            else
                                            {
                                                <div class="status-badge status-paused"><i class="fas fa-pause mr-1"></i> @item.BlockReason</div>
                                            }
                                            break;
                                        }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


