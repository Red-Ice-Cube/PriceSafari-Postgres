@using PriceSafari.Models.ViewModels
@using Microsoft.AspNetCore.Identity
@using PriceSafari.Models

@model AutomationDetailsViewModel
@inject UserManager<PriceSafariUser> UserManager

@{
    ViewData["Title"] = $"Automat Cenowy {Model.RuleName}";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var user = await UserManager.GetUserAsync(User);
    bool canEdit = user?.AccesToEditPriceAutomation ?? false;
    string noAccessMessage = "Nie masz uprawnień aby zarządzać regułami automatyzacji cen. Skontaktuj sie z nami biuro@pricesafari.pl";
    bool isCompetitiveness = Model.StrategyMode == AutomationStrategyMode.Competitiveness;

    string strategyClass = isCompetitiveness ? "strategy-comp" : "strategy-prof";
    string strategyIconClass = isCompetitiveness ? "fa-bolt" : "fa-dollar-sign";
    string strategyLabel = isCompetitiveness ? "Lider Rynku" : "Rentowność";

    string statusClass = Model.IsActive ? "status-active-color" : "status-inactive-color";
    string statusLabel = Model.IsActive ? "Aktywny" : "Wyłączony";

    string borderClass = Model.SourceType == AutomationSourceType.PriceComparison ? "border-left-info" : "border-left-warning";

    bool isMarketplace = Model.SourceType == AutomationSourceType.Marketplace;
    int total = Model.TotalProducts > 0 ? Model.TotalProducts : 1;
    int successCount = Model.CountMet + Model.CountMaintained + Model.CountLimited;
    int blockedCount = Model.CountBlocked;
    int percentSuccess = Model.SuccessRate;
    bool isTimeLimited = Model.IsTimeLimited;
    DateTime? schedStart = Model.ScheduledStartDate;
    DateTime? schedEnd = Model.ScheduledEndDate;
    DateTime now = DateTime.Now;
    bool isDisabled = !Model.IsActive;

    string timeStatusLabel;
    string timeStatusClass;
    string timeStatusIcon;
    double timeProgressPercent = -1;
    string timeExtraLabel = "";
    string timeMarkerClass = "marker-hidden";
    double timeMarkerPos = 0;

    if (isDisabled && isTimeLimited)
    {
        timeStatusLabel = "Automat wyłączony";
        timeStatusClass = "time-status-disabled";
        timeStatusIcon = "fa-power-off";
    }
    else if (!isTimeLimited)
    {
        timeStatusLabel = "Bez ograniczenia";
        timeStatusClass = "time-status-unlimited";
        timeStatusIcon = "fa-infinity";
    }
    else if (schedStart.HasValue && schedEnd.HasValue)
    {
        bool beforeStart = now.Date < schedStart.Value.Date;
        bool afterEnd = now.Date > schedEnd.Value.Date;

        if (beforeStart)
        {
            timeStatusLabel = "Oczekuje";
            timeStatusClass = "time-status-waiting";
            timeStatusIcon = "fa-hourglass-start";
            timeProgressPercent = 0;
            timeMarkerClass = "marker-waiting";
            timeMarkerPos = 0;
            int daysToStart = (int)(schedStart.Value.Date - now.Date).TotalDays;
            timeExtraLabel = $"Start za {daysToStart} {DniLabel(daysToStart)}";

            statusClass = "status-waiting-color";
            statusLabel = "Oczekuje";
        }
        else if (afterEnd)
        {
            timeStatusLabel = "Zakończony";
            timeStatusClass = "time-status-expired";
            timeStatusIcon = "fa-hourglass-end";
            timeProgressPercent = 100;
            timeMarkerClass = "marker-expired";
            timeMarkerPos = 100;
            int daysAgo = (int)(now.Date - schedEnd.Value.Date).TotalDays;
            timeExtraLabel = $"Zakończono {daysAgo} {DniLabel(daysAgo)} temu";

            statusClass = "status-waiting-color";
            statusLabel = "Zatrzymany";
        }
        else
        {
            double totalSpan = (schedEnd.Value.Date - schedStart.Value.Date).TotalDays + 1;
            double elapsedFull = (now.Date - schedStart.Value.Date).TotalDays;
            timeProgressPercent = totalSpan > 0 ? Math.Round((elapsedFull / totalSpan) * 100, 1) : 0;
            timeProgressPercent = Math.Max(0, Math.Min(timeProgressPercent, 99.9));
            int daysLeft = (int)(schedEnd.Value.Date - now.Date).TotalDays + 1;

            timeStatusLabel = "Aktywny";
            timeStatusClass = "time-status-active";
            timeStatusIcon = "fa-hourglass-half";
            timeMarkerClass = "marker-active";
            timeMarkerPos = timeProgressPercent;
            timeExtraLabel = $"Pozostało {daysLeft} {DniLabel(daysLeft)}";
        }
    }
    else if (schedStart.HasValue && !schedEnd.HasValue)
    {
        bool beforeStart = now.Date < schedStart.Value.Date;
        if (beforeStart)
        {
            timeStatusLabel = "Oczekuje";
            timeStatusClass = "time-status-waiting";
            timeStatusIcon = "fa-hourglass-start";
            int daysToStart = (int)(schedStart.Value.Date - now.Date).TotalDays;
            timeExtraLabel = $"Start za {daysToStart} {DniLabel(daysToStart)}";
            timeMarkerClass = "marker-waiting";
            timeMarkerPos = 0;
            timeProgressPercent = 0;

            statusClass = "status-waiting-color";
            statusLabel = "Oczekuje";
        }
        else
        {
            timeStatusLabel = "Aktywny";
            timeStatusClass = "time-status-active";
            timeStatusIcon = "fa-play";
            timeExtraLabel = "Bez daty końcowej";
        }
    }
    else if (!schedStart.HasValue && schedEnd.HasValue)
    {
        bool afterEnd = now.Date > schedEnd.Value.Date;
        if (afterEnd)
        {
            timeStatusLabel = "Zakończony";
            timeStatusClass = "time-status-expired";
            timeStatusIcon = "fa-hourglass-end";
            int daysAgo = (int)(now.Date - schedEnd.Value.Date).TotalDays;
            timeExtraLabel = $"Zakończono {daysAgo} {DniLabel(daysAgo)} temu";
            timeMarkerClass = "marker-expired";
            timeMarkerPos = 100;
            timeProgressPercent = 100;

            statusClass = "status-waiting-color";
            statusLabel = "Zatrzymany";
        }
        else
        {
            timeStatusLabel = "Aktywny";
            timeStatusClass = "time-status-active";
            timeStatusIcon = "fa-play";
            int daysLeft = (int)(schedEnd.Value.Date - now.Date).TotalDays + 1;
            timeExtraLabel = $"Do {schedEnd.Value.ToString("dd.MM.yyyy")} ({daysLeft} {DniLabel(daysLeft)})";
        }
    }
    else
    {
        timeStatusLabel = "Brak dat";
        timeStatusClass = "time-status-waiting";
        timeStatusIcon = "fa-question-circle";
    }

    string DniLabel(int n)
    {
        if (n == 1) return "dzień";
        return "dni";
    }
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
@Html.AntiForgeryToken()


<div class="Vert">
    <div class="Date" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
        <div style="display: flex; align-items: center;">
            <div class="Order-Container-Title" style="font-size: 23px;">
                Automat Cenowy <strong>@Model.RuleName</strong>
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 10px;">
            <div class="header-info-box">
                <div class="strategy-text @strategyClass">
                    <i class="fa-solid @strategyIconClass"></i> @strategyLabel
                </div>
                <span class="header-separator">|</span>
                <div class="status-indicator-text @statusClass">
                    <i class="fa-solid fa-circle" style="font-size: 6px;"></i> @statusLabel
                </div>
            </div>
            <div class="time-schedule-box">
                <div class="time-status-label @timeStatusClass">
                    <i class="fa-solid @timeStatusIcon" style="font-size: 10px;"></i>
                    @timeStatusLabel
                </div>
                @if (!isTimeLimited)
                {
                    <span class="time-extra-label" style="color: #1cc88a;">Automat działa bez limitu czasu</span>
                }
                else if (isDisabled)
                {
                    <span class="time-extra-label">Włącz automat, aby harmonogram zaczął działać</span>
                }
                else
                {
                    @if (schedStart.HasValue || schedEnd.HasValue)
                    {
                        <span class="time-separator">|</span>
                        <div class="time-dates-inline">
                            @if (schedStart.HasValue)
                            {
                                <span class="time-date-badge">@schedStart.Value.ToString("dd.MM.yyyy")</span>
                            }
                            else
                            {
                                <span class="time-date-badge" style="color:#ccc;">—</span>
                            }
                            <i class="fa-solid fa-arrow-right" style="font-size: 7px; color: #ccc;"></i>
                            @if (schedEnd.HasValue)
                            {
                                <span class="time-date-badge">@schedEnd.Value.ToString("dd.MM.yyyy")</span>
                            }
                            else
                            {
                                <span class="time-date-badge" style="color:#ccc;">∞</span>
                            }
                        </div>
                    }
                    @if (schedStart.HasValue && schedEnd.HasValue)
                    {
                        <span class="time-separator">|</span>
                        <div class="time-progress-wrapper">
                            <div class="time-progress-track">
                                @if (timeProgressPercent == 0)
                                {
                                    <div class="time-progress-fill fill-waiting"></div>
                                }
                                else if (timeProgressPercent >= 100)
                                {
                                    <div class="time-progress-fill fill-expired"></div>
                                }
                                else
                                {
                                    <div class="time-progress-fill fill-active" style="width: @(timeProgressPercent.ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                }
                                <div class="time-marker @timeMarkerClass" style="left: @(timeMarkerPos.ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(timeExtraLabel))
                    {
                        <span class="time-separator">|</span>
                        <span class="time-extra-label">@timeExtraLabel</span>
                    }
                }
            </div>
            @if (canEdit)
            {
                <a asp-controller="AutomationRules" asp-action="Edit" asp-route-id="@Model.RuleId" class="btn-icon-settings" title="Konfiguruj Regułę">
                    <i class="fas fa-cog"></i>
                </a>
            }
            else
            {
                <a href="#" onclick="showNoAccessAlert(); return false;" class="btn-icon-settings disabled" title="Brak uprawnień do edycji">
                    <i class="fas fa-cog"></i>
                </a>
            }
        </div>
    </div>
</div>

@if (Model.IntervalRuleId.HasValue)
{
    <div class="Vert">
        <a href="@Url.Action("Details", "IntervalPrice", new { id = Model.IntervalRuleId.Value })" class="interval-info-box">
            <div class="interval-color-dot" style="background-color:@(Model.IntervalRuleColorHex ?? "#858796");"></div>
            <div style="flex-grow:1;">
                <div style="font-size:15px; font-weight:700; color:#333;">@Model.IntervalRuleName</div>
                <div style="font-size:12px; color:#858796; margin-top:2px;">Powiązany interwał cenowy</div>
            </div>
            <span class="interval-top-badge @(Model.IntervalIsActive ? "interval-badge-active" : "interval-badge-inactive")">
                @(Model.IntervalIsActive ? "Aktywny" : "Wyłączony")
            </span>
            <i class="fas fa-chevron-right" style="color:#d1d3e2;"></i>
        </a>
    </div>
}

<div class="Vert">
    <div class="kpi-container">
        <div class="kpi-card">
            <div class="kpi-title">
                Przypisane Produkty
                <i class="fas fa-cube text-gray-400"></i>
            </div>
            <div class="kpi-value-big">@Model.TotalProducts</div>
            <div class="kpi-subtext" style="display:flex; align-items:center; gap:6px;">
                <i class="fas fa-clock" style="font-size: 12px; width: 12px; text-align: center;"></i>
                <span>Aktualizacja: @(Model.LastScrapDate.HasValue? Model.LastScrapDate.Value.ToString("dd.MM HH:mm") : "-")</span>
            </div>
            <div class="kpi-subtext" style="display:flex; align-items:center; gap:6px; margin-top:3px;">
                <i class="fas fa-store" style="font-size: 12px; width: 12px; text-align: center;"></i>
                <span>Sklep: @Model.StoreName</span>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-title">
                Skuteczność Reguły
                <span style="color:#33A795;">@percentSuccess%</span>
            </div>
            <div class="d-flex align-items-end gap-2">
                <div class="kpi-value-big text-gray-800">@successCount</div>
                <div class="kpi-subtext mb-1">ofert przeliczonych</div>
            </div>
            <div class="mini-progress-bg">
                <div class="mini-progress-fill" style="width: @percentSuccess%"></div>
            </div>
            <div class="kpi-subtext mt-2">
                <span class="text-danger font-weight-bold" title="Liczba zablokowanych"><i class="fas fa-ban mr-1"></i> @blockedCount</span> zablokowanych
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-title">
                Dynamika Zmian
                <i class="fas fa-chart-bar text-gray-400"></i>
            </div>
            <div class="dynamics-row">
                <div class="dynamics-item">
                    <div class="dynamics-val text-danger"><i class="fas fa-arrow-up fa-xs"></i> @Model.CountIncreased</div>
                    <div class="dynamics-label">Podwyżki</div>
                </div>
                <div class="dynamics-item" style="border-left: 1px solid #eee; padding-left: 15px;">
                    <div class="dynamics-val text-success"><i class="fas fa-arrow-down fa-xs"></i> @Model.CountDecreased</div>
                    <div class="dynamics-label">Obniżki</div>
                </div>
                <div class="dynamics-item" style="border-left: 1px solid #eee; padding-left: 15px;">
                    <div class="dynamics-val text-primary"><i class="fas fa-circle fa-xs" style="font-size: 8px;"></i> @Model.CountMaintained</div>
                    <div class="dynamics-label">Założenia utrzymane</div>
                </div>
            </div>
            <div class="kpi-subtext mt-2">
                Zoptymalizowano cenę w <strong>@(Model.CountIncreased + Model.CountDecreased)</strong> ofertach
            </div>
        </div>
    </div>
</div>

<div class="Vert">
    <div class="Chart-Box-a" style="width: 100%; min-height: 400px;">
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 15px;">
            <div style="display:flex; align-items:center; gap: 20px;">
                <div class="kpi-title" style="margin-bottom:0;">Analiza Automatu</div>
                <div class="period-selector-group">
                    <button type="button" id="viewModeExec" class="period-btn-custom active" onclick="switchChartMode('execution')">
                        <i class="fas fa-chart-bar" style="margin-right: 4px;"></i> Wykonania
                    </button>
                    @if (isMarketplace)
                    {
                        <button type="button" id="viewModeSales" class="period-btn-custom" onclick="switchChartMode('sales')">
                            <i class="fas fa-chart-line" style="margin-right: 4px;"></i> Sprzedaż
                        </button>
                        <button type="button" id="viewModeBadges" class="period-btn-custom" onclick="switchChartMode('badges')">
                            <i class="fas fa-medal" style="margin-right: 4px;"></i> Odznaki
                        </button>
                    }
                    <button type="button" id="viewModePosition" class="period-btn-custom" onclick="switchChartMode('position')">
                        <i class="fas fa-trophy" style="margin-right: 4px;"></i> Pozycja cenowa
                    </button>
                </div>
            </div>
            <div class="period-selector-group">
                <button type="button" class="period-btn-custom active history-btn" data-days="7">7 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="14">14 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="30">30 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="60">60 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="90">90 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="120">120 Analiz</button>
                <button type="button" class="period-btn-custom history-btn" data-days="240">240 Analiz</button>
