                        { key: 'cheaper-own', label: 'Tańsza własna', icon: 'fa-exclamation-triangle', attr: 'data-has-cheaper-own', value: 'true' }
                    ]
                },
                {
                    id: 'interval',
                    label: 'Interwał',
                    showIf: '@(Model.IntervalRuleId.HasValue ? "true" : "false")' === 'true',
                    filters: [
                        { key: 'in-interval', label: 'W interwale', icon: 'fa-clock', attr: 'data-has-interval', value: 'true' },
                        { key: 'no-interval', label: 'Bez interwału', icon: 'fa-clock', attr: 'data-has-interval', value: 'false' }
                    ]
                }
            ];

            let activeFilters = new Map();
            let allRows = [];

            function init() {
                const tableBody = document.querySelector('#automationTable tbody');
                if (!tableBody) return;

                allRows = Array.from(tableBody.querySelectorAll('tr.main-product-row'));

                // Dynamiczne filtry per flaga
                const flagMap = new Map();
                allRows.forEach(row => {
                    const ids = row.getAttribute('data-flag-ids');
                    if (!ids) return;
                    ids.split(',').forEach(id => {
                        const trimmed = id.trim();
                        if (trimmed) flagMap.set(trimmed, (flagMap.get(trimmed) || 0) + 1);
                    });
                });

                if (flagMap.size > 0) {
                    const flagLookup = {};
                    flags.forEach(f => {
                        const id = (f.flagId ?? f.FlagId ?? '').toString();
                        const name = f.flagName ?? f.FlagName ?? '';
                        const color = f.flagColor ?? f.FlagColor ?? '#858796';
                        if (id) flagLookup[id] = { name: name, color: color };
                    });

                    const flagFilters = [];
                    flagMap.forEach((count, flagId) => {
                        const info = flagLookup[flagId];
                        if (!info) return;
                        flagFilters.push({
                            key: 'flag-' + flagId,
                            label: info.name,
                            icon: 'fa-flag',
                            attr: 'data-flag-ids',
                            value: flagId,
                            color: info.color
                        });
                    });

                    if (flagFilters.length > 0) {
                        filterGroups.push({
                            id: 'flags',
                            label: 'Flagi',
                            filters: flagFilters
                        });
                    }
                }

                buildFilterUI();
                updateCounts();
                bindEvents();
            }

            function buildFilterUI() {
                const toolbar = document.getElementById('filterToolbar');
                if (!toolbar) return;

                toolbar.innerHTML = '';

                filterGroups.forEach(group => {
                    if (group.showIf === false) return;

                    const groupEl = document.createElement('div');
                    groupEl.className = 'filter-group';
                    groupEl.dataset.groupId = group.id;

                    const labelEl = document.createElement('span');
                    labelEl.className = 'filter-group-label';
                    labelEl.innerHTML = `${group.label}`;
                    groupEl.appendChild(labelEl);

                    group.filters.forEach(filter => {
                        const count = countMatching(filter.attr, filter.value);

                        const btn = document.createElement('button');
                        btn.className = 'filter-btn';
                        btn.dataset.filterKey = filter.key;
                        btn.dataset.filterAttr = filter.attr;
                        btn.dataset.filterValue = filter.value;
                        btn.dataset.groupId = group.id;

                        btn.innerHTML = `
                            <i class="fas ${filter.icon}" style="font-size: 10px;"></i>
                            ${filter.label}
                            ${!filter.isSort
                                ? `<span class="filter-count">${count}</span>`
                                : `<span class="filter-count sort-indicator" style="display:none;"><i class="fas fa-arrow-down"></i></span>`
                            }
                        `;

                        if (filter.color) {
                            btn.dataset.filterColor = filter.color;
                        }

                        if (count === 0 && !filter.isSort) {
                            btn.disabled = true;
                            btn.style.opacity = '0.5';
                            btn.style.cursor = 'not-allowed';
                        }

                        groupEl.appendChild(btn);
                    });

                    toolbar.appendChild(groupEl);
                });

                updateTotalCount();
            }

            function countMatching(attr, value) {
                if (attr === 'data-flag-ids') {
                    return allRows.filter(row => {
                        const ids = (row.getAttribute(attr) || '').split(',').map(s => s.trim());
                        return ids.includes(value);
                    }).length;
                }
                return allRows.filter(row => row.getAttribute(attr) === value).length;
            }

            function updateCounts() {
                document.querySelectorAll('.filter-btn').forEach(btn => {
                    if (btn.dataset.groupId === 'marketplace-sales') {
                        const countEl = btn.querySelector('.filter-count');
                        if (countEl) countEl.style.display = 'none';
                        return;
                    }

                    const attr = btn.dataset.filterAttr;
                    const value = btn.dataset.filterValue;
                    const count = countMatching(attr, value);
                    const countEl = btn.querySelector('.filter-count');
                    if (countEl) countEl.textContent = count;
                });
            }

            function updateTotalCount() {
                if (typeof window.updateCombinedTotalCount === 'function') {
                    window.updateCombinedTotalCount();
                }
            }

            function bindEvents() {
                document.getElementById('filterToolbar').addEventListener('click', function (e) {
                    const btn = e.target.closest('.filter-btn');
                    if (!btn || btn.disabled) return;

                    const key = btn.dataset.filterKey;
                    const group = filterGroups.find(g => g.id === btn.dataset.groupId);
                    const filterDef = group.filters.find(f => f.key === key);

                    if (filterDef.isSort) {
                        handleSortClick(btn, filterDef);
                    } else {
                        const attr = btn.dataset.filterAttr;
                        const value = btn.dataset.filterValue;
                        toggleFilter(key, attr, value, btn);
                    }
                });

                document.getElementById('resetFiltersBtn').addEventListener('click', resetFilters);
            }

            function handleSortClick(btn, filterDef) {
                const attr = filterDef.attr;
                const tbody = document.querySelector('#automationTable tbody');
                const indicator = btn.querySelector('.sort-indicator');

                let currentDir = btn.getAttribute('data-sort-dir') || 'none';

                document.querySelectorAll('[data-group-id="' + btn.dataset.groupId + '"]').forEach(b => {
                    if (b !== btn) {
                        b.classList.remove('active');
                        b.setAttribute('data-sort-dir', 'none');
                        const ind = b.querySelector('.sort-indicator');
                        if (ind) ind.style.display = 'none';
                    }
                });

                if (currentDir === 'none') {
                    btn.setAttribute('data-sort-dir', 'desc');
                    btn.classList.add('active');
                    if (indicator) {
                        indicator.innerHTML = '<i class="fas fa-arrow-down"></i>';
                        indicator.style.display = 'inline-flex';
                    }
                    const sortedRows = [...allRows].sort((a, b) => {
                        const valA = parseFloat(a.getAttribute(attr)) || 0;
                        const valB = parseFloat(b.getAttribute(attr)) || 0;
                        return valB - valA;
                    });
                    sortedRows.forEach(row => { tbody.appendChild(row); });
                } else if (currentDir === 'desc') {
                    btn.setAttribute('data-sort-dir', 'asc');
                    btn.classList.add('active');
                    if (indicator) {
                        indicator.innerHTML = '<i class="fas fa-arrow-up"></i>';
                        indicator.style.display = 'inline-flex';
                    }
                    const sortedRows = [...allRows].sort((a, b) => {
                        const valA = parseFloat(a.getAttribute(attr)) || 0;
                        const valB = parseFloat(b.getAttribute(attr)) || 0;
                        return valA - valB;
                    });
                    sortedRows.forEach(row => { tbody.appendChild(row); });
                } else if (currentDir === 'asc') {
                    btn.setAttribute('data-sort-dir', 'none');
                    btn.classList.remove('active');
                    if (indicator) { indicator.style.display = 'none'; }
                    allRows.forEach(row => { tbody.appendChild(row); });
                }
            }

            function toggleFilter(key, attr, value, btn) {
                if (activeFilters.has(key)) {
                    activeFilters.delete(key);
                    btn.classList.remove('active');
                    if (btn.dataset.filterColor) {
                        btn.style.backgroundColor = '';
                        btn.style.borderColor = '';
                        btn.style.color = '';
                    }
                } else {
                    activeFilters.set(key, { attr, value });
                    btn.classList.add('active');
                    if (btn.dataset.filterColor) {
                        btn.style.backgroundColor = btn.dataset.filterColor + 'CC';
                        btn.style.borderColor = btn.dataset.filterColor + 'AA';
                        btn.style.color = '#fff';
                    }
                }

                applyFilters();
                updateGroupIndicators();
                updateResetButton();
            }

            function applyFilters() {
                if (activeFilters.size === 0) {
                    allRows.forEach(row => { row.classList.remove('filter-hidden'); });
                } else {
                    const filtersByAttr = new Map();

                    activeFilters.forEach((filterData, key) => {
                        if (!filtersByAttr.has(filterData.attr)) {
                            filtersByAttr.set(filterData.attr, []);
                        }
                        filtersByAttr.get(filterData.attr).push(filterData.value);
                    });

                    allRows.forEach(row => {
                        let visible = true;

                        filtersByAttr.forEach((values, attr) => {
                            if (attr === 'data-flag-ids') {
                                const rowFlags = (row.getAttribute(attr) || '').split(',').map(s => s.trim());
                                const hasAny = values.some(v => rowFlags.includes(v));
                                if (!hasAny) visible = false;
                            } else {
                                const rowValue = row.getAttribute(attr);
                                if (!values.includes(rowValue)) {
                                    visible = false;
                                }
                            }
                        });

                        if (visible) { row.classList.remove('filter-hidden'); }
                        else { row.classList.add('filter-hidden'); }
                    });
                }

                updateTotalCount();

                if (typeof massActions !== 'undefined') {
                    massActions.updateVisibleButtons();
                }
            }

            function updateGroupIndicators() {
                document.querySelectorAll('.filter-group').forEach(group => {
                    const hasActive = group.querySelector('.filter-btn.active');
                    group.classList.toggle('has-active', !!hasActive);
                });
            }

            function updateResetButton() {
                const resetBtn = document.getElementById('resetFiltersBtn');
                if (resetBtn) {
                    resetBtn.style.display = activeFilters.size > 0 ? 'inline-flex' : 'none';
                }
            }

            function resetFilters() {
                activeFilters.clear();

                document.querySelectorAll('.filter-btn.active').forEach(btn => {
                    btn.classList.remove('active');
                    btn.setAttribute('data-sort-dir', 'none');
                    const ind = btn.querySelector('.sort-indicator');
                    if (ind) ind.style.display = 'none';
                });

                const tbody = document.querySelector('#automationTable tbody');
                allRows.forEach(row => {
                    row.classList.remove('filter-hidden');
                    tbody.appendChild(row);
                });

                updateGroupIndicators();
                updateResetButton();
                updateTotalCount();
            }

            return {
                init,
                resetFilters,
                getActiveFilters: () => Array.from(activeFilters.keys())
            };
        })();

        $(document).ready(function () {
            FilterSystem.init();
        });
    </script>


    <script>
        /* ============================================================
           PAUSE SYSTEM — wstrzymywanie automatu na poziomie produktu
           ============================================================ */
        const PauseSystem = (function () {
            let currentProductId = null;
            let currentProductName = null;
            let countdownTimer = null;

            function escapeHtml(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
                })[c]);
            }

            function isPauseIndefinite(iso) {
                if (!iso) return false;
                const d = new Date(iso);
                if (isNaN(d.getTime())) return false;
                const now = new Date();
                const diffYears = (d - now) / (1000 * 60 * 60 * 24 * 365);
                return diffYears > 5;
            }

            function formatRemaining(iso) {
                if (!iso) return '-';
                const target = new Date(iso);
                if (isNaN(target.getTime())) return '-';
                const now = new Date();
                let diffMs = target - now;
                if (diffMs <= 0) return 'wygasło';

                const diffMinutes = Math.floor(diffMs / 60000);
                const days = Math.floor(diffMinutes / 1440);
                const hours = Math.floor((diffMinutes % 1440) / 60);
                const minutes = diffMinutes % 60;

                if (days > 0) return days + 'd ' + hours + 'h';
                if (hours > 0) return hours + 'h ' + minutes + 'min';
                if (minutes > 0) return minutes + 'min';
                return '< 1min';
            }

            function buildDurationCards() {
                const durations = [
                    { hours: 1, label: '1 godzina' },
                    { hours: 4, label: '4 godziny' },
                    { hours: 6, label: '6 godzin' },
                    { hours: 12, label: '12 godzin' },
                    { hours: 24, label: '24 godziny' }
                ];

                let html = '<div class="pause-duration-grid">';
                durations.forEach(d => {
                    html += `
                        <div class="pause-duration-card" data-pause-hours="${d.hours}">
                            <div class="duration-value">${d.hours}h</div>
                            <div class="duration-label">${d.label}</div>
                        </div>
                    `;
                });
                html += '</div>';

                html += `
                    <div class="pause-duration-card-indefinite" data-pause-hours="-1">
                        <i class="fas fa-infinity indef-icon"></i>
                        <div class="indef-text">
                            <div class="indef-title">Do odwołania</div>
                            <div class="indef-sub">Wstrzymane bez limitu czasu — wznów ręcznie</div>
                        </div>
                    </div>
                `;

                return html;
            }

            function openModal(productId, productName, isPausedNow, pausedUntilIso) {
                currentProductId = productId;
                currentProductName = productName;

                const content = document.getElementById('pauseModalContent');

                if (isPausedNow) {
                    const indefinite = isPauseIndefinite(pausedUntilIso);
                    const remaining = indefinite ? null : formatRemaining(pausedUntilIso);

                    let infoHtml = '';
                    if (indefinite) {
                        infoHtml = '<strong>Wstrzymano do odwołania.</strong> Automat nie będzie zmieniał ceny dopóki nie wznowisz ręcznie.';
                    } else {
                        infoHtml = 'Pozostały czas wstrzymania: <strong>' + escapeHtml(remaining) + '</strong>';
                    }

                    content.innerHTML = `
                        <div class="pause-currently-info">
                            <i class="fas fa-pause-circle pause-currently-icon"></i>
                            <div class="pause-currently-text">
                                <div class="pname">${escapeHtml(productName)}</div>
                                <div class="ptime">${infoHtml}</div>
                            </div>
                        </div>
                        <button type="button" class="pause-resume-btn" data-pause-action="unpause">
                            <i class="fas fa-play"></i> Wznów działanie automatu
                        </button>
                        <div class="pause-section-divider">Lub przedłuż wstrzymanie</div>
                        <p class="pause-instructions">Wybierz nowy czas — zastąpi obecne ustawienie.</p>
                        ${buildDurationCards()}
                    `;
                } else {
                    content.innerHTML = `
                        <div class="pause-product-name-box">${escapeHtml(productName)}</div>
                        <p class="pause-instructions">
                            Wybierz na jak długo chcesz wstrzymać automatyczne zmiany cen dla tego produktu.
                            W tym czasie automat go pominie. Pauza dotyczy automatu cenowego oraz systemu Interwału cenowego.
                        </p>
                        ${buildDurationCards()}
                    `;
                }

                $('#pauseProductModal').modal('show');
            }

            function pause(durationHours) {
                if (!currentProductId) return;
                const token = $('input[name="__RequestVerificationToken"]').val();

                $('#pauseProductModal').modal('hide');
                if (typeof showLoading === 'function') showLoading();

                $.ajax({
                    url: '@Url.Action("PauseProduct", "PriceAutomation")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': token },
                    data: JSON.stringify({
                        RuleId: currentRuleId,
                        ProductId: parseInt(currentProductId),
                        DurationHours: parseInt(durationHours)
                    }),
                    success: function (r) {
                        if (typeof hideLoading === 'function') hideLoading();
                        if (r && r.success) {
                            sessionStorage.setItem('automation_scrollToProduct', currentProductId);
                            location.reload();
                        } else {
                            alert('Błąd: ' + ((r && r.message) || 'Nie udało się zapisać pauzy.'));
                        }
                    },
                    error: function (xhr) {
                        if (typeof hideLoading === 'function') hideLoading();
                        alert('Błąd komunikacji z serwerem: ' + (xhr.responseText || xhr.statusText));
                    }
                });
            }

            function unpause() {
                if (!currentProductId) return;
                const token = $('input[name="__RequestVerificationToken"]').val();

                $('#pauseProductModal').modal('hide');
                if (typeof showLoading === 'function') showLoading();

                $.ajax({
                    url: '@Url.Action("UnpauseProduct", "PriceAutomation")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': token },
                    data: JSON.stringify({
                        RuleId: currentRuleId,
                        ProductId: parseInt(currentProductId)
                    }),
                    success: function (r) {
                        if (typeof hideLoading === 'function') hideLoading();
                        if (r && r.success) {
                            sessionStorage.setItem('automation_scrollToProduct', currentProductId);
                            location.reload();
                        } else {
                            alert('Błąd: ' + ((r && r.message) || 'Nie udało się wznowić.'));
                        }
                    },
                    error: function (xhr) {
                        if (typeof hideLoading === 'function') hideLoading();
                        alert('Błąd komunikacji z serwerem: ' + (xhr.responseText || xhr.statusText));
                    }
                });
            }

            function updateCountdowns() {
                document.querySelectorAll('.pause-product-btn.is-paused').forEach(btn => {
                    const iso = btn.getAttribute('data-paused-until');
                    if (!iso) return;

                    const target = new Date(iso);
                    if (isNaN(target.getTime())) return;
                    const now = new Date();

                    if (target <= now) {
                        // Pauza wygasła — reset wizualny
                        btn.classList.remove('is-paused');
                        btn.innerHTML = '<i class="fas fa-play"></i>';
                        btn.title = 'Wstrzymaj automat dla tego produktu';
                        btn.setAttribute('data-paused-until', '');
                        const row = btn.closest('tr');
                        if (row) {
                            row.classList.remove('row-paused');
                            row.setAttribute('data-is-paused', 'false');
                        }
                        return;
                    }

                    const txt = btn.querySelector('.pause-countdown-text');
                    if (!txt) return;

                    if (isPauseIndefinite(iso)) {
                        txt.textContent = '∞';
                    } else {
                        txt.textContent = formatRemaining(iso);
                    }
                });
            }

            function init() {
                // Klik na przycisk pauzy (przy produkcie)
                document.addEventListener('click', function (e) {
                    const btn = e.target.closest('.pause-product-btn');
                    if (!btn) return;
                    if (btn.style.cursor === 'not-allowed') return; // wariant bez uprawnień
                    e.preventDefault();
                    e.stopPropagation();

                    const productId = btn.dataset.productId;
                    const productName = btn.dataset.productName;
                    const isPausedNow = btn.classList.contains('is-paused');
                    const pausedUntil = btn.getAttribute('data-paused-until');

                    openModal(productId, productName, isPausedNow, pausedUntil);
                });

                // Delegacja: klik wewnątrz modala — karty czasu / wznów
                document.addEventListener('click', function (e) {
                    const card = e.target.closest('.pause-duration-card, .pause-duration-card-indefinite');
                    if (card && document.getElementById('pauseProductModal').classList.contains('show')) {
                        const hours = card.getAttribute('data-pause-hours');
                        pause(hours);
                        return;
                    }

                    const resumeBtn = e.target.closest('[data-pause-action="unpause"]');
                    if (resumeBtn) {
                        unpause();
                        return;
                    }
                });

                // Pierwsze odświeżenie + pętla co 30s
                updateCountdowns();
                countdownTimer = setInterval(updateCountdowns, 30000);
            }

            return { init, openModal, pause, unpause };
        })();

        $(document).ready(function () {
            PauseSystem.init();
        });
    </script>
}
