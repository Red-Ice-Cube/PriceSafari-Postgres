            </div>
            <div style="flex: 1; min-width: 300px; height: 440px; border: 1px solid #e3e6f0; border-radius: 8px; padding: 10px;">
                <div id="chartDynamics" style="width: 100%; height: 100%;"></div>
            </div>
        </div>
        <div id="salesChartContainer" style="display: none; width: 100%; height: 440px; border: 1px solid #e3e6f0; border-radius: 8px; padding: 10px;">
