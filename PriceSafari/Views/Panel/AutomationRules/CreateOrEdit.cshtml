                            <span class="switch-label-text label-left">NIE</span>
                            <span class="switch-label-text label-right">TAK</span>
                        </div>
                    </div>
                </div>

                <div class="row-option">
                    <div class="option-desc">
                        <div class="option-title">
                            <span>Wymagaj oferty na Google</span>
                            <img src="/images/GoogleShopping.png" alt="Google" style="width: 16px; height: 16px; vertical-align: middle; margin-left: 5px;">
                           
                        </div>
                        <div class="option-subtitle">
                            Czy blokować zmianę ceny, jeśli Twój produkt nie został wykryty w wynikach Google Shopping?
                        </div>
                        <div class="option-subtitle" style="color:#858796; font-size:12px; margin-top:2px;">
                            <strong>TAK:</strong> Automat wstrzyma działanie, jeśli nie znajdzie Twojej oferty w Google (chroni przed zmianą ceny "w ciemno").<br />
                            <strong>NIE:</strong> Automat wyliczy cenę, pobierając Twoją aktualną cenę z innego źródła (np. XML lub Ceneo).
                        </div>
                    </div>
                    <div class="switch-container switch-status @(Model.RequireOwnOfferOnGoogle ? "state-right" : "state-left")" onclick="toggleSwitch(this)">
                        <input type="checkbox" asp-for="RequireOwnOfferOnGoogle" />
                        <div class="switch-slider-bg"></div>
                        <div class="switch-labels">
                            <span class="switch-label-text label-left">NIE</span>
                            <span class="switch-label-text label-right">TAK</span>
                        </div>
                    </div>
                </div>

                <div class="row-option">
                    <div class="option-desc">
                        <div class="option-title">Koszt Dostawy</div>
                        <div class="option-subtitle">Uwzględniaj koszty wysyłki przy porównywaniu ofert konkurencji (Cena Produktu + Dostawa).</div>
                        <div class="option-subtitle">Zalecamy wybrać opcję "NIE". Jeżeli jednak jest to kluczowe dla specyfiki Twoich produktów, wybierz "TAK".</div>
                    </div>
                    <div class="switch-container switch-status @(Model.UsePriceWithDelivery ? "state-right" : "state-left")" onclick="toggleSwitch(this)">
                        <input type="checkbox" asp-for="UsePriceWithDelivery" />
                        <div class="switch-slider-bg"></div>
                        <div class="switch-labels">
                            <span class="switch-label-text label-left">NIE</span>
                            <span class="switch-label-text label-right">TAK</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</form>
@if (isEdit)
{
    <form id="deleteRuleForm" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:none;">
    </form>
}
<div asp-validation-summary="All" class="alert alert-danger mt-3" style="display:none;"></div>

<div id="dynamicModalContainer">
    @if (Model.SourceType == AutomationSourceType.Marketplace)
    {
        @await Html.PartialAsync("~/Views/Shared/PartialViewsPanel/_PresetyMarketPlace.cshtml", null, new ViewDataDictionary(ViewData) { { "StoreId", Model.StoreId } })
    }
    else
    {
        @await Html.PartialAsync("~/Views/Shared/PartialViewsPanel/_PresetyPriceComparison.cshtml", null, new ViewDataDictionary(ViewData) { { "StoreId", Model.StoreId } })
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        var storeId = @Model.StoreId;
        window.presetContext = 'automationRule';
        var presetTypeContext = @((int)Model.SourceType);
        var getModalUrl = '@Url.Action("GetModalPartial", "AutomationRules")';
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <script src="~/js/member/Presets.js"></script>

    <script>

        document.addEventListener("DOMContentLoaded", function() {

            var btnOpen = document.getElementById('openPresetSelectorBtn');
            if (btnOpen) {
                btnOpen.addEventListener('click', function() {
                    var modalEl = document.getElementById('competitorModal');
                    if (typeof window.openCompetitorsModal === 'function') {
                        window.openCompetitorsModal();
                    }
                });
            }

            var colorInput = document.getElementById('ColorHexInput');
            var colorContainer = document.getElementById('ColorContainer');

            if(colorInput && colorContainer){

                colorInput.addEventListener('input', function() {
                    colorContainer.style.backgroundColor = this.value;
                });

                colorInput.addEventListener('change', function() {
                    colorContainer.style.backgroundColor = this.value;
                });
            }
        });

        window.toggleSwitch = function(container) {
            const checkbox = container.querySelector('input[type="checkbox"]');
            checkbox.checked = !checkbox.checked;

            if (checkbox.checked) {
                container.classList.remove('state-left');
                container.classList.add('state-right');
            } else {
                container.classList.remove('state-right');
                container.classList.add('state-left');
            }

            if (checkbox.id === 'IsActiveSwitch') {
                const label = document.getElementById('mainStatusLabel');
                if (label) {
                    if (checkbox.checked) {
                        label.innerText = "AUTOMAT CENOWY AKTYWNY";
                        label.classList.remove('toggle-inactive-text');
                        label.classList.add('toggle-active-text');
                    } else {
                        label.innerText = "AUTOMAT CENOWY WYŁĄCZONY";
                        label.classList.remove('toggle-active-text');
                        label.classList.add('toggle-inactive-text');
                    }
                }
            }
        };

        window.validateSmartThreshold = function(input) {
            let val = parseFloat(input.value);

           
            if (isNaN(val) || val <= 0) {
                alert("Granica przebicia musi być większa od 0.");
                input.value = 0.01;
                return;
            }

     
            const allegroSmartThreshold = 45.00;

            if (val >= allegroSmartThreshold) {
                alert(`Granica przebicia nie może być wyższa niż próg Smart! (${allegroSmartThreshold.toFixed(2)} PLN).\n\nJeśli ustawisz tu więcej, mechanizm ochrony nie zadziała, ponieważ Twoja granica będzie wyższa niż sufit Smarta.`);
                input.value = 44.99;
            }
        }

        window.toggleInputs = function(switchEl, containerId) {
            const container = document.getElementById(containerId);
            if (!container) return;
            if (switchEl.checked) {
                container.style.opacity = '1';
                container.style.pointerEvents = 'auto';
            } else {
                container.style.opacity = '0.5';
                container.style.pointerEvents = 'none';
            }
        }



        window.setStrategyMode = function(modeValue) {
            const input = document.getElementById('StrategyModeInput');
            if(input) input.value = modeValue;

            const btnComp = document.getElementById('btn-mode-comp');
            const btnProfit = document.getElementById('btn-mode-profit');

            if (modeValue === 0) {
                if(btnComp) btnComp.classList.add('active');
                if(btnProfit) btnProfit.classList.remove('active');
            } else {
                if(btnComp) btnComp.classList.remove('active');
                if(btnProfit) btnProfit.classList.add('active');
            }

            const compFields = document.getElementById('competitivenessFields');
            const profitFields = document.getElementById('profitFields');
            const descBoxComp = document.getElementById('descBoxComp');
            const descBoxProfit = document.getElementById('descBoxProfit');

            if (modeValue === 0) {
                if(compFields) compFields.style.display = 'block';
                if(profitFields) profitFields.style.display = 'none';
                if(descBoxComp) descBoxComp.classList.add('active-strategy');
                if(descBoxProfit) descBoxProfit.classList.remove('active-strategy');
            } else {
                if(compFields) compFields.style.display = 'none';
                if(profitFields) profitFields.style.display = 'block';
                if(descBoxComp) descBoxComp.classList.remove('active-strategy');
                if(descBoxProfit) descBoxProfit.classList.add('active-strategy');
            }
        }

        window.triggerStrategyClick = function(modeValue) {
            setStrategyMode(modeValue);
        }

        window.selectPresetForAutomation = function(presetId, presetName) {
            var inputId = document.getElementById('CompetitorPresetId');
            var labelName = document.getElementById('selectedPresetName');
            if(inputId) inputId.value = presetId;
            if(labelName) labelName.innerText = presetName;

            var m = document.getElementById('competitorModal');
            if (m) {
                m.classList.remove('show');
                m.style.display = 'none';
            }
            var backdrops = document.getElementsByClassName('modal-backdrop');
            while(backdrops.length > 0){
                backdrops[0].parentNode.removeChild(backdrops[0]);
            }
            document.body.classList.remove('modal-open');
        };

        function confirmDelete() {
            if (confirm('Czy na pewno chcesz usunąć ten automat cenowy? Tej operacji nie można cofnąć.')) {
                document.getElementById('deleteRuleForm').submit();
            }
        }

        window.toggleTimeLimited = function(switchEl) {
            const container = document.getElementById('timeLimitedContainer');
            if (!container) return;
            if (switchEl.checked) {
                container.style.opacity = '1';
                container.style.pointerEvents = 'auto';
            } else {
                container.style.opacity = '0.5';
                container.style.pointerEvents = 'none';
            }
            updateSchedulePreview();
        };

        function updateSchedulePreview() {
            const isTimeLimited = document.getElementById('IsTimeLimitedSwitch')?.checked;
            const startInput = document.getElementById('ScheduledStartDateInput');
            const endInput = document.getElementById('ScheduledEndDateInput');
            const preview = document.getElementById('schedulePreview');
            const previewText = document.getElementById('schedulePreviewText');

            if (!preview || !previewText) return;

            if (!isTimeLimited) {
                preview.style.display = 'none';
                return;
            }

            const startDate = startInput?.value;
            const endDate = endInput?.value;

            if (!startDate && !endDate) {
                preview.style.display = 'none';
                return;
            }

            preview.style.display = 'block';

            let text = '<i class="fas fa-info-circle" style="margin-right: 8px; color: #4e73df;"></i>';

            if (startDate && endDate) {
                text += 'Automat będzie aktywny od <strong>' + formatDatePL(startDate) + '</strong> do <strong>' + formatDatePL(endDate) + '</strong> (włącznie).';
            } else if (startDate) {
                text += 'Automat będzie aktywny od <strong>' + formatDatePL(startDate) + '</strong> (bez daty końcowej).';
            } else if (endDate) {
                text += 'Automat będzie aktywny do <strong>' + formatDatePL(endDate) + '</strong> (włącznie).';
            }

            // Walidacja: end < start
            if (startDate && endDate && new Date(endDate) < new Date(startDate)) {
                text = '<i class="fas fa-exclamation-triangle" style="margin-right: 8px; color: #e74a3b;"></i>';
                text += '<span style="color: #e74a3b;">Data zakończenia nie może być wcześniejsza niż data rozpoczęcia!</span>';
                preview.style.borderColor = '#e74a3b';
                preview.style.background = '#fff5f5';
            } else {
                preview.style.borderColor = '#eaecf4';
                preview.style.background = '#f8f9fc';
            }

            previewText.innerHTML = text;
        }

        function formatDatePL(dateStr) {
            if (!dateStr) return '';
            var parts = dateStr.split('-');
            return parts[2] + '.' + parts[1] + '.' + parts[0];
        }

                function clearDateInput(inputId) {
            var input = document.getElementById(inputId);
            if (input) {
                input.value = '';
                updateSchedulePreview();
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            var startInput = document.getElementById('ScheduledStartDateInput');
            var endInput = document.getElementById('ScheduledEndDateInput');
            if (startInput) startInput.addEventListener('change', updateSchedulePreview);
            if (endInput) endInput.addEventListener('change', updateSchedulePreview);
            updateSchedulePreview();

        
            var form = document.getElementById('automationRuleForm');
            if (form) {
                form.addEventListener('submit', function(e) {
                    var isTimeLimited = document.getElementById('IsTimeLimitedSwitch')?.checked;
                    if (isTimeLimited) {
                        var startVal = document.getElementById('ScheduledStartDateInput')?.value;
                        var endVal = document.getElementById('ScheduledEndDateInput')?.value;

                        if (startVal && endVal && new Date(endVal) < new Date(startVal)) {
                            e.preventDefault();
                            alert('Data zakończenia nie może być wcześniejsza niż data rozpoczęcia!');
                            return false;
                        }
                    }
              
                    var gradDecEnabled = document.querySelector('input[name="EnableGradualDecrease"]')?.checked;
                    if (gradDecEnabled) {
                        var gradDecVal = parseFloat(document.querySelector('input[name="GradualDecreaseValue"]')?.value);
                        if (isNaN(gradDecVal) || gradDecVal <= 0) {
                            e.preventDefault();
                            alert('Wartość stopniowej obniżki musi być większa od 0,00.');
                            return false;
                        }
                    }

                    var gradIncEnabled = document.querySelector('input[name="EnableGradualIncrease"]')?.checked;
                    if (gradIncEnabled) {
                        var gradIncVal = parseFloat(document.querySelector('input[name="GradualIncreaseValue"]')?.value);
                        if (isNaN(gradIncVal) || gradIncVal <= 0) {
                            e.preventDefault();
                            alert('Wartość stopniowej podwyżki musi być większa od 0,00.');
                            return false;
                        }
                    }
                });
            }
        });
    </script>
}