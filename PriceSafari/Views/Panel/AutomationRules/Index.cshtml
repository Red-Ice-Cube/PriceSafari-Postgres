@using Microsoft.AspNetCore.Identity
@using PriceSafari.Models
@using PriceSafari.Enums
@using PriceSafari.Models.ViewModels
@using static PriceSafari.Controllers.MemberControllers.AutomationRulesController

@model IEnumerable<AutomationRuleListViewModel>
@inject UserManager<PriceSafariUser> UserManager

@{
    ViewData["Title"] = "Reguły Automatyzacji";
    int storeId = ViewBag.StoreId;
    string storeName = ViewBag.StoreName;
    Layout = "~/Views/Shared/_PanelLayout.cshtml";

    var user = await UserManager.GetUserAsync(User);
    bool canEdit = user?.AccesToEditPriceAutomation ?? false;
    string noAccessMessage = "Nie masz uprawnień aby zarządzać regułami automatyzacji cen.";

    var intervalLookup = ViewBag.IntervalLookup as Dictionary<int, IntervalInfoDto>
                         ?? new Dictionary<int, IntervalInfoDto>();
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
<style>

    .rules-scroll-container {
        overflow-y: auto;
        max-height: calc(100vh - 180px);
        padding-right: 4px;
    }
    .rules-scroll-container::-webkit-scrollbar { width: 6px; }
    .rules-scroll-container::-webkit-scrollbar-track { background: transparent; }
    .rules-scroll-container::-webkit-scrollbar-thumb { background: #d1d3e2; border-radius: 3px; }
    .rules-scroll-container::-webkit-scrollbar-thumb:hover { background: #b7b9cc; }

    .rule-card {
        background: #fff;
        border: 1px solid #e3e6f0;
        border-radius: 10px;
        margin-bottom: 10px;
        display: flex;
        align-items: stretch;
        transition: all 0.2s;
        cursor: pointer;
        overflow: hidden;
    }
    .rule-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.07); border-color: #b7b9cc; }
    .rule-card.dragging { opacity: 0.3; transform: scale(0.97); }

    .rule-main {
        display: flex;
        align-items: flex-start;
        flex-grow: 1;
        padding: 14px 16px;
        min-width: 0;
        gap: 12px;
    }
    .drag-handle {
        cursor: grab; color: #d1d3e2; font-size: 15px;
        transition: color 0.2s; flex-shrink: 0;
        padding-top: 3px;
    }
    .drag-handle:hover { color: #858796; }
    .drag-handle:active { cursor: grabbing; }
    .rule-color-bar {
        width: 5px; min-height: 100%; border-radius: 3px;
        flex-shrink: 0; align-self: stretch;
    }
    .rule-info { display: flex; flex-direction: column; min-width: 0; flex-grow: 1; gap: 8px; }
    .rule-title {
        font-size: 14px; font-weight: 700; color: #5a5c69;
        text-transform: uppercase; letter-spacing: 0.4px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .rule-meta {
        display: flex; align-items: center; font-size: 11px; color: #858796; gap: 6px;
        flex-wrap: wrap;
    }
    .meta-item { display: flex; align-items: center; gap: 5px; }
    .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #d1d3e2; flex-shrink: 0; }

    .rule-badges {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        margin-top: 2px;
    }
    .rb { 
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 10px; border-radius: 5px; font-size: 10px;
        font-weight: 600; white-space: nowrap; letter-spacing: 0.3px;
        border: 1px solid #e3e6f0; background: #f8f9fc; color: #5a5c69;
    }
    .rb i { font-size: 9px; }
    .rb-strategy-comp { color: rgba(113,96,232,1); border-color: rgba(113,96,232,0.2); background: rgba(113,96,232,0.05); }
    .rb-strategy-prof { color: #0d2c56; border-color: rgba(13,44,86,0.15); background: rgba(13,44,86,0.04); }

    .rb-time { gap: 4px; }
    .rb-time-unlimited { color: #1cc88a; border-color: rgba(28,200,138,0.2); background: rgba(28,200,138,0.05); }
    .rb-time-active { color: #1cc88a; border-color: rgba(28,200,138,0.2); background: rgba(28,200,138,0.05); }
    .rb-time-waiting { color: #f6c23e; border-color: rgba(246,194,62,0.25); background: rgba(246,194,62,0.06); }
    .rb-time-expired { color: #e74a3b; border-color: rgba(231,74,59,0.2); background: rgba(231,74,59,0.05); }
    .rb-time-disabled { color: #858796; }

    .time-mini-dates { font-size: 9px; font-family: monospace; opacity: 0.8; }
    .time-mini-extra { font-size: 9px; opacity: 0.7; }

    .rule-sidebar {
        display: flex; flex-direction: column; align-items: stretch;
        border-left: 1px solid #eaecf4; flex-shrink: 0;
        min-width: 200px; max-width: 240px;
    }

    .sidebar-section {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 10px 16px; gap: 3px;
    }
    .sidebar-section-label {
        font-size: 8px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 1px; color: #b7b9cc; line-height: 1;
    }

    .sidebar-section-label.label-ivl-active { color: #1cc88a; }
    .sidebar-section-label.label-ivl-inactive { color: #e74a3b; }

    .sidebar-status-value {
        display: flex; align-items: center; gap: 5px;
        font-size: 12px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .sidebar-status-value i { font-size: 6px; }
    .st-active { color: #1cc88a; }
    .st-inactive { color: #e74a3b; }
    .st-waiting { color: #f6c23e; }
    .st-stopped { color: #f6c23e; }

    .sidebar-interval {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 10px 14px; gap: 5px;
        border-top: 1px solid #eaecf4;
        background: #fafbfd;
        min-height: 52px;
    }

    .interval-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 12px; border-radius: 6px; font-size: 11px;
        font-weight: 600; cursor: pointer; transition: all 0.15s;
        white-space: nowrap; text-decoration: none !important;
        line-height: 1.3;
    }
    .interval-chip-exists {
        background: #f0f1f5; border: 1px solid #d1d3e2; color: #5a5c69;
    }
    .interval-chip-exists:hover {
        background: #e8e9ef; border-color: #b7b9cc; color: #3a3b45;
    }
    .interval-color-bar {
        width: 4px;
        align-self: stretch; 
        min-height: 14px; 
        border-radius: 2px;
        flex-shrink: 0;
    }
    .interval-chip-add {
        background: transparent; border: 1px dashed #d1d3e2; color: #b7b9cc;
        padding: 5px 12px; border-radius: 6px;
    }
    .interval-chip-add:hover {
        border-color: #858796; color: #858796; background: #f8f9fc;
    }

    .sidebar-no-interval {
        font-size: 10px; color: #d1d3e2; font-weight: 500;
        display: flex; align-items: center; gap: 4px;
    }
    .sidebar-no-interval i { font-size: 9px; }
</style>

<div class="Vert">
    <div class="Vert-full">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <div class="Order-Container-Title" style="margin-bottom:0;">
                Automaty cenowe @storeName
            </div>

            @if (canEdit)
            {
                <a asp-action="Create"
                   asp-route-storeId="@storeId"
                   asp-route-sourceType="@ViewBag.CurrentFilter"
                   class="Button-Action-Small">
                    Dodaj nową regułę
                </a>
            }
            else
            {
                <a href="#" onclick="showNoAccessAlert(); return false;"
                   class="Button-Action-Small" style="opacity:0.6; cursor:not-allowed;">
                    Dodaj nową regułę
                </a>
            }
        </div>

        <div id="sectionStandard" class="rules-scroll-container">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-robot fa-3x text-gray-300 mb-3"></i>
                    <p class="text-gray-500 mb-0">Brak zdefiniowanych reguł dla tego sklepu.</p>
                    <p class="text-gray-500">Kliknij "Dodaj nową regułę", aby rozpocząć.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    bool isComp = item.StrategyMode == AutomationStrategyMode.Competitiveness;

                    bool tl = item.IsTimeLimited;
                    DateTime? ss = item.ScheduledStartDate;
                    DateTime? se = item.ScheduledEndDate;
                    DateTime n = DateTime.Now;
                    bool dis = !item.IsActive;
                    string tLabel, tCls, tIcon;
                    string tExtra = "";
                    string dl(int x) => x == 1 ? "dzień" : "dni";
                    string tDates = "";

                    if (dis && tl) { tLabel = "Wyłączony"; tCls = "rb-time-disabled"; tIcon = "fa-power-off"; }
                    else if (!tl) { tLabel = "Bez limitu"; tCls = "rb-time-unlimited"; tIcon = "fa-infinity"; }
                    else if (ss.HasValue && se.HasValue)
                    {
                        tDates = $"{ss.Value:dd.MM} → {se.Value:dd.MM.yy}";
                        if (n.Date < ss.Value.Date) { int d = (int)(ss.Value.Date - n.Date).TotalDays; tLabel = "Oczekuje"; tCls = "rb-time-waiting"; tIcon = "fa-hourglass-start"; tExtra = $"za {d}{(d==1?"d":"d")}"; }
                        else if (n.Date > se.Value.Date) { int d = (int)(n.Date - se.Value.Date).TotalDays; tLabel = "Zakończony"; tCls = "rb-time-expired"; tIcon = "fa-hourglass-end"; tExtra = $"{d}d temu"; }
                        else { int dLeft = (int)(se.Value.Date - n.Date).TotalDays + 1; tLabel = "Aktywny"; tCls = "rb-time-active"; tIcon = "fa-hourglass-half"; tExtra = $"{dLeft}d"; }
                    }
                    else if (ss.HasValue)
                    {
                        tDates = $"{ss.Value:dd.MM} → ∞";
                        if (n.Date < ss.Value.Date) { int d = (int)(ss.Value.Date - n.Date).TotalDays; tLabel = "Oczekuje"; tCls = "rb-time-waiting"; tIcon = "fa-hourglass-start"; tExtra = $"za {d}d"; }
                        else { tLabel = "Aktywny"; tCls = "rb-time-active"; tIcon = "fa-play"; }
                    }
                    else if (se.HasValue)
                    {
                        tDates = $"— → {se.Value:dd.MM.yy}";
                        if (n.Date > se.Value.Date) { int d = (int)(n.Date - se.Value.Date).TotalDays; tLabel = "Zakończony"; tCls = "rb-time-expired"; tIcon = "fa-hourglass-end"; tExtra = $"{d}d temu"; }
                        else { int dLeft = (int)(se.Value.Date - n.Date).TotalDays + 1; tLabel = "Aktywny"; tCls = "rb-time-active"; tIcon = "fa-play"; tExtra = $"{dLeft}d"; }
                    }
                    else { tLabel = "Brak dat"; tCls = "rb-time-waiting"; tIcon = "fa-question-circle"; }

                    string stClass = item.IsActive ? "st-active" : "st-inactive";
                    string stLabel = item.IsActive ? "Aktywny" : "Wyłączony";
                    if (item.IsActive && tl)
                    {
                        if (tCls == "rb-time-waiting") { stClass = "st-waiting"; stLabel = "Oczekuje"; }
                        else if (tCls == "rb-time-expired") { stClass = "st-stopped"; stLabel = "Zatrzymany"; }
                    }

                    IntervalInfoDto intervalInfo = intervalLookup.ContainsKey(item.Id) ? intervalLookup[item.Id] : null;

                    <div class="rule-card" data-rule-id="@item.Id" data-sort-order="@item.SortOrder"
                         draggable="true"
                         onclick="if(!window._wasDragging) location.href='@Url.Action("Details", "PriceAutomation", new { id = item.Id })'">

                        @* ── LEWA: Główna treść ── *@
                        <div class="rule-main">
                            <div class="drag-handle" title="Przeciągnij aby zmienić kolejność"><i class="fas fa-grip-vertical"></i></div>
                            <div class="rule-color-bar" style="background-color:@item.ColorHex;"></div>
                            <div class="rule-info">
                                <div class="rule-title">@item.Name</div>
                                <div class="rule-meta">
                                    <div class="meta-item">
                                        @if (item.SourceType == AutomationSourceType.PriceComparison)
                                        {
                                            <i class="fas fa-globe"></i> <span>Porównywarki</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-shopping-cart"></i> <span>Marketplace</span>
                                        }
                                    </div>
                                    <div class="meta-dot"></div>
                                    <div class="meta-item">
                                        <span style="font-weight:700; color:#5a5c69;">@item.AssignedProductsCount</span>
                                        <span>produktów</span>
                                    </div>
                                </div>

                                <div class="rule-badges">
                                    @* Strategia *@
                                    <span class="rb @(isComp ? "rb-strategy-comp" : "rb-strategy-prof")">
                                        <i class="fas @(isComp ? "fa-bolt" : "fa-dollar-sign")"></i>
                                        @(isComp ? "Konkurencyjność" : "Rentowność")
                                    </span>

                                    @* Preset *@
                                    <span class="rb">
                                        <i class="fas fa-sliders-h"></i> @item.CompetitorPresetName
                                    </span>

                                    @* Harmonogram czasowy *@
                                    <span class="rb rb-time @tCls">
                                        <i class="fa-solid @tIcon"></i>
                                        @tLabel
                                        @if (!string.IsNullOrEmpty(tDates))
                                        {
                                            <span class="time-mini-dates">@tDates</span>
                                        }
                                        @if (!string.IsNullOrEmpty(tExtra))
                                        {
                                            <span class="time-mini-extra">(@tExtra)</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* ── PRAWA: Status automatu + Interwał ── *@
                        <div class="rule-sidebar">
                            <div class="sidebar-section">
                                <div class="sidebar-section-label">Automat</div>
                                <div class="sidebar-status-value @stClass">
                                    <i class="fas fa-circle"></i> @stLabel
                                </div>
                            </div>
                            <div class="sidebar-interval">
                                @if (intervalInfo != null)
                                {
                                    <div class="sidebar-section-label @(intervalInfo.IntervalIsActive ? "label-ivl-active" : "label-ivl-inactive")">
                                        Interwał @(intervalInfo.IntervalIsActive ? "Aktywny" : "Wyłączony")
                                    </div>

                                    <a href="@Url.Action("Details", "IntervalPrice", new { id = intervalInfo.IntervalId })"
                                       class="interval-chip interval-chip-exists"
                                       onclick="event.stopPropagation();"
                                       title="Otwórz interwał: @intervalInfo.IntervalName">
                                        <div class="interval-color-bar" style="background-color:@intervalInfo.IntervalColorHex;"></div>
                                        <i class="fas fa-clock" style="font-size:9px; color:#858796;"></i>
                                        <span style="max-width:100px; overflow:hidden; text-overflow:ellipsis;">@intervalInfo.IntervalName</span>
                                        @if (intervalInfo.Count > 1)
                                        {
                                            <span style="font-size:9px; color:#b7b9cc;">+@(intervalInfo.Count - 1)</span>
                                        }
                                    </a>
                                }
                                else
                                {
                                    <div class="sidebar-section-label">Interwał</div>

                                    if (canEdit)
                                    {
                                        <a href="@Url.Action("Create", "IntervalPrice", new { automationRuleId = item.Id })"
                                           class="interval-chip interval-chip-add"
                                           onclick="event.stopPropagation();"
                                           title="Dodaj interwał zmiany cen">
                                            <i class="fas fa-plus" style="font-size:8px;"></i>
                                            <i class="fas fa-clock" style="font-size:9px;"></i>
                                            Dodaj interwał
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="sidebar-no-interval">
                                            <i class="fas fa-clock"></i> Brak
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showNoAccessAlert() {
            alert('@Html.Raw(noAccessMessage)');
        }

        window._wasDragging = false;
        let dragSrcEl = null;

        document.addEventListener('DOMContentLoaded', function () {
            const container = document.getElementById('sectionStandard');
            if (!container) return;

            container.addEventListener('dragstart', function (e) {
                const card = e.target.closest('.rule-card');
                if (!card) return;
                const handle = card.querySelector('.drag-handle');
                if (handle) {
                    const rect = handle.getBoundingClientRect();
                    if (e.clientX < rect.left || e.clientX > rect.right || e.clientY < rect.top || e.clientY > rect.bottom) {
                        e.preventDefault();
                        return;
                    }
                }
                dragSrcEl = card;
                window._wasDragging = false;
                requestAnimationFrame(() => card.classList.add('dragging'));
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('text/plain', card.dataset.ruleId);
            });

            container.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                window._wasDragging = true;
                if (!dragSrcEl) return;
                const card = e.target.closest('.rule-card');
                if (!card || card === dragSrcEl) return;
                const rect = card.getBoundingClientRect();
                if (e.clientY < rect.top + rect.height / 2) {
                    if (card.previousElementSibling !== dragSrcEl) container.insertBefore(dragSrcEl, card);
                } else {
                    if (card.nextElementSibling !== dragSrcEl) container.insertBefore(dragSrcEl, card.nextSibling);
                }
            });

            container.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                if (dragSrcEl) { dragSrcEl.classList.remove('dragging'); saveSortOrder(); }
                dragSrcEl = null;
            });

            container.addEventListener('dragend', function () {
                if (dragSrcEl) dragSrcEl.classList.remove('dragging');
                dragSrcEl = null;
                setTimeout(() => { window._wasDragging = false; }, 100);
            });
        });

        function saveSortOrder() {
            const cards = document.querySelectorAll('#sectionStandard .rule-card');
            const total = cards.length;
            const items = [];
            cards.forEach((card, index) => {
                items.push({ Id: parseInt(card.dataset.ruleId), Position: total - index });
            });
            fetch('@Url.Action("UpdateSortOrder", "AutomationRules")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(items)
            }).catch(err => console.error('Błąd zapisu kolejności:', err));
        }
    </script>
}