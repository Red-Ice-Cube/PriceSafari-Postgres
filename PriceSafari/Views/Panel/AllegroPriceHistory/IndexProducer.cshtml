@using Newtonsoft.Json
@using PriceSafari.Models.ViewModels

@{
    ViewBag.Title = "Panel Producenta Allegro - " + ViewBag.StoreName;
    var latestScrap = ViewBag.LatestScrap as PriceSafari.Models.AllegroScrapeHistory;
    var storeId = ViewBag.StoreId;
    var storeLogo = ViewBag.StoreLogo;
    var storeName = ViewBag.StoreName;
    var scrapDate = latestScrap?.Date.ToString("dd.MM.yyyy");
    var flags = ViewBag.Flags as List<FlagViewModel>;
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<style>
    /* ─── Box szczegółów naruszenia (renderowany przez JS między ceną konkurenta a referencyjną) ─── */
    .violation-detail-box {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .violation-detail-header {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
        font-size: 14px;
    }

    .violation-detail-icon {
        font-size: 16px;
        width: 20px;
        text-align: center;
    }

    .violation-detail-meta {
        font-size: 13px;
        color: #555;
        line-height: 1.4;
    }

    .violation-duration-large {
        font-size: 17px;
        font-weight: 500;
        color: #212529;
    }

    /* Stany naruszenia — etykietki/badge */
    .violation-state-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.2px;
    }

    .violation-state-fresh {
        background: #fff4d6;
        color: #8a5a00;
        border: 1px solid #f0c674;
    }

    .violation-state-active {
        background: #fbe1e1;
        color: #8b1a1a;
        border: 1px solid #e89595;
    }

    .violation-state-ended {
        background: #e7eaee;
        color: #495057;
        border: 1px solid #c4cbd2;
    }

    .violation-state-clean {
        background: #dff3e2;
        color: #1e5a2a;
        border: 1px solid #a3d4ad;
    }

    .violation-state-no-ref {
        background: #f1f0fa;
        color: #5b537a;
        border: 1px solid #c8c2dd;
    }

    /* Drobny pasek czasu pod statusem */
    .violation-time-bar {
        position: relative;
        height: 4px;
        background: #e9ecef;
        border-radius: 2px;
        overflow: hidden;
        margin-top: 2px;
    }

    .violation-time-bar-fill {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: #c83333;
        border-radius: 2px;
    }

        .violation-time-bar-fill.fresh {
            background: #d49a1a;
        }

        .violation-time-bar-fill.ended {
            background: #8d949b;
        }

    /* Drobne formatowanie dla bloków sprzedaży 30 dni */
    .producer-sales-line {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
</style>

