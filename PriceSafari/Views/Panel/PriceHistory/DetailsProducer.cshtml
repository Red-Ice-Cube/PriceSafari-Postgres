@model IEnumerable<PriceSafari.Models.PriceHistoryClass>

@{
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    ViewData["Title"] = "Szczegóły Produktu – Panel Producenta";

    var storeId         = ViewBag.StoreId;
    var scrapHistory    = ViewBag.ScrapHistory as PriceSafari.Models.ScrapHistoryClass;
    var productName     = ViewBag.ProductName as string;
    var storeName       = ViewBag.StoreName as string;
    var url             = ViewBag.Url;
    var googleUrl       = ViewBag.GoogleUrl;
    var externalUrl     = ViewBag.ExternalUrl as string;
    var img             = ViewBag.Img as string;
    var ean             = ViewBag.Ean as string;
    var sku             = ViewBag.Sku as string;
    var externalId      = ViewBag.ExternalId as int?;
    var totalOffers     = Model.Count();
    var googleOffers    = Model.Count(x => x.IsGoogle == true);
    var ceneoOffers     = totalOffers - googleOffers;
    var hasAnyStoreLinks = Model.Any(x => !string.IsNullOrEmpty(x.GoogleOfferUrl));

    decimal? referencePrice = ViewBag.ReferencePrice as decimal?;
    string referenceSource  = ViewBag.ReferenceSource as string ?? "none";
    decimal? mapPrice       = ViewBag.MapPrice as decimal?;
    bool isMapMode          = referenceSource == "map";

    var producerRowBuckets    = ViewBag.ProducerRowBuckets    as Dictionary<int, string> ?? new Dictionary<int, string>();
    var producerRowDeltas     = ViewBag.ProducerRowDeltas     as Dictionary<int, (decimal? deltaAbs, decimal? deltaPct)> ?? new Dictionary<int, (decimal?, decimal?)>();
    var producerRowIsOwnStore = ViewBag.ProducerRowIsOwnStore as Dictionary<int, bool>   ?? new Dictionary<int, bool>();
    var producerRowIsHidden   = ViewBag.ProducerRowIsHidden   as Dictionary<int, bool>   ?? new Dictionary<int, bool>();
    var producerThresholdsJson = ViewBag.ProducerThresholdsJson as string ?? "{}";

    var flags                   = ViewBag.Flags as List<PriceSafari.Models.ViewModels.FlagViewModel> ?? new List<PriceSafari.Models.ViewModels.FlagViewModel>();
    var productFlagIds          = ViewBag.ProductFlagIds as List<int> ?? new List<int>();
    var automationRuleName      = ViewBag.AutomationRuleName as string;
    var automationRuleColor     = ViewBag.AutomationRuleColor as string;
    var automationRuleIsActive  = (bool)(ViewBag.AutomationRuleIsActive ?? false);
    var automationRuleId        = ViewBag.AutomationRuleId as int?;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<style>
    .ref-info-inline {
        vertical-align: middle;
        font-size: 13px;
        color: #333;
    }

        .ref-info-inline .ref-price-bold {
            font-weight: 700;
            margin-left: 4px;
        }

        .ref-info-inline .ref-tag {
            font-size: 10px;
            padding: 1px 5px;
            border-radius: 3px;
            background: #e0e7ff;
            color: #3b5bdb;
            font-weight: 500;
            margin-left: 4px;
            vertical-align: middle;
        }
</style>

<div class="Vert" data-store-name="@storeName">
    <div class="Page-Box">

        <div class="detail-header-row">
            <div class="detail-title-block">
                <div class="detail-title-text">@productName</div>
                <div class="detail-flags-row" id="detailFlagsContainer">
                    @foreach (var flag in flags.Where(f => productFlagIds.Contains(f.FlagId)))
                    {
                        <span class="detail-flag-pill"
                              style="border-color: @flag.FlagColor; color: @flag.FlagColor; background-color: @(flag.FlagColor)4D; white-space: nowrap; font-size: 12px; padding: 2px 8px; border-radius: 4px; border: 1px solid;">
                            @flag.FlagName
                        </span>
                    }
                </div>
            </div>
            <div class="detail-mode-switch">
                <button type="button" id="showTableBtn" class="button-active">Ranking</button>
                <button type="button" id="showChartBtn" class="button-inactive">Wykres</button>
            </div>
        </div>

        <div class="form-check-orders">
            <div class="info-row">
                <p><strong>Wykonano</strong>&nbsp;@scrapHistory?.Date.ToString("dd.MM.yyyy")</p>
                @if (externalId.HasValue)
                {
                    <span class="separator">|</span>
                    <span><strong>ID</strong>&nbsp;@externalId</span>
                }
                @if (!string.IsNullOrEmpty(sku))
                {
                    <span class="separator">|</span>
                    <span><strong>SKU</strong>&nbsp;@sku</span>
                }
                @if (!string.IsNullOrEmpty(ean))
                {
                    <span class="separator">|</span>
                    <span><strong>EAN</strong>&nbsp;@ean</span>
                }

                <span class="separator">|</span>
                @if (isMapMode && mapPrice.HasValue && mapPrice.Value > 0)
                {
                    <span class="ref-info-inline">
                        Punkt odniesienia: Cena MAP
                        <span class="ref-price-bold">@mapPrice.Value.ToString("0.00") PLN</span>
                        <span class="ref-tag">REF</span>
                    </span>
                }
                else if (referenceSource == "store" && referencePrice.HasValue && referencePrice.Value > 0)
                {
                    <span class="ref-info-inline">
                        Punkt odniesienia: Cena Rynkowa
                        <span class="ref-price-bold">@referencePrice.Value.ToString("0.00") PLN</span>
                        <span class="ref-tag">REF</span>
                    </span>
                }
                else
                {
                    <span class="ref-info-inline" style="color:#868e96;">
                        Brak ceny referencyjnej
                    </span>
                }
            </div>
        </div>

        <div id="rankingOnlyArea" class="ranking-only-section">
            <div class="ranking-info-block">
                @if (!string.IsNullOrEmpty(img))
                {
                    <div style="display:flex;">
                        <img src="@img" style="height: 110px; width: 110px;" />
                    </div>
                }
                <div class="price-box-column-name ranking-actions-column">
                    <div class="store-section">
                        <div class="form-check">
                            <input class="form-check-input sortFilter" type="radio" name="sortOption" id="sortPrice" value="price" checked>
                            <label class="form-check-label" for="sortPrice">Sortuj po cenie</label>
                        </div>
                        @if (googleOffers > 0 && ceneoOffers > 0)
                        {
                            <div class="form-check">
                                <input class="form-check-input sortFilter" type="radio" name="sortOption" id="sortPosition" value="position">
                                <label class="form-check-label" for="sortPosition">Sortuj po pozycji Ceneo</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input sortFilter" type="radio" name="sortOption" id="sortGooglePosition" value="googlePosition">
                                <label class="form-check-label" for="sortGooglePosition">Sortuj po pozycji Google</label>
                            </div>
                        }
                        else if (googleOffers == totalOffers)
                        {
                            <div class="form-check">
                                <input class="form-check-input sortFilter" type="radio" name="sortOption" id="sortGooglePosition" value="googlePosition">
                                <label class="form-check-label" for="sortGooglePosition">Sortuj po pozycji Google</label>
                            </div>
                        }
                        else if (ceneoOffers == totalOffers)
                        {
                            <div class="form-check">
                                <input class="form-check-input sortFilter" type="radio" name="sortOption" id="sortPosition" value="position">
                                <label class="form-check-label" for="sortPosition">Sortuj po pozycji Ceneo</label>
                            </div>
                        }
                    </div>

                    <div class="ranking-actions-row">
                        <button type="button" class="Button-Page-Small" id="detailManageBtn">
                            <i class="fa-solid fa-sliders"></i> Zarządzaj
                        </button>
                        <button type="button" class="Button-Page-Small" id="presetButton" style="white-space: nowrap;" onclick="openCompetitorsModal()">
                            <span id="activePresetDisplay">Presety - @(ViewBag.ActivePresetName as string ?? "Widok PriceSafari")</span>
                        </button>
                        @if (!string.IsNullOrEmpty(googleUrl?.ToString()))
                        {
                            <a href="@googleUrl" class="Button-Page-Small" target="_blank">
                                <img src="~/images/GoogleShopping.png" alt="" style="width:18px; height:18px;" /> Google
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(url?.ToString()))
                        {
                            <a href="@url" class="Button-Page-Small" target="_blank">
                                <img src="~/images/Ceneo.png" alt="" style="width:18px; height:18px;" /> Ceneo
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(externalUrl))
                        {
                            <a href="@externalUrl" class="Button-Page-Small" target="_blank">
                                <img src="~/images/Click-b.svg" alt="" style="width:20px; height:20px;" /> Strona
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(automationRuleName))
                        {
                            var isPaused    = ViewBag.IsAutomationPaused as bool? ?? false;
                            var statusColor = isPaused ? "#f6c23e" : (automationRuleIsActive ? "#1cc88a" : "#e74a3b");
                            <span class="detail-automation-badge-v2 automation-link-btn"
                                  data-url="@Url.Action("Details", "PriceAutomation", new { id = automationRuleId })"
                                  data-product-id="@ViewBag.ProductId"
                                  style="cursor:pointer;">
                                <span class="detail-automation-color-bar" style="background-color:@automationRuleColor;"></span>
                                <span class="detail-automation-name">@automationRuleName</span>
                                <span class="detail-automation-sep">|</span>
                                <span class="detail-automation-status-dot" style="background-color:@statusColor;"></span>
                            </span>
                        }
                    </div>
                </div>
            </div>
            <div class="ranking-bar-chart-wrap">
                <canvas id="priceChart" width="100" height="100"></canvas>
            </div>
        </div>

        <div id="priceTableContainer" class="Vert-table" style="display: block; margin-top:6px;">
            <table class="table-orders" id="priceTable">
                <thead>
                    <tr>
                        <th></th>
                        <th id="storeHeader">Sklep (@totalOffers)</th>
                        <th>Cena</th>
                        <th>Delta vs ref.</th>
                        <th>Pozycja</th>
                        <th>Odznaki</th>
                        <th>Koszt wysyłki</th>
                        <th>Dostępność</th>
                        <th>Źródło</th>
                        @if (hasAnyStoreLinks) { <th></th> }
                    </tr>
                </thead>
                <tbody>
                    @{ int rowIndex = 0; }
                    @foreach (var item in Model)
                    {
                        bool isHidden = producerRowIsHidden.GetValueOrDefault(rowIndex, false);
                        if (isHidden) { rowIndex++; continue; }
                        var bucket     = producerRowBuckets.GetValueOrDefault(rowIndex, "producer-no-reference");
                        var deltas     = producerRowDeltas.GetValueOrDefault(rowIndex, (null, null));
                        bool isOwnStore = producerRowIsOwnStore.GetValueOrDefault(rowIndex, false);
                        string sortPrice = (isOwnStore && referencePrice.HasValue)
                            ? referencePrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
                            : item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        string badgeBgClass = bucket switch
                        {
                            "producer-deep-violation" => "producer-bg-deep-violation",
                            "producer-violation"      => "producer-bg-violation",
                            "producer-minor-below"    => "producer-bg-minor-below",
                            "producer-equal"          => "producer-bg-equal",
                            "producer-minor-above"    => "producer-bg-minor-above",
                            "producer-above"          => "producer-bg-above",
                            "producer-deep-above"     => "producer-bg-deep-above",
                            _                         => "producer-bg-no-reference"
                        };
                        <tr class="price-row @bucket"
                            data-store-name="@item.StoreName"
                            data-price="@sortPrice"
                            data-position="@item.Position">
                            <td><div class="color-bar @bucket"></div></td>
                            <td class="store-name" style="@(isOwnStore ? "font-weight:bold;" : "")">@item.StoreName</td>
                            <td class="store-price" style="@(isOwnStore ? "font-weight:bold;" : "")">
                                @if (isOwnStore && referencePrice.HasValue)
                                {
                                    @referencePrice.Value.ToString("0.00")
                                    <text> PLN</text>
                                    <span style="font-size:10px;padding:1px 5px;border-radius:3px;background:#e0e7ff;color:#3b5bdb;font-weight:500;margin-left:4px;vertical-align:middle;">REF</span>
                                }
                                else
                                {
                                    @item.Price.ToString("0.00")
                                    <text> PLN</text>
                                }
                            </td>
                            <td>
                                @if (deltas.deltaAbs.HasValue)
                                {
                                    var s  = deltas.deltaAbs.Value >= 0 ? "+" : "";
                                    var sp = deltas.deltaPct.HasValue ? (deltas.deltaPct.Value >= 0 ? "+" : "") : "";
                                    <span class="producer-delta-badge @badgeBgClass">
                                        @s@deltas.deltaAbs.Value.ToString("0.00") PLN (@sp@(deltas.deltaPct?.ToString("0.00") ?? "?")%)
                                    </span>
                                }
                                else
                                {
                                    <span style="color:#bbb;font-size:12px;">—</span>
                                }
                            </td>
                            <td>
                                @if (item.Position != null)
                                {
                                    if (item.IsGoogle == true) { <div class="Position-Google">Poz. Google @item.Position</div> }
                                    else { <div class="Position">Poz. Ceneo @item.Position</div> }
                                }
                                else
                                {
                                    <div class="Position" style="background-color:#414141;">Schowany</div>
                                }
                            </td>
                            <td>
                                @if (item.IsBidding == "1") { <div class="Bidding">Bid</div> }
                                else if (item.IsBidding == "bpg") { <div class="Bidding" style="background-color:#0F9D58;border-color:#0F9D58;">Odz. ceny Google</div> }
                                else if (item.IsBidding == "hpg") { <div class="Bidding" style="background-color:#4285F4;border-color:#4285F4;">Popularne</div> }
                            </td>
                            <td>
                                @if (item.ShippingCostNum == null) { <div class="BD">Brak danych</div> }
                                else if (item.ShippingCostNum == 0) { <div class="FreeShipping">Free</div> }
                                else { <div class="PaidShipping">@item.ShippingCostNum PLN</div> }
                            </td>
                            <td>
                                @{ bool? sv = item.IsGoogle ? item.GoogleInStock : item.CeneoInStock; }
                                @if (sv == true) { <span class="stock-available">Dostępny</span> }
                                else if (sv == false) { <span class="stock-unavailable">Niedostępny</span> }
                                else { <span class="BD">Brak danych</span> }
                            </td>
                            <td class="data-chanel">
                                <img src="@Url.Content(item.IsGoogle ? "~/images/GoogleShopping.png" : "~/images/Ceneo.png")"
                                     alt="" style="width:24px;height:24px;" />
                            </td>
                            @if (hasAnyStoreLinks)
                            {
                                <td style="text-align:right;white-space:nowrap;">
                                    @if (!string.IsNullOrEmpty(item.GoogleOfferUrl))
                                    {
                                        <a href="@item.GoogleOfferUrl" target="_blank" class="Button-Page-Small" style="text-decoration:none;padding:2px 8px;font-size:11px;">
                                            <i class="fas fa-external-link-alt" style="margin-right:4px;"></i>Link
                                        </a>
                                    }
                                    else if (!item.IsGoogle && !string.IsNullOrEmpty(url?.ToString()))
                                    {
                                        <a href="@url" target="_blank" class="Button-Page-Small" style="text-decoration:none;padding:2px 8px;font-size:11px;">
                                            <i class="fas fa-external-link-alt" style="margin-right:4px;"></i>Link
                                        </a>
                                    }
                                </td>
                            }
                        </tr>
                        rowIndex++;
                    }
                </tbody>
            </table>
        </div>

        <div id="trendChartContainer" class="chart-view-wrap">

            <div class="chart-toolbar">
                <div class="chart-toolbar-left">
                    <div class="period-selector-group">
                        @foreach (var d in new[] { 7, 14, 30, 60, 90, 120, 240, 360 })
                        {
                            <button type="button" class="period-btn-custom history-btn @(d == 30 ? "active" : "")" data-days="@d">
                                @d Analiz
                            </button>
                        }
                    </div>
                </div>
                <div class="chart-toolbar-right">
                    <div class="chart-slider-group">
                        <label>Linie</label>
                        <input type="range" id="grayAlphaRange" min="0" max="0.6" step="0.01" value="0.15">
                    </div>
                    <div class="chart-slider-group" id="bandIntensityGroup">
                        <label>Progi</label>
                        <input type="range" id="bandIntensityRange" min="0" max="2.5" step="0.05" value="0.4">
                    </div>
                    <button type="button" id="exportExcelBtn" class="Button-Page-Small" title="Eksportuj do Excela">
                        <i class="fas fa-file-excel" style="margin-right:5px;"></i> Excel
                    </button>
                </div>
            </div>

            <div class="chart-main">
                <div class="chart-area">
                    <div id="trendChart"></div>
                </div>
                <div id="customTrendTooltip" class="chart-side-panel"></div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/PartialViewsPanel/_PresetyPriceComparison.cshtml")
@await Html.PartialAsync("~/Views/Shared/PartialViewsPanel/_MassAction.cshtml")

<div id="loadingOverlay" class="loading-overlay" style="display: none;">
    <div class="loader"></div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/exceljs/4.3.0/exceljs.min.js"></script>
<script>Chart.register(window['chartjs-plugin-annotation']);</script>

<script>
    var priceHistoryPageContext = 'details';
    var storeId = '@storeId';
    const presetTypeContext = 0;
</script>
<script src="~/js/member/Presets.js"></script>
<script src="~/js/member/MassActions.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var detailProductId = @ViewBag.ProductId;

        var detailMassActions = MassActions({
            storeId:    @ViewBag.StoreId,
            isAllegro:  false,
            storageKey: 'massaction_detail_store_@(ViewBag.StoreId)',
            flags:      @Html.Raw(System.Text.Json.JsonSerializer.Serialize(flags.Select(f => new { flagId = f.FlagId, flagName = f.FlagName, flagColor = f.FlagColor }))),

            getAllPrices: function () {
                return [{
                    productId:   detailProductId,
                    productName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ProductName as string))
                }];
            },
            getFilteredPrices: function () {
                return [{
                    productId:   detailProductId,
                    productName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ProductName as string))
                }];
            },
            getProductIdentifier: function () {
                return {
                    label: 'EAN',
                    value: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Ean as string ?? ""))
                };
            },

            showLoading: function () {
                var e = document.getElementById('loadingOverlay');
                if (e) e.style.display = 'flex';
            },
            hideLoading: function () {
                var e = document.getElementById('loadingOverlay');
                if (e) e.style.display = 'none';
            },
            showGlobalUpdate: function () {},
            showGlobalNotification: function (m) { alert('Błąd: ' + m); },
            onFlagsUpdated:       function () { location.reload(); },
            onAutomationsUpdated: function () { location.reload(); }
        });

        detailMassActions.init();

        document.getElementById('detailManageBtn').addEventListener('click', function () {
            detailMassActions.clearSelection();
            detailMassActions.addProduct(detailProductId);
            detailMassActions.updateSelectionUI();
            $('#selectedProductsModal').modal('show');
        });
    });
</script>

<script>
    // ─── Bar chart (mini, w widoku Ranking) ────────────────────────────────
    var pricesData = @Html.Raw(ViewBag.PricesDataJson ?? "[]");
    var chart;
    var producerThresholds = @Html.Raw(producerThresholdsJson);
    var isMapMode = @Html.Raw(isMapMode ? "true" : "false");

    var bucketBarColors = {
        'producer-deep-violation': 'rgba(139,0,0,0.78)',
        'producer-violation':      'rgba(220,20,60,0.78)',
        'producer-minor-below':    'rgba(255,99,71,0.78)',
        'producer-equal':          'rgba(65,105,225,0.78)',
        'producer-minor-above':    'rgba(144,238,144,0.85)',
        'producer-above':          'rgba(34,139,34,0.78)',
        'producer-deep-above':     'rgba(0,100,0,0.82)',
        'producer-no-reference':   'rgba(187,187,187,0.7)'
    };

    function getBucketForPrice(price, ref) {
        if (!ref || ref <= 0) return 'producer-no-reference';
        var d  = price - ref;
        var dp = (d / ref) * 100;
        var t  = producerThresholds;
        var u  = t.useAmount;
        var v  = u ? d : dp;
        if (v <= -(u ? t.redDarkAmt   : t.redDarkPct))   return 'producer-deep-violation';
        if (v <= -(u ? t.redAmt       : t.redPct))       return 'producer-violation';
        if (v <= -(u ? t.redLightAmt  : t.redLightPct))  return 'producer-minor-below';
        if (v <  (u ? t.greenLightAmt : t.greenLightPct)) return 'producer-equal';
        if (v <  (u ? t.greenAmt      : t.greenPct))      return 'producer-minor-above';
        if (v <  (u ? t.greenDarkAmt  : t.greenDarkPct))  return 'producer-above';
        return 'producer-deep-above';
    }

    document.addEventListener("DOMContentLoaded", function () {
        var rows     = Array.from(document.querySelectorAll(".price-row"));
        var myNorm   = document.querySelector(".Vert").getAttribute("data-store-name").toLowerCase().trim();
        var headerEl = document.getElementById("storeHeader");

        function highlightOwn() {
            rows.forEach(function (r) {
                var isMine = r.getAttribute("data-store-name").toLowerCase().trim() === myNorm;
                r.querySelector(".store-name").style.fontWeight  = isMine ? "bold" : "normal";
                r.querySelector(".store-price").style.fontWeight = isMine ? "bold" : "normal";
            });
        }
        function sortByPrice() {
            rows.forEach(function (r) { r.style.display = ''; });
            rows.sort(function (a, b) {
                var pA = parseFloat(a.getAttribute("data-price")) || Infinity;
                var pB = parseFloat(b.getAttribute("data-price")) || Infinity;
                return pA !== pB ? pA - pB : a.getAttribute("data-store-name").localeCompare(b.getAttribute("data-store-name"));
            });
            var tb = document.querySelector("#priceTable tbody");
            rows.forEach(function (r) { tb.appendChild(r); });
            headerEl.textContent = "Sklep (" + rows.length + ")";
            highlightOwn();
        }
        function sortByCeneo() {
            var f = rows.filter(function (r) { return !r.querySelector(".Position-Google"); });
            f.sort(function (a, b) {
                return (parseInt(a.getAttribute("data-position")) || Infinity)
                     - (parseInt(b.getAttribute("data-position")) || Infinity);
            });
            rows.forEach(function (r) { r.style.display = f.indexOf(r) === -1 ? 'none' : ''; });
            var tb = document.querySelector("#priceTable tbody");
            f.forEach(function (r) { tb.appendChild(r); });
            headerEl.textContent = "Sklep (" + f.length + " - Ceneo)";
            highlightOwn();
        }
        function sortByGoogle() {
            var f = rows.filter(function (r) { return r.querySelector(".Position-Google"); });
            f.sort(function (a, b) {
                return (parseInt(a.getAttribute("data-position")) || Infinity)
                     - (parseInt(b.getAttribute("data-position")) || Infinity);
            });
            rows.forEach(function (r) { r.style.display = f.indexOf(r) === -1 ? 'none' : ''; });
            var tb = document.querySelector("#priceTable tbody");
            f.forEach(function (r) { tb.appendChild(r); });
            headerEl.textContent = "Sklep (" + f.length + " - Google)";
            highlightOwn();
        }

        document.getElementById("sortPrice").addEventListener("click", sortByPrice);
        if (document.getElementById("sortPosition")) {
            document.getElementById("sortPosition").addEventListener("click", sortByCeneo);
        }
        if (document.getElementById("sortGooglePosition")) {
            document.getElementById("sortGooglePosition").addEventListener("click", sortByGoogle);
        }
        sortByPrice();
        highlightOwn();

        // ── Bar chart (mini, tylko w widoku Ranking) ──
        var sorted = pricesData.sort(function (a, b) { return b.price - a.price; });
        var ref    = producerThresholds.referencePrice;
        var colors = sorted.map(function (i) {
            return i.store.toLowerCase().trim() === myNorm
                ? bucketBarColors['producer-equal']
                : (bucketBarColors[getBucketForPrice(i.price, ref)] || 'rgba(34,34,34,0.4)');
        });
        var ann = {};
        if (ref && ref > 0) {
            ann.refLine = {
                type: 'line',
                yMin: ref, yMax: ref,
                borderColor: 'rgba(65,105,225,0.8)',
                borderWidth: 2,
                borderDash: [6, 3],
                label: {
                    display: true,
                    content: (isMapMode ? 'MAP ' : 'REF ') + ref.toFixed(2),
                    position: 'start',
                    backgroundColor: 'rgba(65,105,225,0.85)',
                    color: '#fff',
                    font: { size: 10 }
                }
            };
        }
        var ctx = document.getElementById('priceChart').getContext('2d');
        chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: sorted.map(function (i) { return i.store; }),
                datasets: [{
                    label: 'Cena PLN',
                    data: sorted.map(function (i) { return i.price; }),
                    backgroundColor: colors,
                    borderColor: colors.map(function (c) { return c.replace(/[\d.]+\)$/, '1)'); }),
                    borderWidth: 2,
                    borderRadius: 2
                }]
            },
            options: {
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, ticks: { display: false } },
                    x: { display: false }
                },
                plugins: {
                    legend: { display: false },
                    annotation: { annotations: ann },
                    title: {
                        display: true,
                        text: 'Cena (PLN)',
                        position: 'top',
                        align: 'start',
                        font: { size: 12, weight: 'bold' }
                    }
                }
            }
        });
    });
</script>

<script>


    var productId           = @ViewBag.ProductId;
    var myStoreLower        = "@storeName".toLowerCase().trim();
    var lastHoverParams     = null;
    var currentHistoryLimit = 30;

    var highlightedStores     = [];
    var storeColorMap         = {};
    var lastHighlightedStore  = null;
    var hiddenStores          = [];


    var highlightColors = [
        'rgba(255,128,0,1)',    // Orange 500
        'rgba(76,175,80,1)',    // Green 500
        'rgba(156,39,176,1)',   // Purple 500
        'rgba(244,67,54,1)',    // Red 500
        'rgba(0,150,136,1)',    // Teal 500
        'rgba(255,193,7,1)',    // Amber 500
        'rgba(0,188,212,1)',    // Cyan 500
        'rgba(118,255,3,1)',    // Light Green A400 (lime)
        'rgba(121,85,72,1)',    // Brown 500
        'rgba(233,30,99,1)'     // Pink 500
    ];

    var myStoreColor          = 'rgba(54, 162, 235, 1)';   
    var mapRefColor           = 'rgba(65, 105, 225, 1)';   
    var DEFAULT_MARKER_SOLID  = 'rgba(34,34,34,0.9)';    

    var UNIFORM_LINE_WIDTH          = 2.3;
    var UNIFORM_EMPHASIS_LINE_WIDTH = 2.3;

    var defaultGrayAlpha = 0.15;
    var bandIntensity    = 0.4;

    var echartsTrendChart   = null;
    var currentTimelineData = null;
    var currentChartOptions = null;
    var trendIsMapMode      = false;
    var trendThresholds     = {};
    var producerRefByDate   = {};   

    var defaultCustomTooltipContent = 'Najedź na punkt na wykresie...';

 
    var Z_BAND            = 0;
    var Z_BOUNDARY        = 2;
    var Z_NORMAL          = 5;
    var Z_HIGHLIGHT_BASE  = 10;
    var Z_HIGHLIGHT_STEP  = 4;
    var Z_MAIN_OUTLINE    = 100;
    var Z_MAIN_LINE       = 102;
    var Z_MAP_REF         = 110;


    var BAND_DEFS = [
        { r: 139, g: 0,   b: 0,   baseA: 0.22, label: 'Drastyczne naruszenie' },
        { r: 220, g: 20,  b: 60,  baseA: 0.20, label: 'Naruszenie' },
        { r: 255, g: 99,  b: 71,  baseA: 0.18, label: 'Lekko poniżej' },
        { r: 65,  g: 105, b: 225, baseA: 0.15, label: 'Cena zgodna' },
        { r: 144, g: 238, b: 144, baseA: 0.20, label: 'Lekko powyżej' },
        { r: 34,  g: 139, b: 34,  baseA: 0.22, label: 'Powyżej' },
        { r: 0,   g: 100, b: 0,   baseA: 0.20, label: 'Mocno powyżej' }
    ];

  
    var _bucketToBandIdx = {
        'producer-deep-violation': 0,
        'producer-violation':      1,
        'producer-minor-below':    2,
        'producer-equal':          3,
        'producer-minor-above':    4,
        'producer-above':          5,
        'producer-deep-above':     6
    };
   
    var _lightBandIdx = { 4: true };

    function getBucketBadgeColors(bucket) {
        var i = _bucketToBandIdx[bucket];
        if (i == null) return { bg: 'rgba(187,187,187,0.85)', fg: '#fff', border: 'rgba(120,120,120,0.6)' };
        var d = BAND_DEFS[i];
        var isLight = !!_lightBandIdx[i];
        return {
            bg:     'rgba(' + d.r + ',' + d.g + ',' + d.b + ',0.92)',
            fg:     isLight ? '#1a1a1a' : '#fff',
            border: 'rgba(' + Math.max(0, d.r - 30) + ',' + Math.max(0, d.g - 30) + ',' + Math.max(0, d.b - 30) + ',0.85)'
        };
    }

    function getProducerBucketForPrice(price, ref) {
        if (!ref || ref <= 0 || price == null) return 'producer-no-reference';
        var d  = price - ref;
        var dp = (d / ref) * 100;
        var t  = trendThresholds;
        var u  = t.useAmount;
        var v  = u ? d : dp;
        if (v <= -(u ? t.redDarkAmt   : t.redDarkPct))   return 'producer-deep-violation';
        if (v <= -(u ? t.redAmt       : t.redPct))       return 'producer-violation';
        if (v <= -(u ? t.redLightAmt  : t.redLightPct))  return 'producer-minor-below';
        if (v <  (u ? t.greenLightAmt : t.greenLightPct)) return 'producer-equal';
        if (v <  (u ? t.greenAmt      : t.greenPct))      return 'producer-minor-above';
        if (v <  (u ? t.greenDarkAmt  : t.greenDarkPct))  return 'producer-above';
        return 'producer-deep-above';
    }

 
    var stripePatternCache = {};
    function invalidateStripePatterns() { stripePatternCache = {}; }


    function makeStripePattern(idx) {
        if (stripePatternCache[idx]) return stripePatternCache[idx];
        var d = BAND_DEFS[idx];
        var TILE = 8;

        var isDeepZone = (idx === 0 || idx === 6);
        var intensityBoost = isDeepZone ? 1.75 : 1.0;

        var canvas = document.createElement('canvas');
        canvas.width = TILE;
        canvas.height = TILE;
        var ctx = canvas.getContext('2d');

        var bgCap = isDeepZone ? 0.22 : 0.10;
        var bgAlpha = Math.min(bgCap, d.baseA * 0.22 * bandIntensity * intensityBoost);
        ctx.fillStyle = 'rgba(' + d.r + ',' + d.g + ',' + d.b + ',' + bgAlpha.toFixed(3) + ')';
        ctx.fillRect(0, 0, TILE, TILE);

      
        var lineCap = isDeepZone ? 0.95 : 0.85;
        var lineAlpha = Math.min(lineCap, 0.42 * bandIntensity * intensityBoost);
        ctx.strokeStyle = 'rgba(' + d.r + ',' + d.g + ',' + d.b + ',' + lineAlpha.toFixed(3) + ')';
        ctx.lineWidth = isDeepZone ? 1.2 : 1;
        ctx.lineCap = 'square';
        ctx.beginPath();
        ctx.moveTo(0, TILE);
        ctx.lineTo(TILE, 0);
        ctx.stroke();

        stripePatternCache[idx] = canvas;
        return canvas;
    }

    function makeCenaZgodnaWash() {
        var d = BAND_DEFS[3];
        var alpha = Math.min(0.20, d.baseA * 0.55 * bandIntensity);
        return 'rgba(' + d.r + ',' + d.g + ',' + d.b + ',' + alpha.toFixed(3) + ')';
    }

    function bandFillForBandIdx(i) {
        if (i === 3) return makeCenaZgodnaWash();
        return { image: makeStripePattern(i), repeat: 'repeat' };
    }

  
    function boundaryLineStyle(bandIdx) {
        var d = BAND_DEFS[bandIdx];
        var isRefBoundary   = (bandIdx === 3 || bandIdx === 4);
        var isOuterBoundary = (bandIdx === 0 || bandIdx === 6);

        var alpha, width, type;
        if (isRefBoundary) {
            alpha = Math.min(0.95, 0.85 * bandIntensity);
            width = 1.8;
            type  = 'solid';
        } else if (isOuterBoundary) {
            alpha = Math.min(0.90, 0.70 * bandIntensity);
            width = 1.3;
            type  = [6, 4];
        } else {
            alpha = Math.min(0.85, 0.60 * bandIntensity);
            width = 1.2;
            type  = [6, 4];
        }
        return {
            color: 'rgba(' + d.r + ',' + d.g + ',' + d.b + ',' + alpha.toFixed(3) + ')',
            width: width,
            type:  type
        };
    }

    function calcBoundaries(ref, t) {
        if (!ref || ref <= 0) return null;
        var u = t.useAmount;
        function off(v, dir) { return u ? (dir > 0 ? v : -v) : ref * (dir > 0 ? v / 100 : -v / 100); }
        var rdk = u ? t.redDarkAmt    : t.redDarkPct;
        var rk  = u ? t.redAmt        : t.redPct;
        var rlk = u ? t.redLightAmt   : t.redLightPct;
        var glk = u ? t.greenLightAmt : t.greenLightPct;
        var gk  = u ? t.greenAmt      : t.greenPct;
        var gdk = u ? t.greenDarkAmt  : t.greenDarkPct;
        return [
            0,
            ref + off(rdk, -1),
            ref + off(rk,  -1),
            ref + off(rlk, -1),
            ref + off(glk,  1),
            ref + off(gk,   1),
            ref + off(gdk,  1),
            999999
        ];
    }

    function buildBandSeries(allDates, refPrices) {
        var series = [];
        for (var i = 0; i < 7; i++) {
            (function (i) {
                var data = allDates.map(function (_, di) {
                    var b = calcBoundaries(refPrices[di], trendThresholds);
                    if (!b) return null;
                    return i === 0 ? Math.max(0, b[1]) : Math.max(0, b[i + 1] - b[i]);
                });
                series.push({
                    name:      '_band_' + i,
                    type:      'line',
                    stack:     'bands',
                    data:      data,
                    lineStyle: { width: 0, color: 'transparent' },
                    itemStyle: { color: 'transparent' },
                    areaStyle: { color: bandFillForBandIdx(i), opacity: 1 },
                    symbol:    'none',
                    silent:    true,
                    z:         Z_BAND,
                    tooltip:   { show: false },
             
                    emphasis:  { disabled: true },
                    blur:      { areaStyle: { opacity: 1 }, lineStyle: { opacity: 0 } }
                });
            })(i);
        }
        return series;
    }

    function buildBoundaryLineSeries(allDates, refPrices) {
        var series = [];
        var boundaryLabels = [
            { idx: 1, bandIdx: 0 }, { idx: 2, bandIdx: 1 }, { idx: 3, bandIdx: 3 },
            { idx: 4, bandIdx: 4 }, { idx: 5, bandIdx: 5 }, { idx: 6, bandIdx: 6 }
        ];
        boundaryLabels.forEach(function (bl) {
            var data = allDates.map(function (_, di) {
                var b = calcBoundaries(refPrices[di], trendThresholds);
                return b ? b[bl.idx] : null;
            });
            var st = boundaryLineStyle(bl.bandIdx);
            series.push({
                name:      '_bline_' + bl.idx,
                type:      'line',
                data:      data,
                lineStyle: { width: st.width, color: st.color, type: st.type },
                itemStyle: { color: 'transparent' },
                symbol:    'none',
                silent:    true,
                z:         Z_BOUNDARY,
                tooltip:   { show: false },
                emphasis:  { disabled: true },
                blur:      { lineStyle: { opacity: 1 } }
            });
        });
        return series;
    }

    function buildMapRefLine(allDates, refPrices) {
        return {
            name: 'Cena MAP',
            type: 'line',
            data: refPrices.map(function (rp) { return { value: rp, source: 'map' }; }),
            lineStyle: { color: mapRefColor, width: 2.5, type: 'dashed' },
            itemStyle: { color: mapRefColor },
            symbol: 'circle',
            symbolSize: 6,
            showSymbol: false,
            connectNulls: false,
            smooth: 0.30,
            z: Z_MAP_REF,
            emphasis: {
             
                focus: 'none',
                scale: false,
                lineStyle: { width: 3, color: mapRefColor, shadowColor: 'rgba(0,0,0,0.35)', shadowBlur: 6 },
                itemStyle: { color: mapRefColor, borderColor: '#fff', borderWidth: 1 }
            },
            blur: { lineStyle: { opacity: 1 }, areaStyle: { opacity: 1 }, itemStyle: { opacity: 1 } }
        };
    }

    function updateCustomTooltipPanel(h) {
        var e = document.getElementById('customTrendTooltip');
        if (e) e.innerHTML = h || defaultCustomTooltipContent;
    }
    function findNextFreeColorIndex() {
        for (var i = 0; i < highlightColors.length; i++) {
            if (!Object.values(storeColorMap).includes(i)) return i;
        }
        return null;
    }


    function getSeriesStyleAndZ(sl) {
        if (hiddenStores.includes(sl)) {
            return {
                lineStyle:    { color: 'transparent', width: 0 },
                itemStyle:    { color: 'transparent' },
                markerColor:  'transparent',
                z:            0,
                _needsOutline: false,
                _outlineZ:    0
            };
        }

        var isMy = !trendIsMapMode && sl === myStoreLower;
        var isH  = highlightedStores.includes(sl);
        var highlightOrder = isH ? highlightedStores.indexOf(sl) : -1;

        var style = {
            lineStyle:    { width: UNIFORM_LINE_WIDTH },
            itemStyle:    {},
            markerColor:  DEFAULT_MARKER_SOLID,
            z:            Z_NORMAL,
            _needsOutline: false,
            _outlineZ:    0
        };

        if (isMy) {
        
            style.lineStyle.color = myStoreColor;
            style.lineStyle.width = 2.8;
            style.itemStyle.color = myStoreColor;
            style.markerColor     = myStoreColor;
            style.z               = Z_MAIN_LINE;
            style._needsOutline   = true;
            style._outlineZ       = Z_MAIN_OUTLINE;
        } else if (isH) {
            var colorIndex = storeColorMap[sl];
            if (colorIndex != null) {
                var color = highlightColors[colorIndex];
                style.lineStyle.color = color;
                style.lineStyle.width = 2.6 + Math.min(highlightOrder, 8) * 0.08;
                style.itemStyle.color = color;
                style.markerColor     = color;
                var baseZ             = Z_HIGHLIGHT_BASE + highlightOrder * Z_HIGHLIGHT_STEP;
                style.z               = baseZ + 2;
                style._needsOutline   = true;
                style._outlineZ       = baseZ;
            }
        } else {
           
            var gray = 'rgba(0, 0, 0, ' + defaultGrayAlpha + ')';
            style.lineStyle.color = gray;
            style.itemStyle.color = gray;
        }

        return style;
    }

    function buildEmphasisForLine(lineStyle, itemStyle) {
        var baseWidth = (lineStyle && lineStyle.width) || UNIFORM_LINE_WIDTH;
        var lineColor = (lineStyle && lineStyle.color) || 'rgba(0,0,0,' + defaultGrayAlpha + ')';
        var itemColor = (itemStyle && itemStyle.color) || lineColor;
        return {
            focus: 'none',
            scale: false,
            lineStyle: {
                width: baseWidth + 0.4,
                color: lineColor,
                shadowColor: 'rgba(0, 0, 0, 0.4)',
                shadowBlur: 6
            },
            itemStyle: {
                color: itemColor,
                borderColor: '#fff',
                borderWidth: 1
            }
        };
    }

    function recalculateYAxisRange() {
        if (!currentChartOptions || !currentChartOptions.series) return null;
        var mn = Infinity, mx = -Infinity, has = false;
        currentChartOptions.series.forEach(function (s) {
            if (!s.name) return;
            if (s.name.startsWith('_band_') || s.name.startsWith('_bline_') || s.name.startsWith('_outline_')) return;
            if (hiddenStores.includes(s.name.toLowerCase().trim())) return;
            (s.data || []).forEach(function (dp) {
                var v = (dp && typeof dp === 'object') ? dp.value : dp;
                if (v != null) { has = true; mn = Math.min(mn, v); mx = Math.max(mx, v); }
            });
        });
        if (!has) return { min: 0, max: 100 };
        if (mx <= mn) mx = mn + 100;
        var p = (mx - mn) * 0.05;
        return { min: Math.max(0, mn - p), max: mx + p };
    }

    function hideStoreFromChart(sn) {
        if (!echartsTrendChart || !currentTimelineData) return;
        var sl = sn.toLowerCase().trim();
        if (!hiddenStores.includes(sl)) hiddenStores.push(sl);
        var i = highlightedStores.indexOf(sl);
        if (i > -1) {
            highlightedStores.splice(i, 1);
            delete storeColorMap[sl];
            if (lastHighlightedStore === sl) {
                lastHighlightedStore = highlightedStores.length
                    ? highlightedStores[highlightedStores.length - 1]
                    : null;
            }
        }
        
        rebuildChartFromCurrentState();
        var r = recalculateYAxisRange();
        if (r && currentChartOptions) {
            currentChartOptions.yAxis.min = r.min;
            currentChartOptions.yAxis.max = r.max;
            echartsTrendChart.setOption({ yAxis: { min: r.min, max: r.max } });
        }
        if (lastHoverParams) updateCustomTooltipPanel(generateTooltipPanelHtml(lastHoverParams));
    }

    function toggleStoreHighlight(sn) {
        if (!echartsTrendChart || !currentTimelineData) return;
        var sl = sn.toLowerCase().trim();
        var i  = highlightedStores.indexOf(sl);

        if (i >= 0) {
            highlightedStores.splice(i, 1);
            delete storeColorMap[sl];
            if (lastHighlightedStore === sl) {
                lastHighlightedStore = highlightedStores.length
                    ? highlightedStores[highlightedStores.length - 1]
                    : null;
            }
        } else {
            if (!trendIsMapMode && sl === myStoreLower) {
                lastHighlightedStore = sl;
            } else if (highlightedStores.length >= highlightColors.length) {
                alert('Możesz zaznaczyć maks. ' + highlightColors.length + ' sklepów do porównania');
                return;
            } else {
                var ci = findNextFreeColorIndex();
                if (ci === null) return;
                if (!highlightedStores.includes(sl)) highlightedStores.push(sl);
                storeColorMap[sl] = ci;
                lastHighlightedStore = sl;
            }
        }
     
        rebuildChartFromCurrentState();
        if (lastHoverParams) updateCustomTooltipPanel(generateTooltipPanelHtml(lastHoverParams));
    }

 
    function rebuildChartFromCurrentState() {
        if (!echartsTrendChart || !currentTimelineData || !currentChartOptions) return;

        var existing = currentChartOptions.series || [];
        var keepBgSeries = existing.filter(function (s) {
            return s.name && (s.name.startsWith('_band_') || s.name.startsWith('_bline_') || s.name === 'Cena MAP');
        });

     
        var allDates = currentChartOptions.xAxis.data;
        var dbi = window._dbiCache || {};
        var allInst = window._allInstCache || [];

        var storeSeries = prepareStoreSeries(dbi, allDates, allInst);
        var newSeries = keepBgSeries.concat(storeSeries);

        currentChartOptions.series = newSeries;
        echartsTrendChart.setOption(
            { series: newSeries, animation: false },
            { replaceMerge: ['series'] }
        );
    }


    function updateEchartsStylesAndZ() {
        if (!echartsTrendChart || !currentChartOptions) return;
        var upd = currentChartOptions.series.map(function (s) {
            if (!s.name) return s;
            if (s.name.startsWith('_band_')) {
                var idx = parseInt(s.name.replace('_band_', ''));
                return Object.assign({}, s, { areaStyle: { color: bandFillForBandIdx(idx), opacity: 1 } });
            }
            if (s.name.startsWith('_bline_')) {
                var bi = parseInt(s.name.replace('_bline_', ''));
                var bm = { 1: 0, 2: 1, 3: 3, 4: 4, 5: 5, 6: 6 };
                var st = boundaryLineStyle(bm[bi] || 0);
                return Object.assign({}, s, {
                    lineStyle: { width: st.width, color: st.color, type: st.type }
                });
            }
            if (s.name.startsWith('_outline_')) return s;
            if (s.name === 'Cena MAP') return s;

       
            var sl = s.name.toLowerCase().trim();
            var style = getSeriesStyleAndZ(sl);
            return Object.assign({}, s, {
                lineStyle: style.lineStyle,
                itemStyle: style.itemStyle,
                z: style.z,
                emphasis: buildEmphasisForLine(style.lineStyle, style.itemStyle),
                blur: {
                    lineStyle: { opacity: 1 },
                    areaStyle: { opacity: 1 },
                    itemStyle: { opacity: 1 }
                }
            });
        });
        currentChartOptions.series = upd;
        echartsTrendChart.setOption({ series: upd, animation: false });
    }

    function generateTooltipPanelHtml(params) {
        if (!params || !params.length) return null;
        var date  = params[0].axisValueLabel;
        var refPriceForDate = producerRefByDate[date];
        var items = [];

        params.forEach(function (p) {
            if (!p.seriesName) return;
            if (p.seriesName.startsWith('_band_') || p.seriesName.startsWith('_bline_') || p.seriesName.startsWith('_outline_')) return;

            var v   = (p.data && typeof p.data === 'object') ? p.data.value  : p.data;
            var src = (p.data && typeof p.data === 'object') ? (p.data.source || '') : '';
            var sn  = p.seriesName;
            var sl  = sn.toLowerCase().trim();
            if (hiddenStores.includes(sl) || v == null) return;

            var isRef = sn === 'Cena MAP';
            var marker;
            if (isRef) {
                marker = mapRefColor;
            } else {
                var st = getSeriesStyleAndZ(sl);
                marker = st.markerColor;
            }
            items.push({
                storeName:   sn,
                price:       v,
                source:      src,
                markerColor: marker,
                isMapRef:    isRef,
                isMyStore:   !trendIsMapMode && sl === myStoreLower,
                colorIndex:  storeColorMap[sl]
            });
        });

        items.sort(function (a, b) {
            if (a.isMapRef) return -1;
            if (b.isMapRef) return 1;
            return a.price !== b.price ? a.price - b.price : a.storeName.localeCompare(b.storeName);
        });

        var h = '<div style="font-weight:bold;margin-bottom:8px;">Data: ' + date + '</div>';

        // Ref price prominentnie na górze
        if (refPriceForDate) {
            var refLabel = trendIsMapMode ? 'Cena MAP' : 'Cena Rynkowa';
            h += '<div style="padding:4px 0;margin-bottom:8px;border-bottom:1px solid #ccc;display:flex;justify-content:space-between;align-items:center;">' +
                    '<strong>' + refLabel +
                        '<span style="font-size:10px;padding:1px 5px;border-radius:3px;background:#e0e7ff;color:#3b5bdb;font-weight:500;margin-left:4px;vertical-align:middle;">REF</span>' +
                    '</strong>' +
                    '<strong style="color:#000;font-size:14px;">' + refPriceForDate.toFixed(2) + ' PLN</strong>' +
                 '</div>';
        }

        if (!items.length) {
            h += '<div style="color:#666;font-style:italic;">Brak danych.</div>';
            return h;
        }

        h += '<table style="width:100%;border-collapse:collapse;font-size:0.85rem;">';
        items.forEach(function (it) {
            var sl = it.storeName.toLowerCase().trim();
            var ct = 'rgba(50,50,50,1)';
            var fw = 'normal';
            if (it.isMapRef)        { ct = mapRefColor; fw = 'bold'; }
            else if (it.isMyStore)  { ct = myStoreColor; fw = 'bold'; }
            else if (highlightedStores.includes(sl) && it.colorIndex != null) {
                ct = highlightColors[it.colorIndex];
                fw = 'bold';
            }


            var bucketBadge = '';
            if (it.isMyStore && !trendIsMapMode && refPriceForDate) {
               
                bucketBadge = '<span style="font-size:10px;padding:2px 5px;background:#e0e7ff;color:#3b5bdb;border:1px solid #b6c3ff;border-radius:3px;font-weight:600;white-space:nowrap;">REF</span>';
            } else if (!it.isMapRef && refPriceForDate && refPriceForDate > 0) {
                var b = getProducerBucketForPrice(it.price, refPriceForDate);
                var cols = getBucketBadgeColors(b);
                var da = it.price - refPriceForDate;
                var dp = (da / refPriceForDate) * 100;
                var s  = da >= 0 ? '+' : '';
                var sp = dp >= 0 ? '+' : '';
                bucketBadge = '<span style="font-size:11px;padding:2px 5px;background:' + cols.bg + ';color:' + cols.fg + ';border:1px solid ' + cols.border + ';border-radius:5px;font-weight:600;white-space:nowrap;">' + s + da.toFixed(2) + ' PLN (' + sp + dp.toFixed(2) + '%)</span>';
            }

            var dn = it.storeName.length > 23 ? it.storeName.substring(0, 20) + '...' : it.storeName;
            var icon = it.isMapRef
                ? '<i class="fa-solid fa-bullseye" style="font-size:12px;color:' + mapRefColor + ';margin-right:4px;vertical-align:middle;"></i>'
                : (it.source === 'google'
                    ? '<img src="/images/GoogleShopping.png" alt="" style="width:14px;height:14px;margin-right:4px;vertical-align:middle;"/>'
                    : '<img src="/images/Ceneo.png" alt="" style="width:14px;height:14px;margin-right:4px;vertical-align:middle;"/>');

            var esc = it.storeName.replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '&quot;');
            var rm = it.isMapRef ? '' :
                '<span title="Ukryj sklep \'' + esc + '\'" style="cursor:pointer;color:#aaa;font-weight:bold;font-size:16px;line-height:1;flex-shrink:0;padding:0 2px;" ' +
                'onmouseover="this.style.color=\'red\'" onmouseout="this.style.color=\'#aaa\'" ' +
                'onclick="event.stopPropagation();hideStoreFromChart(\'' + esc + '\');">&times;</span>';
            var cl = it.isMapRef ? '' : ' onclick="event.stopPropagation();toggleStoreHighlight(\'' + esc + '\');"';

            h += '<tr style="border-bottom:1px solid #eee;cursor:' + (it.isMapRef ? 'default' : 'pointer') + ';"' + cl + '>' +
                    '<td colspan="2" style="padding:5px 2px;">' +
                        '<div style="display:flex;align-items:center;gap:8px;width:100%;">' +
                            '<div style="flex:1;min-width:0;color:' + ct + ';font-weight:' + fw + ';overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + it.storeName + '">' +
                                '<span style="display:inline-block;margin-right:5px;width:10px;height:10px;border-radius:50%;background-color:' + it.markerColor + ';vertical-align:middle;"></span>' +
                                icon +
                                '<span style="vertical-align:middle;">' + dn + '</span>' +
                            '</div>' +
                            '<div style="display:flex;flex-direction:column;align-items:flex-end;white-space:nowrap;gap:2px;">' +
                                '<span style="font-size:14px;font-weight:500;color:#000;">' + it.price.toFixed(2) + ' PLN</span>' +
                                bucketBadge +
                            '</div>' +
                            rm +
                        '</div>' +
                    '</td>' +
                 '</tr>';
        });
        h += '</table>';
        return h;
    }


    function prepareStoreSeries(dbi, allDates, allInst) {
        var seriesList = [];

        allInst.forEach(function (iid) {
            var p   = iid.split('|');
            var sn  = p[0];
            var src = p[1];
            var sl  = sn.toLowerCase().trim();
            var style = getSeriesStyleAndZ(sl);
            var vc = 0;

            var data = allDates.map(function (d) {
                var pr = (dbi[iid] && dbi[iid][d]) || null;
                if (pr != null) vc++;
                return { value: pr, source: src, storeName: sn };
            });

            var isSingle = vc === 1;

          
            if (style._needsOutline) {
                seriesList.push({
                    name: '_outline_' + iid,
                    type: 'line',
                    data: data,
                    connectNulls: false,
                    smooth: 0.30,
                    symbol: 'circle',
                    symbolSize: 0,
                    showSymbol: false,
                    lineStyle: {
                        color: 'rgba(0, 0, 0, 0.88)',
                        width: (style.lineStyle.width || UNIFORM_LINE_WIDTH) + 2.4
                    },
                    itemStyle: { color: 'rgba(0,0,0,0)' },
                    areaStyle: null,
                    z: style._outlineZ,
                    silent: true,
                    tooltip: { show: false },
                    emphasis: { disabled: true },
                    blur: { lineStyle: { opacity: 1 } }
                });
            }

            seriesList.push({
                name:         sn,
                _instanceId:  iid,
                _source:      src,
                type:         'line',
                data:         data,
                connectNulls: false,
                smooth:       0.30,
                showSymbol:   isSingle,
                symbol:       'circle',
                symbolSize:   isSingle ? 10 : 6,
                lineStyle:    style.lineStyle,
                itemStyle:    style.itemStyle,
                z:            style.z,
         
                emphasis:     buildEmphasisForLine(style.lineStyle, style.itemStyle),
             
                blur: {
                    lineStyle: { opacity: 1 },
                    areaStyle: { opacity: 1 },
                    itemStyle: { opacity: 1 }
                }
            });
        });
        return seriesList;
    }

    function drawEchartsTrendChart(resp) {
        var td = resp.timelineData;
        trendIsMapMode  = resp.isMapMode;
        trendThresholds = resp.producerThresholds || {};
        currentTimelineData = td;

        var dom = document.getElementById('trendChart');
        if (!dom) return;
        if (echartsTrendChart) { echartsTrendChart.dispose(); echartsTrendChart = null; }
        echartsTrendChart = echarts.init(dom);

        var datesSet = new Set();
        var instSet  = new Set();
        var dbi      = {};
        producerRefByDate = {};

        td.forEach(function (e) {
            datesSet.add(e.scrapDate);
            producerRefByDate[e.scrapDate] = e.referencePrice;
            e.pricesByStore.forEach(function (ps) {
                if (!ps.storeName || !ps.source || ps.price == null) return;
                var iid = ps.storeName + '|' + ps.source;
                instSet.add(iid);
                if (!dbi[iid]) dbi[iid] = {};
                dbi[iid][e.scrapDate] = ps.price;
            });
        });

        var allDates = Array.from(datesSet).sort();
        var allInst  = Array.from(instSet);
        allInst.sort(function (a, b) {
            var nA = a.split('|')[0], nB = b.split('|')[0];
            var aL = nA.toLowerCase().trim(), bL = nB.toLowerCase().trim();
            if (!trendIsMapMode) {
                if (aL === myStoreLower && bL !== myStoreLower) return -1;
                if (bL === myStoreLower && aL !== myStoreLower) return  1;
            }
            return nA.localeCompare(nB);
        });

       
        window._dbiCache     = dbi;
        window._allInstCache = allInst;

        var refPrices = allDates.map(function (d) { return producerRefByDate[d] || null; });
        var hasAnyRef = refPrices.some(function (rp) { return rp != null && rp > 0; });

        var bandGroup = document.getElementById('bandIntensityGroup');
        if (bandGroup) bandGroup.style.display = hasAnyRef ? 'flex' : 'none';

        var gMin = Infinity, gMax = -Infinity;
        Object.values(dbi).forEach(function (dm) {
            Object.values(dm).forEach(function (p) {
                gMin = Math.min(gMin, p);
                gMax = Math.max(gMax, p);
            });
        });
        refPrices.forEach(function (rp) {
            if (rp != null) { gMin = Math.min(gMin, rp); gMax = Math.max(gMax, rp); }
        });
        if (!isFinite(gMin)) gMin = 0;
        if (!isFinite(gMax) || gMax <= gMin) {
            gMax = gMin + 100;
        } else {
            var pad = (gMax - gMin) * 0.05;
            gMin = Math.max(0, gMin - pad);
            gMax += pad;
        }

        var allSeries = prepareStoreSeries(dbi, allDates, allInst);
        if (hasAnyRef) {
            var bandSeries     = buildBandSeries(allDates, refPrices);
            var boundarySeries = buildBoundaryLineSeries(allDates, refPrices);
            allSeries = bandSeries.concat(boundarySeries, allSeries);
            if (trendIsMapMode) allSeries.push(buildMapRefLine(allDates, refPrices));
        }

        var pm = ['sty', 'lut', 'mar', 'kwi', 'maj', 'cze', 'lip', 'sie', 'wrz', 'paź', 'lis', 'gru'];
        function fmtDate(ds) {
            try {
                var p  = ds.split(' ');
                var dp = p[0].split('-');
                var d  = parseInt(dp[2]);
                var m  = pm[parseInt(dp[1]) - 1];
                return p.length > 1 && p[1] ? d + ' ' + m + '\n' + p[1] : d + ' ' + m;
            } catch (e) { return ds; }
        }

        var container = document.getElementById('trendChartContainer');
        if (container && typeof ResizeObserver !== 'undefined') {
            new ResizeObserver(function () {
                if (echartsTrendChart && $('#trendChartContainer').is(':visible')) {
                    echartsTrendChart.resize({ animation: { duration: 200 } });
                }
            }).observe(container);
        }

        currentChartOptions = {
            title: {
                text: 'Cena w czasie',
                left: 20,
                top: 4,
                textStyle: { fontSize: 13, fontWeight: 600, color: '#333' }
            },
            tooltip: {
                trigger: 'axis',
                axisPointer: { type: 'cross', snap: true, label: { backgroundColor: '#6a7985' } },
                formatter: function (p) {
                    lastHoverParams = p;
                    updateCustomTooltipPanel(generateTooltipPanelHtml(p) || defaultCustomTooltipContent);
                    return '';
                }
            },
            xAxis: {
                type: 'category',
                data: allDates,
                boundaryGap: false,
                splitLine: { show: true, lineStyle: { color: '#E8E8E8', type: 'dashed', width: 1 } },
                axisLabel: { formatter: fmtDate, fontSize: 11, color: '#666' }
            },
            yAxis: {
                type: 'value',
                min: gMin, max: gMax,
                scale: true,
                axisLabel:   { show: false },
                axisPointer: { show: true, snap: true },
                splitLine:   { show: true, lineStyle: { color: '#E8E8E8', type: 'dashed', width: 1 } }
            },
            grid: { left: 20, right: 20, bottom: 65, top: 40, containLabel: false },
            series: allSeries,
            animationEasing: 'quadraticInOut',
            animationDuration: 600,
            dataZoom: [
                {
                    type: 'slider', xAxisIndex: 0, start: 0, end: 100, bottom: 10, height: 25,
                    showDetail: true, realtime: true, filterMode: 'filter',
                    backgroundColor: 'rgba(240,240,240,0.6)', borderColor: '#ccc', fillerColor: 'rgba(180,180,180,0.4)',
                    handleStyle: { color: '#a7a7a7', borderColor: '#747474', borderWidth: 1 },
                    dataBackground: { lineStyle: { color: 'transparent' }, areaStyle: { color: '#ebebeb' } },
                    selectedDataBackground: { lineStyle: { color: 'transparent' }, areaStyle: { color: '#dcdcdc' } },
                    showMoveHandle: false, moveHandleIcon: 'none', moveHandleStyle: { color: 'transparent', opacity: 0 },
                    emphasis: { fillerColor: 'rgba(180,180,180,0.6)', handleStyle: { color: '#747474', borderColor: '#505050' }, moveHandleStyle: { color: 'transparent', opacity: 0 } },
                    labelFormatter: function (v) {
                        var ds = (typeof v === 'number' && v >= 0 && v < allDates.length)
                            ? allDates[v]
                            : (typeof v === 'string' ? v : '');
                        return fmtDate(ds);
                    }
                },
                {
                    type: 'inside', xAxisIndex: 0, start: 0, end: 100,
                    zoomOnMouseWheel: true, moveOnMouseMove: true, preventDefaultMouseMove: true
                }
            ]
        };

        echartsTrendChart.setOption(currentChartOptions);
        echartsTrendChart.on('click', function (p) {
            if (p && p.seriesName
                && !p.seriesName.startsWith('_band_')
                && !p.seriesName.startsWith('_bline_')
                && !p.seriesName.startsWith('_outline_')
                && p.seriesName !== 'Cena MAP') {
                toggleStoreHighlight(p.seriesName);
            }
        });
        window.addEventListener('resize', function () {
            if (echartsTrendChart) echartsTrendChart.resize();
        });
        updateCustomTooltipPanel(null);
    }

    function loadTrendDataAndDrawEcharts() {
        if ($('#trendChartContainer').is(':visible')) $('#loadingOverlay').show();
        $.ajax({
            url:  '@Url.Action("GetPriceTrendDataForProducer", "PriceHistory")',
            type: 'GET',
            data: { productId: productId, limit: currentHistoryLimit },
            success: function (r) {
                if (r && r.timelineData && Array.isArray(r.timelineData)) {
                    if ($('#trendChartContainer').is(':visible') && document.getElementById('trendChart')) {
                        drawEchartsTrendChart(r);
                    }
                } else {
                    alert("Nieprawidłowy format danych.");
                }
            },
            error:    function (_, __, err) { alert("Błąd: " + err); },
            complete: function () { $('#loadingOverlay').hide(); }
        });
    }

 
    $('.history-btn').on('click', function () {
        $('.history-btn').removeClass('active');
        $(this).addClass('active');
        var n = $(this).data('days');
        if (currentHistoryLimit !== n) {
            currentHistoryLimit = n;
            if ($('#trendChartContainer').is(':visible')) loadTrendDataAndDrawEcharts();
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        var $tBtn = $('#showTableBtn'),
            $cBtn = $('#showChartBtn'),
            $tC   = $('#priceTableContainer'),
            $cC   = $('#trendChartContainer'),
            $rk   = $('#rankingOnlyArea');

        function showRanking() {
            $cC.hide();
            $tC.show();
            $rk.css('display', 'flex');
            $tBtn.removeClass('button-inactive').addClass('button-active');
            $cBtn.removeClass('button-active').addClass('button-inactive');
        }
        function showChart() {
            $tC.hide();
            $rk.hide();
            $cC.css('display', 'flex');
            $cBtn.removeClass('button-inactive').addClass('button-active');
            $tBtn.removeClass('button-active').addClass('button-inactive');
            if (!echartsTrendChart) {
                loadTrendDataAndDrawEcharts();
            } else {
                setTimeout(function () { echartsTrendChart.resize(); }, 50);
            }
        }

        $tBtn.on('click', showRanking);
        $cBtn.on('click', showChart);

        
        document.getElementById("grayAlphaRange").addEventListener("input", function (e) {
            defaultGrayAlpha = parseFloat(e.target.value);
            updateEchartsStylesAndZ();
            if (lastHoverParams) updateCustomTooltipPanel(generateTooltipPanelHtml(lastHoverParams));
        });


        document.getElementById("bandIntensityRange").addEventListener("input", function (e) {
            bandIntensity = parseFloat(e.target.value);
            invalidateStripePatterns();
            updateEchartsStylesAndZ();
        });

        $('#exportExcelBtn').on('click', function () {
            if (!currentTimelineData) {
                alert("Załaduj widok wykresu.");
            } else {
                exportChartDataToExcel();
            }
        });


        showRanking();
    });


    function rgbaToHex(r) {
        if (typeof r !== 'string' || !r.toLowerCase().startsWith('rgba')) return null;
        var p = r.substring(r.indexOf('(') + 1, r.lastIndexOf(')')).split(/,\s*/);
        if (p.length < 3) return null;
        try {
            var rv = parseInt(p[0]), gv = parseInt(p[1]), bv = parseInt(p[2]);
            if ([rv, gv, bv].some(function (c) { return isNaN(c) || c < 0 || c > 255; })) return null;
            return '#' + [rv, gv, bv].map(function (c) { return ('0' + c.toString(16)).slice(-2); }).join('').toUpperCase();
        } catch (e) { return null; }
    }
    function getExcelColor(sk, inf) {
        if (!inf || !sk || !inf[sk]) return null;
        var sl = inf[sk].name.toLowerCase().trim();
        var c  = null;
        if (!trendIsMapMode && sl === myStoreLower) c = myStoreColor;
        else if (highlightedStores.includes(sl) && storeColorMap[sl] != null) c = highlightColors[storeColorMap[sl]];
        return c ? rgbaToHex(c) : null;
    }

    async function exportChartDataToExcel() {
        if (!currentTimelineData || !currentTimelineData.length || !echartsTrendChart) {
            alert("Brak danych.");
            return;
        }

        var ad = new Set(), sd = {}, li = {};
        currentTimelineData.forEach(function (e) {
            ad.add(e.scrapDate);
            if (trendIsMapMode && e.referencePrice != null) {
                var mk = 'Cena MAP|map';
                if (!sd[mk]) { sd[mk] = {}; li[mk] = { name: 'Cena MAP', source: 'MAP' }; }
                sd[mk][e.scrapDate] = e.referencePrice;
            }
            e.pricesByStore.forEach(function (ps) {
                if (ps.price == null || !ps.storeName || !ps.source) return;
                var sk = ps.storeName + '|' + ps.source;
                var sl = ps.storeName.toLowerCase().trim();
                if (hiddenStores.includes(sl)) return;
                if (!sd[sk]) { sd[sk] = {}; li[sk] = { name: ps.storeName, source: ps.source }; }
                sd[sk][e.scrapDate] = ps.price;
            });
        });

        var sorted = Array.from(ad).sort();
        var opt    = echartsTrendChart.getOption();
        var si = 0, ei = sorted.length - 1;
        if (opt && opt.dataZoom && opt.dataZoom.length) {
            var dz = opt.dataZoom.find(function (d) { return d.xAxisIndex === 0 || typeof d.xAxisIndex === 'undefined'; });
            if (dz && dz.start != null) {
                si = Math.max(0, Math.floor(sorted.length * dz.start / 100));
                ei = Math.min(sorted.length - 1, Math.ceil(sorted.length * dz.end / 100) - 1);
            }
        }
        var fd = sorted.slice(si, ei + 1);
        if (!fd.length) { alert("Brak danych."); return; }

        var keys = Object.keys(sd).sort();
        if (!keys.length) { alert("Brak danych."); return; }

        try {
            var wb = new ExcelJS.Workbook();
            var ws = wb.addWorksheet("Historia Cen");
            var cols = [
                { header: 'Sklep',  key: 'store',  width: 35 },
                { header: 'Źródło', key: 'source', width: 10 }
            ];


            var hasRef = fd.some(function (d) { return producerRefByDate[d] != null; });
            if (hasRef) {
                cols.push({ header: 'Ref.', key: 'ref', width: 14, style: { numFmt: '#,##0.00 "PLN"' } });
            }

            fd.forEach(function (d) {
                cols.push({
                    header: d, key: d, width: 12,
                    style: { numFmt: '#,##0.00', alignment: { horizontal: 'right' } }
                });
            });
            ws.columns = cols;
            ws.getRow(1).font = { bold: true };
            ws.getRow(1).fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFE0E0E0' } };

          
            if (hasRef) {
                var refRowData = { store: trendIsMapMode ? 'CENA MAP (referencja)' : 'CENA RYNKOWA (referencja)', source: 'REF' };
                fd.forEach(function (d) {
                    var rp = producerRefByDate[d];
                    if (rp != null) refRowData[d] = rp;
                });
                var refRow = ws.addRow(refRowData);
                refRow.font = { bold: true, color: { argb: 'FFFFFFFF' } };
                refRow.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF4169E1' } };
                ws.addRow({});
            }

            keys.forEach(function (sk) {
                var inf = li[sk];
                var pr  = sd[sk];
                var rd  = { store: inf.name, source: inf.source };
                fd.forEach(function (d) { rd[d] = pr[d] !== undefined ? pr[d] : null; });
                var row = ws.addRow(rd);
                var hex = getExcelColor(sk, li);
                if (hex) {
                    var fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF' + hex.substring(1) } };
                    row.eachCell({ includeEmpty: true }, function (c) { c.fill = fill; });
                }
            });

            var buf  = await wb.xlsx.writeBuffer();
            var blob = new Blob([buf], { type: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" });
            var pn   = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ProductName ?? "Produkt"));
            var safe = pn.replace(/[^a-z0-9_]/gi, '_').substring(0, 50);
            var fn   = 'PriceSafari_Producent_' + safe + '_' + fd[0] + '_do_' + fd[fd.length - 1] + '.xlsx';

            var link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = fn;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            setTimeout(function () { URL.revokeObjectURL(link.href); }, 100);
        } catch (err) {
            console.error(err);
            alert("Błąd Excel.");
        }
    }
</script>

