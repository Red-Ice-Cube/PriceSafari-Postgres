@using Newtonsoft.Json
@using PriceSafari.Models.ViewModels

@{
    ViewBag.Title = "Panel Producenta - " + ViewBag.StoreName;
    var latestScrap = ViewBag.LatestScrap as PriceSafari.Models.ScrapHistoryClass;
    var storeId = ViewBag.StoreId;
    var storeLogo = ViewBag.StoreLogo;
    var scrapId = ViewBag.ScrapId;
    var flags = ViewBag.Flags as List<FlagViewModel>;
    var scrapDate = latestScrap?.Date.ToString("dd.MM.yyyy");
    var store = ViewBag.StoreName as string;
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<input type="hidden" id="initialScrapId" value="@scrapId" />

<style>
    /* === COLOR BAR (pionowy w boksie danych) === */
    .color-bar.producer-deep-violation { background-color: rgba(139, 0, 0, 0.85); }
    .color-bar.producer-violation { background-color: rgba(220, 20, 60, 0.85); }
    .color-bar.producer-minor-below { background-color: rgba(255, 99, 71, 0.85); }
    .color-bar.producer-equal { background-color: rgba(65, 105, 225, 0.85); }
    .color-bar.producer-minor-above { background-color: rgba(144, 238, 144, 0.85); }
    .color-bar.producer-above { background-color: rgba(34, 139, 34, 0.85); }
    .color-bar.producer-deep-above { background-color: rgba(0, 100, 0, 0.85); }
    .color-bar.producer-no-reference { background-color: rgba(187, 187, 187, 0.85); }
    .color-bar.producer-no-competition { background-color: rgba(136, 136, 136, 0.85); }

    /* === KOLOROWE PROSTOKĄTY w sidebarze (legenda buckets) === */
    .producer-rect-deep-violation { background-color: rgba(139, 0, 0, 0.85); }
    .producer-rect-violation { background-color: rgba(220, 20, 60, 0.85); }
    .producer-rect-minor-below { background-color: rgba(255, 99, 71, 0.85); }
    .producer-rect-equal { background-color: rgba(65, 105, 225, 0.85); }
    .producer-rect-minor-above { background-color: rgba(144, 238, 144, 0.85); }
    .producer-rect-above { background-color: rgba(34, 139, 34, 0.85); }
    .producer-rect-deep-above { background-color: rgba(0, 100, 0, 0.85); }
    .producer-rect-no-reference { background-color: rgba(187, 187, 187, 0.85); }
    .producer-rect-no-competition { background-color: rgba(136, 136, 136, 0.85); }

    /* Czeckboxy bucketów - zaznaczone */
    .bucketFilter:checked#bucketDeepViolation { background-color: rgba(139, 0, 0, 0.7); border-color: rgba(139, 0, 0, 1); }
    .bucketFilter:checked#bucketViolation { background-color: rgba(220, 20, 60, 0.7); border-color: rgba(220, 20, 60, 1); }
    .bucketFilter:checked#bucketMinorBelow { background-color: rgba(255, 99, 71, 0.7); border-color: rgba(255, 99, 71, 1); }
    .bucketFilter:checked#bucketEqual { background-color: rgba(65, 105, 225, 0.7); border-color: rgba(65, 105, 225, 1); }
    .bucketFilter:checked#bucketMinorAbove { background-color: rgba(144, 238, 144, 0.7); border-color: rgba(144, 238, 144, 1); }
    .bucketFilter:checked#bucketAbove { background-color: rgba(34, 139, 34, 0.7); border-color: rgba(34, 139, 34, 1); }
    .bucketFilter:checked#bucketDeepAbove { background-color: rgba(0, 100, 0, 0.7); border-color: rgba(0, 100, 0, 1); }
    .bucketFilter:checked#bucketNoReference { background-color: rgba(187, 187, 187, 0.7); border-color: rgba(187, 187, 187, 1); }
    .bucketFilter:checked#bucketNoCompetition { background-color: rgba(136, 136, 136, 0.7); border-color: rgba(136, 136, 136, 1); }

    /* Pozycjonowanie kolorowych prostokątów obok checkboxów */
    #filters-producer .form-check {
        position: relative;
        display: flex;
        align-items: center;
        margin-bottom: 2px;
        padding-left: 0;
        margin-left: 3px;
    }
    #filters-producer .color-rect {
        position: absolute;
        left: -10px;
        top: 50%;
        transform: translateY(-50%);
        display: block;
        width: 6px;
        height: 16px;
        min-width: 6px;
        border-radius: 2px;
    }
    #filters-producer .form-check-input {
        margin-top: 0 !important;
        margin-left: 0 !important;
        margin-right: 8px !important;
        position: static !important;
    }

    /* === INLINE PANEL PROGÓW === */
    .producer-thresholds-section {
        padding-top: 8px;
        margin-top: 8px;
        border-top: 1px solid #ededed;
        display: flex;
        flex-direction: column;
        gap: 4px;
        width: 100%;
    }
    .producer-thresholds-section .price-range-settings {
        margin-top: 2px;
        align-items: center;
    }
    .price-range-settings .producer-circle-deep-above { background-color: rgba(0, 100, 0, 0.85); }
    .price-range-settings .producer-circle-above { background-color: rgba(34, 139, 34, 0.85); }
    .price-range-settings .producer-circle-minor-above { background-color: rgba(144, 238, 144, 0.85); }
    .price-range-settings .producer-circle-minor-below { background-color: rgba(255, 99, 71, 0.85); }
    .price-range-settings .producer-circle-violation { background-color: rgba(220, 20, 60, 0.85); }
    .price-range-settings .producer-circle-deep-violation { background-color: rgba(139, 0, 0, 0.85); }

    .producer-unit-label {
        display: inline-flex;
        align-items: center;
        height: 26px;
        margin-left: 3px;
        font-size: 13px;
        color: #4e4e4e;
        min-width: 22px;
    }

    .producer-threshold-actions {
        display: flex;
        gap: 4px;
        margin-top: 8px;
        width: 100%;
    }
    .producer-threshold-actions > * { flex: 1; margin: 0 !important; }

    /* Switch %/PLN */
    .useAmountSwitch {
        appearance: none;
        display: flex;
        width: 100%;
        height: 33px;
        background-color: #e3e3e3;
        border-radius: 4px;
        position: relative;
        cursor: pointer;
        font-size: 14px;
        color: #4e4e4e;
        text-align: center;
        user-select: none;
        margin: 0;
    }
    .useAmountSwitch::before {
        content: "Tryb: %";
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 4px;
        top: 0;
        left: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.3s, color 0.3s;
    }
    .useAmountSwitch:checked::before { content: "Tryb: PLN"; }
    .useAmountSwitch:hover::before { background-color: #323232; color: #e3e3e3; }

    /* Walidacja */
    .producer-threshold-input.input-error {
        border-color: rgba(220, 20, 60, 0.9) !important;
        box-shadow: 0 0 0 2px rgba(220, 20, 60, 0.15) !important;
    }
    .error-message-row {
        color: rgba(220, 20, 60, 0.9);
        font-size: 12px;
        margin-top: 4px;
        line-height: 1.4;
        display: none;
    }
    .error-message-row.visible { display: block; }

    /* Tryb badge */
    .producer-mode-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0 12px;
        height: 34px;
        background: rgb(245, 245, 245);
        border: 1px solid #e3e3e3;
        color: #4e4e4e;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 500;
    }
    .producer-mode-badge i { color: #4169E1; }
    .producer-mode-badge.amount-mode i { color: #6f42c1; }

    /* Rozkład sklepów - linijki */
    .producer-stores-dist {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-top: 6px;
        padding-top: 6px;
        border-top: 1px solid #ededed;
    }
    .producer-stores-line {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 500;
        line-height: 1.3;
        padding: 1px 0;
    }
    .producer-stores-line.bad { color: rgba(220, 20, 60, 0.9); }
    .producer-stores-line.good { color: rgba(34, 139, 34, 0.9); }
    .producer-stores-line.equal { color: rgba(65, 105, 225, 0.9); }

    /* Delta badge */
    .producer-delta-badge {
        display: inline-block;
        padding: 3px 9px;
        border-radius: 4px;
        font-weight: 500;
        font-size: 12px;
        color: white;
    }
    .producer-bg-deep-violation { background-color: rgba(139, 0, 0, 0.9); }
    .producer-bg-violation { background-color: rgba(220, 20, 60, 0.9); }
    .producer-bg-minor-below { background-color: rgba(255, 99, 71, 0.9); }
    .producer-bg-equal { background-color: rgba(65, 105, 225, 0.9); }
    .producer-bg-minor-above { background-color: rgba(144, 238, 144, 1); color: #222; }
    .producer-bg-above { background-color: rgba(34, 139, 34, 0.9); }
    .producer-bg-deep-above { background-color: rgba(0, 100, 0, 0.9); }

    /* Reference price box */
    .ref-label-small {
        font-size: 11px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 500;
    }
    .ref-alt-line {
        font-size: 12px;
        color: #888;
        line-height: 1.3;
    }
    .ref-missing {
        color: rgba(220, 20, 60, 0.9);
        font-style: italic;
        font-size: 13px;
    }

    /* Wartość delta - duża z ikoną */
    .producer-delta-value-row {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .producer-delta-value-row.bad { color: rgba(220, 20, 60, 0.9); }
    .producer-delta-value-row.good { color: rgba(34, 139, 34, 0.9); }
    .producer-delta-value-row.neutral { color: rgba(65, 105, 225, 0.9); }
    .producer-delta-value-row.deep-bad { color: rgba(139, 0, 0, 0.9); }
    .producer-delta-value-row.deep-good { color: rgba(0, 100, 0, 0.9); }
</style>

<div class="Vert">
    <div class="Page-Box">
        <div class="Page-Box-Container">

            <!-- ===================== LEWY PANEL ===================== -->
            <div class="Page-Box-Category">
                <div><img src="@storeLogo" class="img-container" /></div>

                <div class="side-chart-box">
                    <canvas id="colorChart"></canvas>
                </div>

                <!-- 9 bucketów (kolejność od góry: brak konkur > brak ref > mocno powyżej > ... > drastyczne) -->
                <div class="store-section" id="filters-producer">
                    <div class="form-check">
                        <span class="color-rect producer-rect-no-competition"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketNoCompetition" value="producer-no-competition">
                        <label class="form-check-label" for="bucketNoCompetition">Brak konkurencji</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-no-reference"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketNoReference" value="producer-no-reference">
                        <label class="form-check-label" for="bucketNoReference">Brak ceny ref.</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-deep-above"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketDeepAbove" value="producer-deep-above">
                        <label class="form-check-label" for="bucketDeepAbove">Mocno powyżej</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-above"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketAbove" value="producer-above">
                        <label class="form-check-label" for="bucketAbove">Powyżej</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-minor-above"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketMinorAbove" value="producer-minor-above">
                        <label class="form-check-label" for="bucketMinorAbove">Lekko powyżej</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-equal"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketEqual" value="producer-equal">
                        <label class="form-check-label" for="bucketEqual">Cena zgodna</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-minor-below"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketMinorBelow" value="producer-minor-below">
                        <label class="form-check-label" for="bucketMinorBelow">Lekko poniżej</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-violation"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketViolation" value="producer-violation">
                        <label class="form-check-label" for="bucketViolation">Naruszenie</label>
                    </div>
                    <div class="form-check">
                        <span class="color-rect producer-rect-deep-violation"></span>
                        <input class="form-check-input bucketFilter" type="checkbox" id="bucketDeepViolation" value="producer-deep-violation">
                        <label class="form-check-label" for="bucketDeepViolation">Drastyczne naruszenie</label>
                    </div>
                </div>

                <!-- INLINE: 6 progów + tryb + zapis -->
                <div class="store-section producer-thresholds-section">
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-deep-above"></div>
                        <div class="legendBox"><span>Mocno powyżej</span></div>
                        <input type="number" id="thrInline_greenDark" class="producer-threshold-input" data-level="dark" data-direction="above" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-above"></div>
                        <div class="legendBox"><span>Powyżej</span></div>
                        <input type="number" id="thrInline_green" class="producer-threshold-input" data-level="normal" data-direction="above" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-minor-above"></div>
                        <div class="legendBox"><span>Lekko powyżej</span></div>
                        <input type="number" id="thrInline_greenLight" class="producer-threshold-input" data-level="light" data-direction="above" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-minor-below"></div>
                        <div class="legendBox"><span>Lekko poniżej</span></div>
                        <input type="number" id="thrInline_redLight" class="producer-threshold-input" data-level="light" data-direction="below" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-violation"></div>
                        <div class="legendBox"><span>Naruszenie</span></div>
                        <input type="number" id="thrInline_red" class="producer-threshold-input" data-level="normal" data-direction="below" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>
                    <div class="price-range-settings">
                        <div class="color-circle producer-circle-deep-violation"></div>
                        <div class="legendBox"><span>Drastyczne</span></div>
                        <input type="number" id="thrInline_redDark" class="producer-threshold-input" data-level="dark" data-direction="below" step="0.5" min="0">
                        <span class="producer-unit-label">%</span>
                    </div>

                    <div class="producer-threshold-actions">
                        <div style="flex: 1; display: flex;">
                            <input class="useAmountSwitch" type="checkbox" id="useAmountToggle" />
                        </div>
                        <button class="Button-Page-Small" id="saveProducerInlineBtn">
                            Przelicz i zapisz
                        </button>
                    </div>

                    <div class="error-message-row" id="errInline"></div>
                </div>

                <div class="filterBox">
                    <div class="Category-Container-Select" style="margin-top:-2px;">
                        Flagi
                        <a asp-controller="Flags" asp-action="List" asp-route-storeId="@ViewBag.StoreId" class="link-line">+ Dodaj Flage</a>
                    </div>
                    <div class="store-section" id="flagContainer"></div>

                    <div class="Category-Container-Select">Pozycja</div>
                    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/15.6.1/nouislider.min.css">
                    <div class="store-section">
                        <div class="position-slider-container">
                            <div id="positionRange" class="position-range-display" style="font-size:14px; font-weight:400;"></div>
                        </div>
                        <div id="positionRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Liczba ofert</div>
                    <div class="store-section">
                        <div class="offer-slider-container">
                            <div id="offerRange" class="offer-range-display" style="font-size:14px; font-weight:400;"></div>
                        </div>
                        <div id="offerRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Cena referencyjna</div>
                    <div class="store-section">
                        <div class="position-slider-container">
                            <div id="myPriceRange" class="position-range-display" style="font-size:14px; font-weight:400;"></div>
                        </div>
                        <div id="myPriceRangeSlider"></div>
                    </div>

                    <div class="Category-Container-Select">Naruszenia MAP</div>
                    <div class="store-section">
                        <div class="flag-filter-group" style="display: flex; align-items: center; max-width: 100%;">
                            <div class="form-check form-check-inline check-include" style="margin-right:0px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-include" type="checkbox" id="include_freshViolation" value="freshViolation" title="Pokaż tylko świeże naruszenia">
                            </div>
                            <div class="form-check form-check-inline check-exclude" style="margin-right:0px; padding-left:16px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-exclude" type="checkbox" id="exclude_freshViolation" value="freshViolation" title="Ukryj świeże naruszenia">
                            </div>
                            <span class="flag-name-count" style="font-size:14px; font-weight: 400; flex: 1; min-width: 0; margin-left: 6px;">Świeże naruszenie</span>
                        </div>
                        <div class="flag-filter-group" style="display: flex; align-items: center; max-width: 100%; margin-top: 4px;">
                            <div class="form-check form-check-inline check-include" style="margin-right:0px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-include" type="checkbox" id="include_currentlyViolating" value="currentlyViolating" title="Pokaż tylko obecne naruszenia">
                            </div>
                            <div class="form-check form-check-inline check-exclude" style="margin-right:0px; padding-left:16px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-exclude" type="checkbox" id="exclude_currentlyViolating" value="currentlyViolating" title="Ukryj obecne naruszenia">
                            </div>
                            <span class="flag-name-count" style="font-size:14px; font-weight: 400; flex: 1; min-width: 0; margin-left: 6px;">Obecne naruszenie</span>
                        </div>
                    </div>

                    <div class="Category-Container-Select">Dostępność konkurencji</div>
                    <div class="store-section">
                        <div class="flag-filter-group" style="display: flex; align-items: center; max-width: 100%;">
                            <div class="form-check form-check-inline check-include" style="margin-right:0px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-include" type="checkbox" id="include_compStockAvailable" value="compStockAvailable" title="Pokaż tylko dostępne">
                            </div>
                            <div class="form-check form-check-inline check-exclude" style="margin-right:0px; padding-left:16px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-exclude" type="checkbox" id="exclude_compStockAvailable" value="compStockAvailable" title="Ukryj dostępne">
                            </div>
                            <span class="flag-name-count" style="font-size:14px; font-weight: 400; flex: 1; min-width: 0; margin-left: 6px;">Dostępny</span>
                        </div>
                        <div class="flag-filter-group" style="display: flex; align-items: center; max-width: 100%; margin-top: 4px;">
                            <div class="form-check form-check-inline check-include" style="margin-right:0px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-include" type="checkbox" id="include_compStockUnavailable" value="compStockUnavailable" title="Pokaż tylko niedostępne">
                            </div>
                            <div class="form-check form-check-inline check-exclude" style="margin-right:0px; padding-left:16px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-exclude" type="checkbox" id="exclude_compStockUnavailable" value="compStockUnavailable" title="Ukryj niedostępne">
                            </div>
                            <span class="flag-name-count" style="font-size:14px; font-weight: 400; flex: 1; min-width: 0; margin-left: 6px;">Niedostępny</span>
                        </div>
                    </div>

                    <div class="Category-Container-Select">Nowe produkty</div>
                    <div class="store-section">
                        <div class="flag-filter-group" style="display: flex; align-items: center; max-width: 100%;">
                            <div class="form-check form-check-inline check-include" style="margin-right:0px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-include" type="checkbox" id="include_isNew" value="isNew" title="Pokaż tylko nowe">
                            </div>
                            <div class="form-check form-check-inline check-exclude" style="margin-right:0px; padding-left:16px; flex-shrink: 0;">
                                <input class="form-check-input adv-filter-exclude" type="checkbox" id="exclude_isNew" value="isNew" title="Ukryj nowe">
                            </div>
                            <span class="flag-name-count" style="font-size:14px; font-weight: 400; flex: 1; min-width: 0; margin-left: 6px;">Nowy - 7 dni <span id="count-new" style="color: #888; font-size: 0.9em; margin-left: 4px;"></span></span>
                        </div>
                    </div>

                    <div class="Category-Container-Select">Sprzedaż Ceneo - 90 dni</div>
                    <div class="store-section">
                        <div id="salesSortingButtons">
                            <button id="sortCeneoSales">Sprzedaż - ilość</button>
                            <button id="sortSalesTrendAmount">Trend - ilość</button>
                            <button id="sortSalesTrendPercent">Trend - %</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== PRAWY PANEL ===================== -->
            <div class="Horizontal">

                <div class="order-upper-box">
                    <input type="text" id="productSearch" style="max-width:140px; height:34px;" placeholder="Wyszukaj produkt">
                    <input type="text" id="storeSearch" style="max-width:140px; height:34px;" placeholder="Wyszukaj sklep">

                    <select id="producerFilterDropdown" class="DropDown" style="max-width:140px; height:34px;">
                        <option value="">Wszystkie marki</option>
                    </select>

                    <span id="producerModeBadge" class="producer-mode-badge">
                        <i class="fa-solid fa-anchor"></i>
                        <span>Tryb: MAP (%)</span>
                    </span>

                    <button type="button" class="Button-Page-Small" style="height: 34px; max-width: 250px; padding: 0 12px; text-align: left; display: inline-flex; align-items: center;" id="presetButton" onclick="openCompetitorsModal()">
                        <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0;">Presety</span>
                    </button>
                    <button class="Button-Page-Small" style="white-space: nowrap;" id="exportToExcelButton"><i class="fa-solid fa-floppy-disk" style="margin-top:2px;"></i>Eksport</button>

                    <button type="button" class="Button-Page-Small" style="white-space: nowrap;" id="apiExportSettingsBtn" data-toggle="modal" data-target="#apiExportModal">
                        <i class="fa-solid fa-code" style="margin-top:2px;"></i>Feed
                    </button>

                    <button type="button" class="Button-Page-Small" style="justify-self:flex-end; margin-right:4px;" data-toggle="modal" data-target="#infoModal">
                        <i class="fa fa-info-circle"></i>
                    </button>

                    <div class="SimpleSpace" style="justify-content:flex-end; margin-right: 12px;">
                        <div id="selectionContainer" class="selection-container">
                            <span id="selectedProductsCounter" class="ProductCount" style="width:126px; height:34px;">Wybrano: 0</span>
                            <button id="selectAllVisibleBtn" class="Button-Page-Small" style="width:48px;" title="Zaznacz wszystkie widoczne produkty">
                                <i class="fa-solid fa-square-check"></i>
                            </button>
                            <button id="deselectAllVisibleBtn" class="Button-Page-Small" style="width:48px;" title="Odznacz wszystkie widoczne produkty">
                                <i class="fa-solid fa-square-xmark"></i>
                            </button>
                            <button id="showSelectedProductsBtn" class="Button-Page-Small" style="width:100px;">Akcje</button>
                        </div>
                    </div>
                </div>

                <div id="sortingButtons">
                    <div class="ProductCount" id="displayedProductCount"></div>
                    <div id="paginationContainer"></div>

                    <button id="sortName">A-Z</button>
                    <button id="sortPrice">Cena ref.</button>
                    <button id="sortDeltaPercent">Delta %</button>
                    <button id="sortDeltaAmount">Delta PLN</button>
                    <button id="sortDaysViolation">Dni naruszenia</button>
                    <button id="sortStoresViolating">Liczba naruszycieli</button>
                </div>

                <div class="buttonsContainer">
                    <div id="priceChangeSummary" class="priceChangeSummary">
                        <div id="summaryText"></div>
                        <button id="openProducerSettingsBtn" class="Button-Page-Small" style="width:48px;" title="Konfiguracja monitoringu"><i class="fa fa-cog"></i></button>
                    </div>
                </div>

                <div class="Vert-table">
                    <div id="priceContainer" class="price-container"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ==== MODAL: Konfiguracja producenta (tylko 2 ustawienia) ==== -->
<div class="modal fade" id="producerSettingsModal" tabindex="-1" role="dialog" aria-labelledby="producerSettingsModalLabel" aria-hidden="true">
    <div class="modal-dialog" style="max-width:600px" role="document">
        <div class="modal-content" style="margin: 10% auto;">
            <div class="modal-header">
                <div class="price-box-column-name" id="producerSettingsModalLabel">Konfiguracja monitoringu</div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Zamknij">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom: 24px; line-height: 1.6;">
                    Skonfiguruj sposób identyfikacji produktów oraz źródło ceny referencyjnej, względem której będą porównywane oferty rynkowe.
                </p>

                <div class="form-group" style="margin-bottom: 20px;">
                    <label for="identifierForSimulationInput">Element nawigacyjny dla produktów</label>
                    <select class="form-control" id="identifierForSimulationInput">
                        <option value="EAN">EAN</option>
                        <option value="ID">ID</option>
                        <option value="ProducerCode">Kod producenta</option>
                    </select>
                </div>

                <div class="form-group" style="margin-bottom: 20px;">
                    <label for="comparisonSourceInput">Źródło ceny referencyjnej</label>
                    <select class="form-control" id="comparisonSourceInput">
                        <option value="1">Cena MAP (z pola „cena zakupu")</option>
                        <option value="0">Cena Twojego sklepu</option>
                    </select>
                    <small style="color: #888; display: block; margin-top: 6px; font-size: 12px; line-height: 1.4;">
                        <strong>Cena MAP</strong> - używana, gdy producent ma zdefiniowaną politykę MAP w katalogu produktów.<br>
                        <strong>Cena Twojego sklepu</strong> - używana, gdy producent ma własny sklep online jako benchmark.
                    </small>
                </div>
            </div>
            <div class="modal-footer" style="justify-content:space-between;">
                <button type="button" class="Button-Page-Small" data-dismiss="modal">Anuluj</button>
                <button type="button" class="Button-Page-Small-bl" id="saveProducerModalBtn">Zapisz</button>
            </div>
        </div>
    </div>
</div>

