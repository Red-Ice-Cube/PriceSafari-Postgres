                        <span style="color:#888; font-size:12px;">%</span>
                    </div>
                    <div class="error-message-row" id="errAbovePct"></div>
                </div>

                <div id="thresholdsBlock_amt" style="display:none;">
                    <div class="threshold-section-title" style="color:#DC143C;">Progi „poniżej" (PLN różnicy)</div>
                    <div class="threshold-row">
                        <div class="color-rect rect-deep-violation"></div>
                        <label for="thrRedDarkAmt">Drastyczne naruszenie (poniżej)</label>
                        <input type="number" id="thrRedDarkAmt" class="threshold-input amt" data-group="below-amt" data-level="3" step="1" min="0" placeholder="50.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="threshold-row">
                        <div class="color-rect rect-violation"></div>
                        <label for="thrRedAmt">Naruszenie</label>
                        <input type="number" id="thrRedAmt" class="threshold-input amt" data-group="below-amt" data-level="2" step="1" min="0" placeholder="20.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="threshold-row">
                        <div class="color-rect rect-minor-below"></div>
                        <label for="thrRedLightAmt">Lekko poniżej (próg tolerancji)</label>
                        <input type="number" id="thrRedLightAmt" class="threshold-input amt" data-group="below-amt" data-level="1" step="1" min="0" placeholder="5.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="error-message-row" id="errBelowAmt"></div>

                    <div class="threshold-section-title" style="color:#228B22;">Progi „powyżej" (PLN różnicy)</div>
                    <div class="threshold-row">
                        <div class="color-rect rect-minor-above"></div>
                        <label for="thrGreenLightAmt">Lekko powyżej (próg tolerancji)</label>
                        <input type="number" id="thrGreenLightAmt" class="threshold-input amt" data-group="above-amt" data-level="1" step="1" min="0" placeholder="5.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="threshold-row">
                        <div class="color-rect rect-above"></div>
                        <label for="thrGreenAmt">Powyżej</label>
                        <input type="number" id="thrGreenAmt" class="threshold-input amt" data-group="above-amt" data-level="2" step="1" min="0" placeholder="20.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="threshold-row">
                        <div class="color-rect rect-deep-above"></div>
                        <label for="thrGreenDarkAmt">Mocno powyżej</label>
                        <input type="number" id="thrGreenDarkAmt" class="threshold-input amt" data-group="above-amt" data-level="3" step="1" min="0" placeholder="50.00">
                        <span style="color:#888; font-size:12px;">PLN</span>
                    </div>
                    <div class="error-message-row" id="errAboveAmt"></div>
                </div>

                <div style="margin-top:20px; padding:12px; background:#f0f4f8; border-left:4px solid #4169E1; border-radius:4px; font-size:13px; color:#333;">
                    <i class="fa-solid fa-circle-info" style="color:#4169E1; margin-right:5px;"></i>
                    <strong>Zasada progów:</strong> próg „lekki" musi być mniejszy lub równy progowi „normalnemu", a normalny mniejszy lub równy „mocnemu". System wykorzystuje aktywny tryb (PLN albo %) – nieaktywny tryb i tak musi mieć poprawne wartości na wypadek przełączenia.
                </div>
            </div>
            <div class="modal-footer" style="justify-content:space-between;">
                <button type="button" class="Button-Page-Small" data-dismiss="modal">Anuluj</button>
                <button type="button" class="Button-Page-Small-bl" id="saveProducerSettingsBtn">Zapisz ustawienia</button>
            </div>
        </div>
    </div>
</div>

